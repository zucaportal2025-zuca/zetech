{Songs:[{Guid:"SthxFDz+oEmYgDR+m+mguw",Verses:[{
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>SOMO LA KWANZA
2 Samueli 7;4-17</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1384>Somo katika kitabu cha pili cha Samueli
Siku zile: </s></f>"},{ID:3,
Text:"<fArial Black><s1384>Neno la Bwana lilimjia Nathani kusema: Nenda 
ukamwambie mtumishi wangu Daudi, Bwana anasema
hivi: </s></f>"},{ID:4,
Text:"<fArial Black><s1384>Je, wewe utanijengea nyumba, nikae ndani yake?</s></f>"},{ID:5,
Text:"<fArial Black><s1384>Mimi sijakaa katika nyumba tangu siku ile niliyowatoa Waisraeli kutoka Misri,</s></f>"},{ID:6,
Text:"<fArial Black><s1384>hata leo, lakini nimezunguka katika hema na kibanda. Wakati</s></f>"},{ID:7,
Text:"<fArial Black><s1384>wote nimesafiri na Waisraeli, nimewahi kumwambia mmoja,</s></f>"},{ID:8,
Text:"<fArial Black><s1384>wa waamuzi wa Israeli niliowaweka kuwaongoza, 
watu wangu  Israeli, nikisema: </s></f>"},{ID:9,
Text:"<fArial Black><s1384>Mbona hamkunijengea nyumba ya mielezi?</s></f>"},{ID:10,
Text:"<fArial Black><s1384>Sasa ukamwambie mtumishi wangu Daudi ifuatavyo: </s></f>"},{ID:11,
Text:"<fArial Black><s1384>Bwana wa majeshi asema hivi: Mimi nalikutwaa katika</s></f>"},{ID:12,
Text:"<fArial Black><s1384>kazi ya kuwalisha na kuwaandama kondoo,</s></f>"},{ID:13,
Text:"<fArial Black><s1384> ili uwe mkuu juu ya watu wangu Israeli,</s></f>"},{ID:14,
Text:"<fArial Black><s1384>nimekuwa pamoja nawe popote ulipokwenda na</s></f>"},{ID:15,
Text:"<fArial Black><s1384>nimewaondosha maadui zako wote mbele yako. </s></f>"},{ID:16,
Text:"<fArial Black><s1384>Nami  nitakufanyia  jina la wakuu waliopo duniani. </s></f>"},{ID:17,
Text:"<fArial Black><s1384>Nami nitawawekea mahali watu wangu Israeli, </s></f>"},{ID:18,
Text:"<fArial Black><s1384>nitawapanda wapate kukaa mahali</s></f>"},{ID:19,
Text:"<fArial Black><s1384>pao wenyewe, wasiweze kuondolewa tena, </s></f>"},{ID:20,
Text:"<fArial Black><s1384>wala wana wa uovu hawatawasumbua tena, </s></f>"},{ID:21,
Text:"<fArial Black><s1384>kama hapo zamani, tangu nilipowaweka waamuzi,</s></f>"},{ID:22,
Text:"<fArial Black><s1384>juu ya Israeli watu wangu. Nami nitakustarehesha mbele ya</s></f>"},{ID:23,
Text:"<fArial Black><s1384>adui zako wote. Tena, Bwana anakufunulia kuwa atakujengea nyumba. </s></f>"},{ID:24,
Text:"<fArial Black><s1384>siku zako zitakapotimia, nawe umejipumzisha</s></f>"},{ID:25,
Text:"<fArial Black><s1384>na baba zako, nitamwinua mzao wako, </s></f>"},{ID:26,
Text:"<fArial Black><s1384>baada yako atokaye viunoni mwako, nami nitauimarisha ufalme wake. </s></f>"},{ID:27,
Text:"<fArial Black><s1384>Yeye ndiye atakayenijengea nyumba kwa jina langu, </s></f>"},{ID:28,
Text:"<fArial Black><s1384>nami nitakiimarisha kiti chake cha enzi daima. </s></f>"},{ID:29,
Text:"<fArial Black><s1384>Mimi nitakuwa baba yake, naye atakuwa mwanangu; </s></f>"},{ID:30,
Text:"<fArial Black><s1384>na akitenda uovu nitamwadhibu kwa</s></f>"},{ID:31,
Text:"<fArial Black><s1384>fimbo watumiayo watu na mapıgo wapigayo wanadamu,</s></f>"},{ID:32,
Text:"<fArial Black><s1384>Bali sitamwondolea fadhili zangu, </s></f>"},{ID:33,
Text:"<fArial Black><s1384>kama nilivyomwondolea mtangulizi wako, </s></f>"},{ID:34,
Text:"<fArial Black><s1384>Sauli, ambaye nilimwondoa mbele yangu. </s></f>"},{ID:35,
Text:"<fArial Black><s1384>Nayo nyumba yako na ufalme wako vitadumu milele mbele yangu, </s></f>"},{ID:36,
Text:"<fArial Black><s1384>na kiti chako kitakaa imara milele, </s></f>"},{ID:37,
Text:"<fArial Black><s1384>Nathani aliyanena maneno hayo na ufunuo huo wote kwa Daudi.</s></f>"},{ID:38,
Text:"<fArial Black><s1384>Neno la Bwana.
(sifa kwako ee Kristu)</s></f>"},{ID:39,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>ZABURI YA KUITIKIZANA
Zaburi 89:4-5, 27-28, 29-30 (K. 29a)</k></c></s></f>"},{ID:40,
Text:"<fArial Black><s1384>K. Nitadumisha fadhili zangu hata milele.</s></f>"},{ID:41,
Text:"<fArial Black><s1384>1.Nimefunga agano na mteule wangu;
nimemwapia Daudi, mtumishi wangu:</s></f>"},{ID:42,
Text:"<fArial Black><s1384>nitawasimika wazao wako hata milele,
nitaimarisha kiti cha ufalme wako kwa vizazi vyote. K.</s></f>"},{ID:43,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>K. Nitadumisha fadhili zangu hata milele.</k></c></s></f>"},{ID:44,
Text:"<fArial Black><s1384>2.Yeye ataniita, “Wewe ni Baba yangu,
Mungu wangu na mwamba wa Wokovu wangu,</s></f>"},{ID:45,
Text:"<fArial Black><s1384>Nami nitamweka awe mzaliwa wangu wa kwanza,
kua juu sana kuliko wafalme wa dunia. K.</s></f>"},{ID:46,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>K. Nitadumisha fadhili zangu hata milele.</k></c></s></f>"},{ID:47,
Text:"<fArial Black><s1384>3.Nitamhifadhia fadhili zangu hata milele; 
na agano langu kwake litadumu kuwa imara.</s></f>"},{ID:48,
Text:"<fArial Black><s1384>Nitasimika uzazi wake milele. 
na kiti chake cha enzi kitadumu kama mbingu.” K.</s></f>"},{ID:49,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>K. Nitadumisha fadhili zangu hata milele.</k></c></s></f>"},{ID:50,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>SHANGILIO LA INJILI
</k></c></s></f><fArial Black><s1384>K. Aleluya. W. Aleluya.</s></f>"},{ID:51,
Text:"<fArial Black><s1384>Mbegu ni neno la Mungu, anayepanda ni Kristo;
atakayempata ataishi milele.</s></f>"},{ID:52,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>W. Aleluya.
W. Aleluya.</k></c></s></f>"},{ID:53,
Text:"<fArial Black><s1384>INJILI
</s></f><fArial Black><s1384><cFFF2F200><kFFFF0000>Marko 4:1-20</k></c></s></f>"},{ID:54,
Text:"<fArial Black><s1384>Somo la Injili takatifu ilivyoandikwa na Marko</s></f>"},{ID:55,
Text:"<fArial Black><s1384>Wakati ule: Yesu alianza kufundisha tena kando ya ziwa. </s></f>"},{ID:56,
Text:"<fArial Black><s1384>Kundi kubwa lilikusanyika mbele yake, </s></f>"},{ID:57,
Text:"<fArial Black><s1384>hata akaingia katika chombo ziwani, akaketi humo. </s></f>"},{ID:58,
Text:"<fArial Black><s1384>Watu wote walikaa kando ya ziwa.</s></f>"},{ID:59,
Text:"<fArial Black><s1384>Aliwafundisha mengi kwa mifano, na katika mafundisho yake
aliwaambia, </s></f>"},{ID:60,
Text:"<fArial Black><s1384>\"Sikilizeni! Mpanzi alikwenda shambani kupanda
mbegu. </s></f>"},{ID:61,
Text:"<fArial Black><s1384>Katika kupanda, mbegu nyingine zilianguka kando ya
njia, </s></f>"},{ID:62,
Text:"<fArial Black><s1384>wakaja ndege, wakazidonoa. Nyingine zilianguka penye
changarawe pasipo udongo mwingi. </s></f>"},{ID:63,
Text:"<fArial Black><s1384>Zikaota upesi lakini chini
kina hakikupatikana. </s></f>"},{ID:64,
Text:"<fArial Black><s1384>Na jua lilipochomoza ziliungua, zikanyauka
kwa kukosa mizizi. </s></f>"},{ID:65,
Text:"<fArial Black><s1384>Nyingine zilianguka kati ya miiba na miiba</s></f>"},{ID:66,
Text:"<fArial Black><s1384>ikamea, ikazisonga, zisitoe mavuno. </s></f>"},{ID:67,
Text:"<fArial Black><s1384>Nyingine zilianguka katika udongo mzuri, zikaota, zikakua, </s></f>"},{ID:68,
Text:"<fArial Black><s1384>zikazaa moja thelathini,nyingine sitini, na nyingine mia.</s></f>"},{ID:69,
Text:"<fArial Black><s1384>Akasema, Aliye na masikio ya kusikilizia, na asikie.” </s></f>"},{ID:70,
Text:"<fArial Black><s1384>Baadaye alipokuwa peke yake, </s></f>"},{ID:71,
Text:"<fArial Black><s1384>wale Kumi na Wawili pamoja na maana ya mifano,
Akawajibu, </s></f>"},{ID:72,
Text:"<fArial Black><s1384>Ninyi mmejaliwa kujua mfano wa ufalme wa Mungu,
bali wale walio nje hupewa yote kwa mifano, </s></f>"},{ID:73,
Text:"<fArial Black><s1384>ili kuona Waone, wasitambue, kusikia wasikie,
wasielewe, wasije wakaongoka</s></f>"},{ID:74,
Text:"<fArial Black><s1384>na dhambi kusamehewa.\"\" Yesu akawaambia, “Je, </s></f>"},{ID:75,
Text:"<fArial Black><s1384>hamwelewi mfano huu? Mtawezaje kufahamu mifano yoyote?</s></f>"},{ID:76,
Text:"<fArial Black><s1384>Mpanzi analipanda neno. Hawa ni wale walio</s></f>"},{ID:77,
Text:"<fArial Black><s1384>kando ya njia wakati neno linapopandwa. </s></f>"},{ID:78,
Text:"<fArial Black><s1384>Mara wanapolisikia, Shetani huja, akalichukua </s></f>"},{ID:79,
Text:"<fArial Black><s1384>neno lililopandwa mioyoni mwao. Na wale waliopandwa kwenye
changarawe ni wale ambao, </s></f>"},{ID:80,
Text:"<fArial Black><s1384>wanapolisikia neno, mara wanalipo kea kwa furaha. 
Ila hawana mizizi ndani  mwao: </s></f>"},{ID:81,
Text:"<fArial Black><s1384>wanalipokea kwa muda tu. Panapotokea matatizo au madhulumu
kwa ajili ya hilo neno, mara wanakwazwa. </s></f>"},{ID:82,
Text:"<fArial Black><s1384>Wale waliopandwa kati ya miiba, hao
ni wale wanaolisikia neno, lakini shughuli za dunia, </s></f>"},{ID:83,
Text:"<fArial Black><s1384>na ulaghai wa mali, na tamaa za mambo mengine, 
zinaingia kulisonga neno,</s></f>"},{ID:84,
Text:"<fArial Black><s1384>na hivyo neno halizai kitu. Kisha waliopandwa</s></f>"},{ID:85,
Text:"<fArial Black><s1384>katika undongo wenye rutuba, hawa ndio wanaolisikia wakalipokea,</s></f>"},{ID:86,
Text:"<fArial Black><s1384>wakazaa matunda mmoja thelathini, mmoja sitini, na
na mmoja mia,\"</s></f>"},{ID:87,
Text:"<fArial Black><s1384>Injili  ya bwana</s></f>"}],
Text:"JUMATANO 28 JAN MWAKA A"},{Guid:"gV4h6OUA60CPcNeoiDyBDw",Verses:[{
Text:"<fArial Black><s1846>SOMO LA KWANZA 
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>2 Samueli 24:12,9-17</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha pili cha Samueli</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Silu zile: Mfalme Daudi aliwaagiza Yoabu na wakuu wa jeshi
waliokuwa pamoja naye, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>\"Zungukeni makabila yote ya Israeli
toka Dani mpaka Beersheba, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>na mkawahesabu watu ili nipate
kujua jumla yao.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>\" Kisha Yoabu akampa mfalme hesabu ya
walioandikishwa: </s></f>"},{ID:7,
Text:"<fArial Black><s1846>katika Israeli watu mia nane elfu, mashujaa
wenye kufuta upanga,</s></f>"},{ID:8,
Text:"<fArial Black><s1846>na katika Yuda watu mia tano elfu.
Baadaye, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>moyo wake Daudi ukamsuta kwa kuwa amewahesabu
watu, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>na akamwambia Bwana, Nimekosa sana kwa mambo haya
niliyoyatenda. Lakini,</s></f>"},{ID:11,
Text:"<fArial Black><s1846> sasa ee Bwana, nakusihi uusamehe uovu wa
mtumishi wako, kwani nimefanya upumbavu kabisa.</s></f>"},{ID:12,
Text:"<fArial Black><s1846>\" Na Daudi
alipoamka asubuhi, neno la Bwana lilikuwa limemjia nabii Gadi,</s></f>"},{ID:13,
Text:"<fArial Black><s1846>mwonaji wa Daudi, kusema, Nenda ukamwambie Daudi: Bwana
asema hivi: </s></f>"},{ID:14,
Text:"<fArial Black><s1846>Ninakuletea mambo matatu, chagua moja katika hayo,
nami nitakutendea.\" </s></f>"},{ID:15,
Text:"<fArial Black><s1846>Gadi, akamwendea Daudi na kumwambia,
Wataka ikujie miaka mitatu ya njaa katika nchi yako;</s></f>"},{ID:16,
Text:"<fArial Black><s1846>au ukimbie kwa miezi mitatu mbele ya adui zako, wakikufuatilia?</s></f>"},{ID:17,
Text:"<fArial Black><s1846> Au kwa siku tatu kuwe na tauni katika nchi yako? Sasa fikiri, na uamue,</s></f>"},{ID:18,
Text:"<fArial Black><s1846>nimjibu nini yule aliyenituma.\" Daudi akamwambia Gadi,</s></f>"},{ID:19,
Text:"<fArial Black><s1846>Ninahangaika sana: na tuanguke katika mikono ya Bwana,</s></f>"},{ID:20,
Text:"<fArial Black><s1846>maana huruma yake ni kubwa, wala nisianguke katika mikono
ya watu.\" </s></f>"},{ID:21,
Text:"<fArial Black><s1846>Hivyo Daudi akachagua tauni. Nao ulikuwa wakati wa
kuvuna ngano hapo Bwana alipoleta tauni katika Israeli, </s></f>"},{ID:22,
Text:"<fArial Black><s1846>Bwana akaleta tauni katika Israeli tangu asubuhi,</s></f>"},{ID:23,
Text:"<fArial Black><s1846>hata muda ulioamriwa na
wakaanguka watu elfu sabini kutoka Dani hata Beersheba. </s></f>"},{ID:24,
Text:"<fArial Black><s1846>Lakini huyo malaika aliponyosha mkono wake kuelekea Yerusalemu ili kuiharibu, </s></f>"},{ID:25,
Text:"<fArial Black><s1846>Bwana akaghairi maafa yale na kumwambia huyo
malaika mwenye kuharibu watu, Inatosha! </s></f>"},{ID:26,
Text:"<fArial Black><s1846>Legeza sasa mkono wako.\" 
Na malaika yule alikuwa amesimama, </s></f>"},{ID:27,
Text:"<fArial Black><s1846>karibu na uwanja wa
kupuria nafaka wa Arauna, Myebusi. </s></f>"},{ID:28,
Text:"<fArial Black><s1846>Daudi alipomwona malaika
aliyewapiga watu, </s></f>"},{ID:29,
Text:"<fArial Black><s1846>akasema na Bwana akimwambia, Tazama, </s></f>"},{ID:30,
Text:"<fArial Black><s1846>ni mimi niliyekosa, ni mimi mchungaji niliyepotoka, lakini kondoo hawa, wamefanya nini? </s></f>"},{ID:31,
Text:"<fArial Black><s1846>Basi, mkono wako na uwe juu yangu, na
Juu ya jamaa yangu!\"</s></f>"},{ID:32,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:33,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 32:1-2, 5, 6, 7 (K. Sa)</k></c></s></f>"},{ID:34,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>K Ee Bwana, uusamehe uovu wa dhambi Yangu</k></c></s></f><fArial Black><s1846>.</s></f>"},{ID:35,
Text:"<fArial Black><s1846>1.Heri mtu yule aliyesamehewa dhambi yake,
na kusitiriwa makosa yake. </s></f>"},{ID:36,
Text:"<fArial Black><s1846>Heri mtu yule ambaye Bwana hamhesabu kuwa mwenye hatia, na ambaye moyo wake hauna hila. K.</s></f>"},{ID:37,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>K Ee Bwana, uusamehe uovu wa dhambi yangu.</k></c></s></f>"},{ID:38,
Text:"<fArial Black><s1846>2.Nilikujulisha dhambi yangu;
wala sikulificha kosa langu.</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Kwa hiyo kila mcha mungu akuombe
Nikasema, </s></f>"},{ID:40,
Text:"<fArial Black><s1846>\"Nitamwungamia Bwana uovu wangu
nawe ukausamehe uovu wa dhambi yangu. K.</s></f>"},{ID:41,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>K Ee Bwana, uusamehe uovu wa dhambi yangu.</k></c></s></f>"},{ID:42,
Text:"<fArial Black><s1846>3.Wewe ndiwe sitara yangu:
unanihifadhi na mateso;
wanizungushia nyimbo za wokovu.</s></f>"},{ID:43,
Text:"<fArial Black><s1846>Mafuriko ya maji yatafika juu / lakini hayatamfikia yeye. K.</s></f>"},{ID:44,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>K Ee Bwana, uusamehe uovu wa dhambi yangu.</k></c></s></f>"},{ID:45,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Yohane 10:27</k></c></s></f>"},{ID:46,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>K. Aleluya. W. Aleluya.</k></c></s></f>"},{ID:47,
Text:"<fArial Black><s1846>K. Kondoo wangu huisikia sauti yangu, asema Bwana;
nami nawajua, nao wanifuata.</s></f>"},{ID:48,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>W. Aleluya.</k></c></s></f>"},{ID:49,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Marko 6:1-6</k></c></s></f>"},{ID:50,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Marko</s></f>"},{ID:51,
Text:"<fArial Black><s1846>Wakati ule: Yesu alikwenda mjini kwake; wafuasi wake walifuatana naye. </s></f>"},{ID:52,
Text:"<fArial Black><s1846>Siku ya Sabato alianza kufundisha katika sinagogi;</s></f>"},{ID:53,
Text:"<fArial Black><s1846>wengi waliomsikia, walishangaa sana, wakasema,</s></f>"},{ID:54,
Text:"<fArial Black><s1846>\"Amepata wapi haya? Je, hekima gani hii aliyopewa huyu? </s></f>"},{ID:55,
Text:"<fArial Black><s1846>Tena imekuwaje matendo ya ajabu yatendwa kwa mikono yake! </s></f>"},{ID:56,
Text:"<fArial Black><s1846>Je, huyu si seremala, mwana wa Maria</s></f>"},{ID:57,
Text:"<fArial Black><s1846>, na ndugu yake Yakobo, na Yose, na Yuda, na Simoni? </s></f>"},{ID:58,
Text:"<fArial Black><s1846>Na dada zake hawakai hapa kwetu?</s></f>"},{ID:59,
Text:"<fArial Black><s1846>Wakakwazika kwake. Yesu akawaambia, \"Nabii hakosi heshima, </s></f>"},{ID:60,
Text:"<fArial Black><s1846>ila katika mji wake na kwa jamaa zake, na nyumbani mwake.</s></f>"},{ID:61,
Text:"<fArial Black><s1846>Hakuweza kufanya mwujiza huko, isipokuwa kuponya wagonjwa wachache kwa kuwawekea mikono.</s></f>"},{ID:62,
Text:"<fArial Black><s1846>Alishangaa kwa sababu ya
ukosefu wao wa imani.</s></f>"},{ID:63,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],Style:{Body:{VerticalAlignment:0,Transition:15},Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_80a6444a.jpg"}},
Text:"JUMATANO 4 FEB MWAKA A"},{Guid:"DIJ4dqoV/k+dWMmPtvAfdQ",Verses:[{
Text:"<u><fArial Black><s1846>SOMO LA KWANZA
</s></f></u><fArial Black><s1846><cFFF2F200><kFFFF0000>1 Wafalme 10:1-10</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha kwanza cha Wafalme</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Siku zile: Malkia wa Sheba aliposikia umaarufu wa Sulemani alimjia ili kumjaribu kwa maswali ya mafumbo. </s></f>"},{ID:4,
Text:"<fArial Black><s1846>Alifika Yerusalemu na wafuasi wengi sana na ngamia waliochukua manukato, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>dhahabu nyingi sana, na vito vya thamani. </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Alipofika kwa Sulemani alimwuliza yote aliyokuwa nayo moyoni mwake. </s></f>"},{ID:7,
Text:"<fArial Black><s1846>Naye Sulemani akamfumbulia maswali yake yote, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>wala hakukuwa na neno aliloshindwa kumfumbulia. </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Basi malkia wa Sheba alipoonahekima nyingi za Sulemani, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>na nyumba aliyoijenga, na chakula kilichowekwa mezani pake, </s></f>"},{ID:11,Style:{Body:{Transition:15}},
Text:"<fArial Black><s1846>na watumishi walivyokaa, na wahudumu wake walivyosimama na mavazi yao, na wanyweshaji wake, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>na sadaka alizotolea hekaluni mwa Bwana, aliishiwa pumzi.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>“Habari nilizosikia nchini mwangu juu ya matendo yako na hekima zako ni za kweli,” </s></f>"},{ID:14,
Text:"<fArial Black><s1846>alimwambia mfalme. “Ingawa sikuzisadiki
habari hizo, mpaka nimefika na kuona yote kwa macho yangu,</s></f>"},{ID:15,
Text:"<fArial Black><s1846>nimegundua kuwa hata nusu sikuambiwa. Kwa maana hekima yako imezidi, </s></f>"},{ID:16,
Text:"<fArial Black><s1846>na kufanikiwa sana kuliko habari nilizozisikia. Heri
watu wako, </s></f>"},{ID:17,
Text:"<fArial Black><s1846>heri hawa watumishi wako, wanaosimama mbele
yako daima, </s></f>"},{ID:18,
Text:"<fArial Black><s1846>wakisikia hekima yako. Na ahimidiwe Bwana Mungu
wako, </s></f>"},{ID:19,
Text:"<fArial Black><s1846>aliyependezwa nawe na kukuweka juu ya kiti cha ufalme wa Israeli. </s></f>"},{ID:20,
Text:"<fArial Black><s1846>Kwa upendo wake wa milele kwa Israeli, </s></f>"},{ID:21,
Text:"<fArial Black><s1846>Bwana
amekufanya mfalme juu yake ili utende hukumu na haki.”</s></f>"},{ID:22,
Text:"<fArial Black><s1846>Kisha akampa mfalme talanta mia moja na ishirini za dhahabu,</s></f>"},{ID:23,
Text:"<fArial Black><s1846>na manukato mengi sana, na vito vya thamani. Wala hakutokea tena mtu aliyemletea mfalme Sulemani, </s></f>"},{ID:24,
Text:"<fArial Black><s1846>uwingi wa manukato kama ya malkia wa Sheba.</s></f>"},{ID:25,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:26,
Text:"<u><fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f></u><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 37:5-6, 30-31, 39-40 (K. 30a)</k></c></s></f>"},{ID:27,
Text:"<fArial Black><s1846>K </s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Kinywa cha mwenye haki hunena hekima.</k></c></s></f>"},{ID:28,
Text:"<fArial Black><s1846>1.Umkabithi Bwana njia yako;
mtumainie naye atatenda,</s></f>"},{ID:29,
Text:"<fArial Black><s1846>na ufanye unyofu wako unga’re kama mwanga,
na haki ya njia yako kama jua la adhuhuri. K.</s></f>"},{ID:30,
Text:"<fArial Black><s1846><kFFFF0000>K </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Kinywa cha mwenye haki hunena hekima.</k></c></s></f>"},{ID:31,
Text:"<fArial Black><s1846>2.Kinywa cha mtu mwenye haki hunena hekima,
ulimi wake husema yaliyo kweli.</s></f>"},{ID:32,
Text:"<fArial Black><s1846>Sheria ya Mungu imo moyoni mwake;
hatua zake hazitateleza. K.</s></f>"},{ID:33,
Text:"<fArial Black><s1846><kFFFF0000>K </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Kinywa cha mwenye haki hunena hekima.</k></c></s></f>"},{ID:34,
Text:"<fArial Black><s1846>3.Wokovu wa wenye haki watoka kwa Bwana,
yeye ni kimbilio lao wakati wa shida.</s></f>"},{ID:35,
Text:"<fArial Black><s1846>Bwana huwasaidia na kuwaopoa,
nuwaopoa na waovu, na kuwakomboa:</s></f>"},{ID:36,
Text:"<fArial Black><s1846>kwa kuwa wamemkimbilia Mungu. K.</s></f>"},{ID:37,
Text:"<fArial Black><s1846><kFFFF0000>K </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Kinywa cha mwenye haki hunena hekima.</k></c></s></f>"},{ID:38,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Tazama Yohane 17:1 7b. a</k></c></s></f>"},{ID:39,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:40,
Text:"<fArial Black><s1846>K. Neno lako, ee Bwana, ni kweli;
ututakase kwa hiyo kweli.</s></f>"},{ID:41,
Text:"<fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>. Aleluya.</k></c></s></f>"},{ID:42,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Marko 7:14-23</k></c></s></f>"},{ID:43,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Marko</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Wakati ule:
Yesu aliwaita watu tena, akawaambia, </s></f>"},{ID:45,
Text:"<fArial Black><s1846>“Nisikieni, ninyi nyote, na eleweni. </s></f>"},{ID:46,
Text:"<fArial Black><s1846>Hakuna kitu kinachomwingia mtu kutoka nje kinachoweza kumnajisi;  </s></f>"},{ID:47,
Text:"<fArial Black><s1846>bali vitu vimtokavyo mtu vyamtia unajisi.”</s></f>"},{ID:48,
Text:"<fArial Black><s1846>Alipowaacha watu na kuingia nyumbani, wafuasi wake walimwuliza maana ya mfano. </s></f>"},{ID:49,
Text:"<fArial Black><s1846>Naye akawaambia, “Yaani, hata ninyi hamna
ufahamu? </s></f>"},{ID:50,
Text:"<fArial Black><s1846>Hamwelewi ya kuwa kitu kinachomwingia mtu toka
nje hakiwezi kumnajisi, </s></f>"},{ID:51,
Text:"<fArial Black><s1846>kwa maana hakimwingii moyoni,
ila tumboni? </s></f>"},{ID:52,
Text:"<fArial Black><s1846>Kutoka humo chaondoshwa kikaishia chooni.”</s></f>"},{ID:53,
Text:"<fArial Black><s1846>(Kwa kusema hivi alitangaza ya kuwa vyakula vyote ni halali.)</s></f>"},{ID:54,
Text:"<fArial Black><s1846>“Lakini yamtokayo mtu ndiyo yanayomnajisi. Kwa maana kutoka ndani ya watu, </s></f>"},{ID:55,
Text:"<fArial Black><s1846>kutoka mioyoni mwao, yanatoka mawazo mabaya:</s></f>"},{ID:56,
Text:"<fArial Black><s1846>uasherati, wizi, uuaji, uzinzi, choyo, ukorofi, </s></f>"},{ID:57,
Text:"<fArial Black><s1846>hila, ufisadi, wivu, matusi, kiburi, upumbavu.</s></f>"},{ID:58,
Text:"<fArial Black><s1846>Maovu hayo yote yatoka ndani, nayo yamtia mtu unajisi.”</s></f>"},{ID:59,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],Style:{Body:{VerticalAlignment:0,Transition:14},Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_cb1061b1.jpg",Transition:12,Duration:371,Luminosity:-60}},
Text:"JUMATANO 11 FEB MWAKA A"},{Guid:"e4MupL5kk0SPIV+atHhLuw",Verses:[{
Text:"<u><fArial Black><s1384><cFFF2F200><kFFFF0000>JUMATANO YA MAJIVU</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1384>SOMO 1
</s></f><fArial Black><s1384><cFFF2F200><kFFFF0000>Yoeli 2:12-18</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1384>Somo katika kitabu cha Nabii Yoeli</s></f>"},{ID:3,
Text:"<fArial Black><s1384>Bwana asema hivi: Mnirudie kwa moyo wenu wote, </s></f>"},{ID:4,
Text:"<fArial Black><s1384>kwa kufunga, na kulia, na kuomboleza. </s></f>"},{ID:4,
Text:"<fArial Black><s1384> Irarueni mioyo yenu, sio mavazi yenu, mrudieni Bwana, </s></f>"},{ID:5,
Text:"<fArial Black><s1384>Mungu wenu, kwa maana yeye ni mpole na mwingi wa huruma,</s></f>"},{ID:5,
Text:"<fArial Black><s1384> Sio mwepesi wa hasira ni mwingi wa rehema ni mwenye kuisikitikia taabu yenu.  </s></f>"},{ID:6,
Text:"<fArial Black><s1384>Ni nani anayejua? Labda, atarudi na kusikitika,</s></f>"},{ID:6,
Text:"<fArial Black><s1384> na kuwaachia baraka yake.  Mmtolee Bwana, </s></f>"},{ID:7,
Text:"<fArial Black><s1384>Mungu wenu, matoleo na sadaka  ya kinywaji.  </s></f>"},{ID:7,
Text:"<fArial Black><s1384>Pigeni baragumu katika Sioni, mtoleeni Mungu mafungo, </s></f>"},{ID:8,
Text:"<fArial Black><s1384>tangazeni kusanyiko la ibada, kusanyeni watu wa taifa,</s></f>"},{ID:8,
Text:"<fArial Black><s1384> muwaite katika mkutano mtakatifu, </s></f>"},{ID:9,
Text:"<fArial Black><s1384>muwakutanishe wazee, muwakusanye watoto wachanga, </s></f>"},{ID:9,
Text:"<fArial Black><s1384>nao wanyonyao maziwa. Bwana harusi atoke chumbani kwake, </s></f>"},{ID:10,
Text:"<fArial Black><s1384>na bibi harusi katika kikao chake. </s></f>"},{ID:10,
Text:"<fArial Black><s1384> Kati ya mlango wa hekalu na altare walie makuhani, walio watumishi wa Bwana, waseme: </s></f>"},{ID:11,
Text:"<fArial Black><s1384>“Ee Bwana, ulihurumie taifa lako! Wala usitoe urithi wako upate aibu, </s></f>"},{ID:12,
Text:"<fArial Black><s1384>na kuchekwa na mataifa.  Kwa nini katika mataifa waseme:</s></f>"},{ID:12,
Text:"<fArial Black><s1384> ‘Yuko wapi Mungu wao?’” Ndipo Bwana aliitendea nchi yake kwa moyo wa mapendo, akalihurumia taifa lake.</s></f>"},{ID:13,
Text:"<fArial Black><s1384>Neno la Bwana</s></f>"},{
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>ZABURI YA KUITIKIZANA 
Zab. 51:3-4,5-6ab. 12-13,14 na 17(K. 3a)</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>(K) Utuhurumie, ee Bwana, kwa kuwa tumetenda dhambi.</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1384>Unihurumie, ee Mungu, kulingana na wema wako; </s></f>"},{ID:4,
Text:"<fArial Black><s1384>kwa kadiri ya huruma yako kuu, uyafute makosa yangu.</s></f>"},{ID:4,
Text:"<fArial Black><s1384>Unioshe kabisa na uovu wangu, 
unitakase dhambi yangu.</s></f>"},{ID:5,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>(K) Utuhurumie, ee Bwana, kwa kuwa tumetenda dhambi.</k></c></s></f>"},{ID:6,
Text:"<fArial Black><s1384>Kwa maana nayatambua makosa yangu, 
na dhambi yangu ipo daima mbele yangu.</s></f>"},{ID:7,
Text:"<fArial Black><s1384>Nimekukosea wewe peke yako, 
nikatenda yaliyo mabaya mbele ya macho yako (K) </s></f>"},{ID:8,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>(K) Utuhurumie, ee Bwana, kwa kuwa tumetenda dhambi.</k></c></s></f>"},{ID:9,
Text:"<fArial Black><s1384>Uniumbie moyo safi, ee Mungu, 
ufanye upya roho thabiti ndani yangu.</s></f>"},{ID:10,
Text:"<fArial Black><s1384>Usinitupe mbali na uso wako, 
wala usiniondolee roho yako takatifu. (K)</s></f>"},{ID:11,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>(K) Utuhurumie, ee Bwana, kwa kuwa tumetenda dhambi.</k></c></s></f>"},{ID:12,
Text:"<fArial Black><s1384>Unirudishie furaha ya wokovu wako, 
unitegemeze kwa kunijalia roho sikivu.</s></f>"},{ID:13,
Text:"<fArial Black><s1384>Ee Bwana, ufumbue midomo yangu 
na kinywa changu kitatangaza sifa yako.(K)</s></f>"},{ID:14,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>(K) Utuhurumie, ee Bwana, kwa kuwa tumetenda dhambi.</k></c></s></f>"},{
Text:"<fArial Black><s1384>SOMO 2 
</s></f><fArial Black><s1384><cFFF2F200><kFFFF0000>2 Wakorintho 5:20-6:2</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1384>Somo katika barua ya pili ya Mtakatifu Paulo kwa Wakorintho</s></f>"},{ID:3,
Text:"<fArial Black><s1384>Ndugu zangu: 
Tumekuwa wajumbe mahali pa Kristo, </s></f>"},{ID:4,
Text:"<fArial Black><s1384>kwa maana ni Mungu anayeonya kwa huduma yetu.</s></f>"},{ID:4,
Text:"<fArial Black><s1384>  Na ombi tunalotoa kwa jina la Kristo ndilo hili: mpatanishwe na Mungu.</s></f>"},{ID:5,
Text:"<fArial Black><s1384>Yeye amemfanya yule asiyejua dhambi kuwa dhambi kwa ajili yetu,</s></f>"},{ID:5,
Text:"<fArial Black><s1384> ili na sisi tuwe uadilifu wa Mungu katika yeye.  </s></f>"},{ID:6,
Text:"<fArial Black><s1384>Sisi tulio wafanyakazi pamoja na Mungu, </s></f>"},{ID:7,
Text:"<fArial Black><s1384>tunawaonya msiipokee bure neema ya Mungu Maana asema: </s></f>"},{ID:6,
Text:"<fArial Black><s1384>“Wakati wa neema nawasikiliza; siku ya wokovu nawasaidia.” </s></f>"},{ID:7,
Text:"<fArial Black><s1384>Kumbe, sasa ndio wakati wa neema; sasa ndio siku ya wokovu.</s></f>"},{ID:8,
Text:"<fArial Black><s1384>Neno la Bwana</s></f>"},{ID:7,
Text:"<fArial Black><s1384>SHANGILIO	LA INJILI
</s></f><fArial Black><s1384><cFFF2F200><kFFFF0000>Zaburi 95;7d,8a</k></c></s></f>"},{ID:8,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>Sifa na utukufu kwako, ee Kristo</k></c></s></f>"},{ID:9,
Text:"<fArial Black><s1384>Ingekuwa heri leo msikie sauti ya Bwana, 
msiifanye migumu mioyo yenu.</s></f>"},{ID:10,
Text:"<fArial Black><s1384><cFFF2F200><kFFFF0000>Sifa na utukufu kwako, ee Kristo</k></c></s></f>"},{
Text:"<fArial Black><s1384>INJILI
</s></f><fArial Black><s1384><cFFF2F200><kFFFF0000>Mathayo 6:1-6,16-18</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1384>Somo la Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:3,
Text:"<fArial Black><s1384>Wakati ule:
Yesu aliwaambia wafuasi wake, “Angalieni, msifanye matendo yenu mema mbele ya watu, kusudi wawaone.  Mkifanya hivyo,</s></f>"},{ID:4,
Text:"<fArial Black><s1384> hamna thawabu kwa Baba yenu aliye mbinguni. Basi, unaposaidia wenye shida, usipige tarumbeta mbele yako, </s></f>"},{ID:5,
Text:"<fArial Black><s1384>kama wanafiki wafanyavyo katika masinagogi na njiani, ili wasifiwe na watu.  Amin, nawaambieni, wamekwisha pata tuzo yao. </s></f>"},{ID:6,
Text:"<fArial Black><s1384> Wewe unaposaidia wenye shida, hata mkono wako wa kushoto usilijue tendo la mkono wako wa kuume.</s></f>"},{ID:7,
Text:"<fArial Black><s1384>Hivyo ufadhili wako uwe faraghani, na Baba yako aonaye faraghani atakutuza.
Kadhalika mnaposali, </s></f>"},{ID:8,
Text:"<fArial Black><s1384>msiwe kama wanafiki.  Hao wanaposali wapenda kusimama katika sinagogi na njia panda, ili waonekane na watu.  Amin, nawaambieni,</s></f>"},{ID:9,
Text:"<fArial Black><s1384> wamekwisha pata tuzo yao.  Bali wewe unaposali, ingia chumbani mwako, funga mlango wako, usali kwa Baba yako faraghani, </s></f>"},{ID:10,
Text:"<fArial Black><s1384>na Baba yako aonaye faraghani atakutuza. Mnapofung msikune nyuso kama wanafiki, maana hujiumbua nyuso, ili waonekane kwa watu wanafunga. </s></f>"},{ID:11,
Text:"<fArial Black><s1384> Amin, nawaambieni, wamekwisha pata tuzo yao.  
Bali wewe unapofunga, ujipake mafuta kichwani,</s></f>"},{ID:12,
Text:"<fArial Black><s1384> unawe uso, ili usionekane kwa watu unafunga, ila kwa Baba yako aliye faraghani; </s></f>"},{ID:13,
Text:"<fArial Black><s1384>na Baba yako aonaye faraghani atakutuza.”</s></f>"},{ID:14,
Text:"<fArial Black><s1384>Injili ya Bwana</s></f>"}],Style:{Body:{VerticalAlignment:0,Transition:15},Background:{Image:"sunsea1.jpg",Transition:15,Duration:402}},
Text:"JUMATANO YA MAJIVU
"}],IsCompressed:0,Guid:"MRhu5l6F0E+OlqsJIRPLnQ",Style:{Background:{Transition:15}},
Text:"ZUCA"}