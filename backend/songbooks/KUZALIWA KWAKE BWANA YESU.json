{Songs:[{Guid:"11his6rv7E2Uum6zZ4Ohyg",Verses:[{
Text:"<fArial Black><s1846></s></f><u><fArial Black><s2769><cFFF2F200><kFFFF0000>Misa ya Alfajiri</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaya 62:11-12</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Ndiyo haya Bwana anayotangaza mpaka mwisho wa dunia:</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Mwambieni binti Sioni,
\"Tazama, mwokozi wako anakuja!</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Thawabu yake iko pamoja naye, na malipo yake yako mbele zake.\"</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Wataitwa, \"Taifa Takatifu\" waliokombolewa na Bwana.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Nawe utaitwa “Aliyetafutwa,\" \"Mji Usioachwa.\"</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 97:1 na 6. 11-12</k></c></s></f>"},{ID:7,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mwanga utatung'aria leo:
Bwana amezaliwa kwetu.</k></c></s></f>"},{ID:8,
Text:"<fArial Black><s1846>Bwana ametamalaki; nchi na ishangilie:
visiwa vingi na vifurahi.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Mbingu zinatangaza haki ya Mungu;
na mataifa yote wameuona utukufu walke. K.</s></f>"},{ID:9,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mwanga utatung’aria leo:
Bwana amezaliwa kwetu.</k></c></s></f>"},{ID:10,
Text:"<fArial Black><s1846>Mwanga wamtokea mwenye haki,
na furaha kwa walio na moyo mnyofu.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Enyi waadilifu, mfurahieni Bwana,
litukuzeni jina lake takatifu. K.</s></f>"},{ID:11,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mwanga utatung’aria leo:
Bwana amezaliwa kwetu.</k></c></s></f>"},{ID:12,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Tito 34-7</k></c></s></f>"},{ID:13,
Text:"<fArial Black><s1846>Somo katika barua ya Mtakatifu Paulo kwa Tito</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Mpendwa:
upendo wake kwa</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Wakati wema wa Mwokozi wetu Mungu na</s></f>"},{ID:16,
Text:"<fArial Black><s1846>wanadamu zilipotokea, ametuokoa, lakini si kwa sababu ya</s></f>"},{ID:17,
Text:"<fArial Black><s1846>matendo maadilifu tuliyoyatenda sisi, isipokuwa kwa huruma yake</s></f>"},{ID:18,
Text:"<fArial Black><s1846>akituosha tupate kuzaliwa tena na kutengenezwa upya kwa njia ya
Roho Mtakatifu.</s></f>"},{ID:19,
Text:"<fArial Black><s1846>Mungu alitumwagia huyo ndani yetu kwa wingi, kwa ajili ya Yesu</s></f>"},{ID:20,
Text:"<fArial Black><s1846>Kristo Mwokozi wetu, tupate kuthibitishwa kwa neema yake na</s></f>"},{ID:21,
Text:"<fArial Black><s1846>hivyo kufanywa warithi wa uzima wa milele tunaotumaini.</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Luka 2:14</k></c></s></f>"},{ID:17,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W.</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Aleluya.</k></c></s></f>"},{ID:18,
Text:"<fArial Black><s1846>Utukufu kwa Mungu juu,
na amani duniani
kwa watu aliopendezwa nao.</s></f>"},{ID:19,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:20,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Luka 2;15-20</k></c></s></f>"},{ID:21,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Luka</s></f>"},{ID:22,
Text:"<fArial Black><s1846>Mara malaika walipotoka warudi kwao mbinguni, wachungaji waliambiana, </s></f>"},{ID:23,
Text:"<fArial Black><s1846>“Haya, twendeni Bethlehemu, tuyaone matukio aliyotujulisha
Bwana.”</s></f>"},{ID:24,
Text:"<fArial Black><s1846>Wakaenda kwa haraka, wakamkuta Maria na Yosefu, na mtoto</s></f>"},{ID:25,
Text:"<fArial Black><s1846>mchanga amelala horini. Walipomwona, 
walieleza habari waliyoambiwa juu ya mtoto huyu. </s></f>"},{ID:26,
Text:"<fArial Black><s1846>Wote waliosikia wakayastaajabia maneno
waliyoambiwa na wachungaji.</s></f>"},{ID:27,
Text:"<fArial Black><s1846>Naye Maria akatunza mambo hayo yote akiyawaza moyoni mwake.</s></f>"},{ID:28,
Text:"<fArial Black><s1846>Wachungaji wakarudi kwao wakimtukuza na kumsifu Mungu </s></f>"},{ID:29,
Text:"<fArial Black><s1846>kwa yote waliyoyasikia na kuyaona, kama walivyoambiwa.</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"OIP (2).jpg",Luminosity:-50}},
Text:"MISA YA ALFAJIRI"},{Guid:"AE9B1hxktE6ZG5PFY/ekHA",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF0000>Katika Misa ya Kesha</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaya 62:1-5</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Kwa ajili ya Sioni, sitanyamaza,
kwa ajili ya Yerusalemu sitatulia,</s></f>"},{ID:5,
Text:"<fArial Black><s1846>mpaka haki yake itokee kama mapambazuko,
na wokovu wake uwake kama mwenge.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Hapo mataifa wataiona haki yako,
nao wafalme wote utukufu wako;</s></f>"},{ID:7,
Text:"<fArial Black><s1846>nawe utaitwa jina jipya,
lenye kutajwa kwa kinywa cha Bwana.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Utakuwa taji lenye kumetameta mkononi mwa Bwana,</s></f>"},{ID:9,
Text:"<fArial Black><s1846>na kilemba cha kifalme mkononi mwa Mungu wako.
Hutaitwa tena, \"Yule aliyeachwa,\"</s></f>"},{ID:10,
Text:"<fArial Black><s1846>wala nchi yako haitaitwa tena, \"Jangwa.\"
Bali watakuita,</s></f>"},{ID:11,
Text:"<fArial Black><s1846>\"Furaha yangu imo ndani yake,\"
na nchi yako, “Bibi harusi wangu.\"</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Maana BWANA amependezwa nawe,
na nchi yako itaolewa naye.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Kama kijana anavyonmwoa bikira,
na hivyo aliyekujenga atakuoa wewe;</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Kama bwana harusi anavyomfurahia bibi harusi,
hivyo Mungu wako atafurahishwa nawe.</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 89:4-5,16-17,27 na 29</k></c></s></f>"},{ID:17,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Fadhili za Bwana nitaziimba milele.</k></c></s></f>"},{ID:18,
Text:"<fArial Black><s1846>1.Nimefunga agano na mteule wangu;
nimemwapia Daudi, mtumishi wangu:</s></f>"},{ID:19,
Text:"<fArial Black><s1846>nitawasimika wazao wako hata milele,
nitaimarisha kiti cha ufalme wako kwa vizazi vyote. K.</s></f>"},{ID:20,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Fadhili za Bwana nitaziimba milele.</k></c></s></f>"},{ID:21,
Text:"<fArial Black><s1846>2.Heri taifa linalokujua,
waendao ee Bwana, katika mwanga wako.</s></f>"},{ID:22,
Text:"<fArial Black><s1846>Wanafurahiwa na jina lako mchana kutwa;
nao kwa haki yako wanatukuza kwa kushangilia. K.</s></f>"},{ID:23,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Fadhili za Bwana nitaziimba milele.</k></c></s></f>"},{ID:24,
Text:"<fArial Black><s1846>Yeye atanita, Wewe ni Baba
yangu, Mungu wangu na nwamba wa wokovu wangu!</s></f>"},{ID:25,
Text:"<fArial Black><s1846>Nitamhifadhia fadhili zangu hata milele; na
agano langu kwake litadumu daima. K.</s></f>"},{ID:26,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Fadhili za Bwana nitaziimba milele.</k></c></s></f>"},{ID:27,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Matendo ya Mitume 
13:16-17.22-25</k></c></s></f>"},{ID:28,
Text:"<fArial Black><s1846>Somo katika kitabu cha Matendo ya Mitume</s></f>"},{ID:29,
Text:"<fArial Black><s1846>Paulo anamshuhudia Kristo, mwana wa Daudi</s></f>"},{ID:30,
Text:"<fArial Black><s1846>Paulo alisimama kwenye sinagogi ya Antokia [kwenye Sinagogi ya Antiokia], akawaashiria</s></f>"},{ID:31,
Text:"<fArial Black><s1846>kwa mkono, akasema, \"Enyi Waisraeli na ninyi mnaomcha Mungu,</s></f>"},{ID:32,
Text:"<fArial Black><s1846>sikilizeni. Mungu wa taifa hili la Israeli aliwachagua baba zetu,</s></f>"},{ID:33,
Text:"<fArial Black><s1846>akalikuza taifa ugenini katika nchi ya Misri. Akawahamisha huko</s></f>"},{ID:34,
Text:"<fArial Black><s1846>kwa mkono mnyofu. Baadaye alimweka Daudi awe mfalme wao;</s></f>"},{ID:35,
Text:"<fArial Black><s1846>naye alimthibitisha kwa maneno haya, Nimemkuta Daudi, mwana</s></f>"},{ID:36,
Text:"<fArial Black><s1846>wa Yese, aliye kadiri ya moyo wangu naye atatimiza yote nitakayo.</s></f>"},{ID:37,
Text:"<fArial Black><s1846>Katika ukoo wake Mungu amewaletea Waisraeli mwokozi, ndiye
Yesu, kama alivyoahidi.</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Kuja kwake hadharani kulitangazwa na Yohane alipowahubiria</s></f>"},{ID:39,
Text:"<fArial Black><s1846>watu wote wa Israeli ubatizo wa toba kabla ya kuja kwake; Yohane</s></f>"},{ID:40,
Text:"<fArial Black><s1846>alipotimiza mwendo wake, aliwaambia watu, 'Mimi si yeye</s></f>"},{ID:41,
Text:"<fArial Black><s1846>mnayenidhania. Lakini angalieni, anakuja mmoja nyuma yangu;</s></f>"},{ID:42,
Text:"<fArial Black><s1846>ambaye mimi sistahili kulegeza viatu vya miguu yake.\"</s></f>"},{ID:43,
Text:"<fArial Black><s1846>Neno la Bwana,</s></f>"},{ID:44,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI</s></f>"},{ID:45,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:46,
Text:"<fArial Black><s1846>K. Kesho uovu wa dunia utashindwa:
mwokozi wa dunia atatutawala.</s></f>"},{ID:47,
Text:"<fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:48,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mathayo 1:1- 25</k></c></s></f>"},{ID:49,
Text:"<fArial Black><s1846>Mwanzo wa Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:50,
Text:"<fArial Black><s1846>Kitabu cha ukoo wa Yesu Kristo, mwana wa Daudi, mwana wa Abrahanmu.</s></f>"},{ID:51,
Text:"<fArial Black><s1846>Abrahamu alimzaa Isaka, Isaka alimzaa Yakobo, Yakobo alimzaa</s></f>"},{ID:52,
Text:"<fArial Black><s1846>Yuda na ndugu zake. Yuda alimzaa Peresi na Zera kwa Tamari, Peresi</s></f>"},{ID:53,
Text:"<fArial Black><s1846>alimzaa Esromu, Esromu alimzaa Aramu. Aramu alimzaa Aminadabu,</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Aminadabu alimzaa Nashoni, Nashoni alimzaa Salmoni. Salmoni</s></f>"},{ID:55,
Text:"<fArial Black><s1846>alimzaa Boazi kwa Rahabu, Boazi alimzaa Obedi kwa Ruthu, Obedi</s></f>"},{ID:56,
Text:"<fArial Black><s1846>alimzaa Yese. Yese alimzaa Mfalme Daudi.</s></f>"},{ID:57,
Text:"<fArial Black><s1846>Daudi alimzaa Sulemani kwa mke wa Uria. Sulemani alimzaa</s></f>"},{ID:58,
Text:"<fArial Black><s1846>Rehoboamu, Rehoboamu alimzaa Abiya, Abiya alimzaa Asa. Asa</s></f>"},{ID:59,
Text:"<fArial Black><s1846>alimzaa Yehoshafati, Yehoshafati alimzaa Yoramu; Yoramu alimzaa</s></f>"},{ID:60,
Text:"<fArial Black><s1846>Uzia. Uzia alimzaa Yothamu, Yothamu alimzaa Ahazi, Ahazi alimzaa</s></f>"},{ID:61,
Text:"<fArial Black><s1846>Hezekia. Hezekia alimzaa Manase, Manase alimzaa Amoni, Amoni</s></f>"},{ID:62,
Text:"<fArial Black><s1846>alimzaa Yosia. Yosia alimzaa Yekonia na ndugu zake wakati wa
uhamisho wa Babiloni.</s></f>"},{ID:63,
Text:"<fArial Black><s1846>Na baada ya uhamisho wa Babiloni, Yekonia alimzaa Shealtieli,</s></f>"},{ID:64,
Text:"<fArial Black><s1846>Shealtieli alimzaa Zerubabeli. Zerubabeli alimnzaa Abihudi. Abihudi</s></f>"},{ID:65,
Text:"<fArial Black><s1846>alimzaa Eliakimu, Eliakimu alimzaa Azori, Azori alimzaa Sadoki,</s></f>"},{ID:66,
Text:"<fArial Black><s1846>Sadoki alimzaa Akimu, Akimu alimzaa Eliudi, Eliudi alimzaa Eleazari,</s></f>"},{ID:67,
Text:"<fArial Black><s1846>Eleazari alimzaa Mathani, Mathani alimzaa Yakobo. Yakobo alimzaa</s></f>"},{ID:68,
Text:"<fArial Black><s1846>Yosefu, mumewe Maria aliyemzaa Yesu aitwaye Kristo.</s></f>"},{ID:69,
Text:"<fArial Black><s1846>Basi vizazi vyote tangu Abrahamu hadi Daudi ni vizazi kumi na vinne</s></f>"},{ID:70,
Text:"<fArial Black><s1846>na tangu Daudi hadi ule uhamisho wa Babiloni ni vizazi kumi na vinne</s></f>"},{ID:71,
Text:"<fArial Black><s1846>na tangu uhamisho wa Babiloni hadi Kristo ni vizazi kumi na Vinne </s></f>"},{ID:72,
Text:"<fArial Black><s1846>Kuzaliwa kwa Yesu Kristo kulikuwa hivi. Maria, mama 
yake,</s></f>"},{ID:73,
Text:"<fArial Black><s1846>alipokuwa ameposwa na Yosefu, kabla hawajakaa pamoja, alionekana</s></f>"},{ID:74,
Text:"<fArial Black><s1846>ana mimba kwa uwezo wa Roho Mtakatifu. Mumewe Yosefu akiwa</s></f>"},{ID:75,
Text:"<fArial Black><s1846>mtu mwadilifu, hakupenda kumwaibisha hadharani. Basi, akanuja</s></f>"},{ID:76,
Text:"<fArial Black><s1846>kumwacha kwa siri. Alipokuwa akifikiria hayo, tazama, malaika</s></f>"},{ID:77,
Text:"<fArial Black><s1846>wa Bwana alimtokea katika ndoto, akasema, \"Yosefu, mwana wa</s></f>"},{ID:78,
Text:"<fArial Black><s1846>Daudi, usiogope kumchukua Maria kuwa mke wako, maana mimba</s></f>"},{ID:79,
Text:"<fArial Black><s1846>vake anmeipata kwa uwezo wa Roho Mtakatifu. Atamzaa mwana.</s></f>"},{ID:80,
Text:"<fArial Black><s1846>nawe utampa jina \"Yesu. Maana yeye atawaokoa watu wake katika</s></f>"},{ID:81,
Text:"<fArial Black><s1846>dhambi zao.\" Hayo yote yametendeka, ili neno alilonena Bwana kwa</s></f>"},{ID:82,
Text:"<fArial Black><s1846>njia ya nabii litimie, kwamba \"Tazama, bikira atachukua mimba na</s></f>"},{ID:83,
Text:"<fArial Black><s1846>kuzaa mwana, naye watamwita Emanueli,\" maana yake, \"Mungu</s></f>"},{ID:84,
Text:"<fArial Black><s1846>pamoja nasi.\" Yosefu alipoamka kutoka usingizini, alifanya kama</s></f>"},{ID:85,
Text:"<fArial Black><s1846>malaika wa Bwana alivyomwagiza, akampokea mkewe nyumbani</s></f>"},{ID:86,
Text:"<fArial Black><s1846>kwake. Lakini hakumjua hata alipomzaa mwanawe. Akampa jina lake Yesu.</s></f>"},{ID:87,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"},{ID:88,
Text:"<fArial Black><s1846>AU SOMO FUPI:</s></f>"},{ID:89,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Mathayo 1:18-25</k></c></s></f>"},{ID:90,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:91,
Text:"<fArial Black><s1846>Kuzaliwa kwa Yesu Kristo kulikuwa hivi. Maria, mama yake,</s></f>"},{ID:92,
Text:"<fArial Black><s1846>alipokuwa ameposwa na Yosefu, kabla hawajakaa pamoja,</s></f>"},{ID:93,
Text:"<fArial Black><s1846>alionekana ana mimba kwa uwezo wa Roho Mtakatifu.</s></f>"},{ID:94,
Text:"<fArial Black><s1846>Mumewe Yosefu akiwa mtu mwadilifu, hakupenda kumwaibisha</s></f>"},{ID:95,
Text:"<fArial Black><s1846>hadharani. Basi, akanuia kumwacha kwa siri. Alipokuwa</s></f>"},{ID:96,
Text:"<fArial Black><s1846>akifikiria hayo, tazama, malaika wa Bwana alimtokea katika ndoto,</s></f>"},{ID:97,
Text:"<fArial Black><s1846>akasema, Yosefu, mwana wa Daudi, usiogope kumchukua Maria</s></f>"},{ID:98,
Text:"<fArial Black><s1846>kuwa mke wako, maana mimba yake ameipata kwa uwezo wa</s></f>"},{ID:99,
Text:"<fArial Black><s1846>Roho Mtakatifu. Atamzaa mwana, nawe utampa jina
Yesu.</s></f>"},{ID:100,
Text:"<fArial Black><s1846>Maana yeye atawaokoa watu wake katika dhambi zao.\" Hayo</s></f>"},{ID:101,
Text:"<fArial Black><s1846>yote yametendeka, ili neno alilonena Bwana kwa njia ya</s></f>"},{ID:102,
Text:"<fArial Black><s1846>nabii litimie, kwamba \"Tazama, bikira atachukua mimba na kuzaa</s></f>"},{ID:103,
Text:"<fArial Black><s1846>mwana, naye watamwita Emanueli,\" maana yake, \"Mungu pamoja
nasi.\"</s></f>"},{ID:104,
Text:"<fArial Black><s1846>Yosefu alipoamka kutoka usingizini, alifanya kama malaika wa</s></f>"},{ID:105,
Text:"<fArial Black><s1846>Bwana alivyomwagiza, akampokea mkewe nyumbaní kwake. Lakiní</s></f>"},{ID:106,
Text:"<fArial Black><s1846>hakumjua hata alipomzaa mwanawe. Akampa jina lake Yesu.</s></f>"},{ID:107,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"OIP (2).jpg"}},
Text:"MISA YA KESHA"},{Guid:"gx7JmNZiokqHPbiUvrTScA",Verses:[{
Text:"<fArial Black><s1846></s></f><u><fArial Black><s1846><cFFF2F200><kFFFF0000>Katika Misa ya Usiku</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaya 9:1-6</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Watu waliotembea gizani wameona mwanga mkuu:</s></f>"},{ID:5,
Text:"<fArial Black><s1846>nao waliokaa katika nchi ya kivuli cha mauti
mwanga umewaangazia.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Umezidisha furaha yao,
na umeongeza shangwe zao;</s></f>"},{ID:7,
Text:"<fArial Black><s1846>wanashangilia mbele yako,
kama wanavyoshangilia wavunaji,</s></f>"},{ID:8,
Text:"<fArial Black><s1846>kama wanavyofurahi wenye kugawanya mateka.
Kwa maana mzigo uliowalemea,</s></f>"},{ID:9,
Text:"<fArial Black><s1846>na gongo juu ya mabega yao,
na fimbo ya wakandamizaji wao,</s></f>"},{ID:10,
Text:"<fArial Black><s1846>umezivunjavunja,
kama siku ile ya kushindwa kwa Midiani.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Viatu vyote vya askari vyenye kukanyaga nchi,
makoti yao yenye kuchafuka kwa damu,</s></f>"},{ID:12,
Text:"<fArial Black><s1846>yameteketezwa, yamechomwa motoni.
Maana mtoto amezaliwa kwetu,</s></f>"},{ID:13,
Text:"<fArial Black><s1846>mwana ametolewa kwetu;
alama ya uwezo mabegani pake.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Ameitwa jina lake:
Mshauri mwenye Hekima,</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Mungu mwenye nguvu,
Baba wa Milele,</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Mfalme wa Amani.
Uwezo wake utaenea,</s></f>"},{ID:17,
Text:"<fArial Black><s1846>amani haitakuwa na mwisho,
katika kiti cha enzi cha Daudi,</s></f>"},{ID:18,
Text:"<fArial Black><s1846>na katika ufalme wake.
Nao utasimikwa imara juu ya haki na uadilifu</s></f>"},{ID:19,
Text:"<fArial Black><s1846>tangu sasa na kwa siku zote.
Ndiyo yatakayotendeka</s></f>"},{ID:20,
Text:"<fArial Black><s1846>kwa mapendo ya Bwana wa majeshi!</s></f>"},{ID:21,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:22,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 96:1-2a,2b3,11-12.13 (K. Luka 2:11)</k></c></s></f>"},{ID:23,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Leo amezaliwa kwa ajili yetu Mwokozi,
ndiye Kristo Bwana.</k></c></s></f>"},{ID:24,
Text:"<fArial Black><s1846>Mwimbieni Bwana wimbo mpya;
mwimbieni Bwana, nchi yote.</s></f>"},{ID:25,
Text:"<fArial Black><s1846>Mwimbieni Bwana, lisifuni jina lake. K.</s></f>"},{ID:26,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Leo amezaliwa kwa ajili yetu Mwokozi,
ndiye Kristo Bwana.</k></c></s></f>"},{ID:27,
Text:"<fArial Black><s1846>Siku kwa siku tangazeni wokovu wake.
Uhubirini utukufu wake kati ya mataifa;</s></f>"},{ID:28,
Text:"<fArial Black><s1846>maajabu yake, kati ya watu wote. K.</s></f>"},{ID:29,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K.</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Leo amezaliwa kwa ajili yetu Mwokozi,
ndiye Kristo Bwana.</k></c></s></f>"},{ID:30,
Text:"<fArial Black><s1846>Mbingu na zifurahi, nchi na ishangilie;
bahari na ivume na vyote viijazavyo;</s></f>"},{ID:31,
Text:"<fArial Black><s1846>mashamba na yachangamke, na vyote vilivyomo.
Ndipo miti yote ya msituni imbe kwa furaha. K.</s></f>"},{ID:32,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Leo amezaliwa kwa ajili yetu Mwokozi,
ndiye Kristo Bwana.</k></c></s></f>"},{ID:33,
Text:"<fArial Black><s1846>Mbele za Bwana, kwa kuwa anakuja.
kwa kuwa anakuja kuihukumu nchi,</s></f>"},{ID:34,
Text:"<fArial Black><s1846>atahukumu ulimwengu kwa haki
nayo mataifa kwa uaminifu wake. K.</s></f>"},{ID:35,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K.</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Leo amezaliwa kwa ajili yetu Mwokozi,
ndiye Kristo Bwana.</k></c></s></f>"},{ID:36,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Tito 2:1 1-14</k></c></s></f>"},{ID:37,
Text:"<fArial Black><s1846>Somo katika barua ya Mtakatifu Paulo kwa Tito</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Mpendwa: Neema ya Mungu imetokea kwa kuwaokoa watu wote.</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Nayo inatuongoza kuzuia yasiyo ya Mungu, na kupinga tamaa</s></f>"},{ID:40,
Text:"<fArial Black><s1846>kidunia, tupate kuishi duniani hapa kwa kiasi, kwa haki na kwa</s></f>"},{ID:41,
Text:"<fArial Black><s1846>uchaji wa Mungu, tukingoja heri tunayoitazamia na ufunuo wa</s></f>"},{ID:42,
Text:"<fArial Black><s1846>utukufu wa Mungu mkuu na wa Mwokozi wetu Yesu Kristo.</s></f>"},{ID:43,
Text:"<fArial Black><s1846>Yeye amejitoa mwenyewe kwa ajili yetu, ili atukomboe katika</s></f>"},{ID:44,
Text:"<fArial Black><s1846>uovu wote, na ajitakasie watu walio mali yake ya pekee na wenye
bidii ya kutenda mema.</s></f>"},{ID:45,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:46,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Luka 2:10-11</k></c></s></f>"},{ID:47,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:48,
Text:"<fArial Black><s1846>K. Nimewaletea habari njema ya furaha kubwa kwa watu wote.</s></f>"},{ID:49,
Text:"<fArial Black><s1846>Maana leo katika mji wa Daudi amezaliwa Mwokozi,
ndiye Kristo Bwana.</s></f>"},{ID:50,
Text:"<fArial Black><s1846></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:51,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Luka 2:1-14</k></c></s></f>"},{ID:52,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Luka</s></f>"},{ID:53,
Text:"<fArial Black><s1846>Siku zile Kaisari Augusto alitoa amri kuandika orodha ya watu</s></f>"},{ID:54,
Text:"<fArial Black><s1846>wote wa nchi nzima. Orodha hii ilikuwa ya kwanza, wakati</s></f>"},{ID:55,
Text:"<fArial Black><s1846>Kirenio alipokuwa liwali wa Siria. Basi, wote walikwenda</s></f>"},{ID:56,
Text:"<fArial Black><s1846>kujiandikisha, kila mmoja katika mji wake.</s></f>"},{ID:57,
Text:"<fArial Black><s1846>Yosefu pia alitoka Galilaya katika mji wa Nazareti, akapanda</s></f>"},{ID:58,
Text:"<fArial Black><s1846>kwenda Yudea mpaka mji wa Daudi, uitwao Bethlehemu, kwa</s></f>"},{ID:59,
Text:"<fArial Black><s1846>maana alikuwa jamaa na ukoo wa Daudi, kusudi ajiandikishe pamoja</s></f>"},{ID:60,
Text:"<fArial Black><s1846>na Maria, mke wake, naye alikuwa ni mja mzito.</s></f>"},{ID:61,
Text:"<fArial Black><s1846>Walipokuwa wakikaa huko, siku zake za kuzaa zilitimia, akamzaa</s></f>"},{ID:62,
Text:"<fArial Black><s1846>mwanawe, mzaliwa wa kwanza. Akamzungushia vitambaa, akamlaza</s></f>"},{ID:63,
Text:"<fArial Black><s1846>horini, kwa maana walikosa kupata nafasi katika nyumba ya wageni.</s></f>"},{ID:64,
Text:"<fArial Black><s1846>Sasa kulikuwa na wachungaji katika nchi ile wakikesha malishoni</s></f>"},{ID:65,
Text:"<fArial Black><s1846>kulinda kundi lao usiku. Mara malaika wa Bwana akawajia, na</s></f>"},{ID:66,
Text:"<fArial Black><s1846>utukufu wa Bwana ukawang'aria pande zote, wakashikwa na hofu</s></f>"},{ID:67,
Text:"<fArial Black><s1846>nyingi. Malaika akawaambia, \"Msihofu; kwa maana, ninawaletea</s></f>"},{ID:68,
Text:"<fArial Black><s1846>habari njema ya furaha kubwa kwa watu wote. Maana leo katika mji</s></f>"},{ID:69,
Text:"<fArial Black><s1846>wa Daudi amezaliwa Mwokozi, ndiye Kristo Bwana. Na hii ndiyo</s></f>"},{ID:70,
Text:"<fArial Black><s1846>ishara kwenu: mtamkuta nmtoto mchanga amezungushiwa vitambaa.,
amelala horini.\"</s></f>"},{ID:71,
Text:"<fArial Black><s1846>Mara jeshi kubwa la mbinguni wakawa pamoja na malaika wakimsifu</s></f>"},{ID:72,
Text:"<fArial Black><s1846>Mungu, na kusema, \"Utukufu kwa Mungu juu, na amani duniani
kwa watu aliopendezwa nao.\"</s></f>"},{ID:73,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"OIP (5).jpg",Luminosity:-55}},
Text:"MISA YA USIKU"},{Guid:"lozekSVAbESjD7BPeu9vOA",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF0000>Katika Misa ya Mchana</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaya 52:7-10</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Jinsi ilivyo mizuri juu ya milima</s></f>"},{ID:5,
Text:"<fArial Black><s1846>miguu yake aletaye habari njema na kutangaza amani,</s></f>"},{ID:6,
Text:"<fArial Black><s1846>aletaye habari ya heri na kutangaza wokovu,
anayeuambia Sioni, “Mungu wako atawala!”</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Sikiliza walinzi wako wanapaza sauti,
wanalia pamoja kwa furaha;</s></f>"},{ID:8,
Text:"<fArial Black><s1846>maana wataona jicho kwa jicho jinsi
Bwana anavyorudi Sioni.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Shangilieni kwa furaha, enyi wakiwa wa Yerusalemu!
Maana Bwana anawatuliza watu wa taifa lake,</s></f>"},{ID:10,
Text:"<fArial Black><s1846>anaukomboa Yerusalemu.
Bwana anaufunua mkono wake mtakatifu</s></f>"},{ID:11,
Text:"<fArial Black><s1846>mbele ya macho ya mataifa yote:
na miisho yote ya dunia</s></f>"},{ID:12,
Text:"<fArial Black><s1846>itauona wokovu wa Mungu wetu.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>ZABURIYA KUITIKIZANA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 98:1.2-3ab.3cd 4,5.6 (K. 3c)</k></c></s></f>"},{ID:15,
Text:"<fArial Black><s1846><kFFFF0000>K.</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Miisho yote ya dunia imeuona wokovu wa Mungu wetu.</k></c></s></f>"},{ID:16,
Text:"<fArial Black><s1846>1.Mwimbieni Bwana wimbo mpya,
kwa maana amefanya mambo ya ajabu,</s></f>"},{ID:17,
Text:"<fArial Black><s1846>mkono wake wa kulia, na mkono wake mtakatifu,
umemletea ushindi. K.</s></f>"},{ID:18,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Miisho yote ya dunia imeuona wokovu wa Mungu wetu.</k></c></s></f>"},{ID:19,
Text:"<fArial Black><s1846>2. Bwana ameujulisha ushindi wake:
mbele ya macho ya mataifa ameifunua haki yake,</s></f>"},{ID:20,
Text:"<fArial Black><s1846>amekumbuka wema na uaminifu wake
kwa nyumba ya Israeli. K.</s></f>"},{ID:21,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Miisho yote ya dunia imeuona wokovu wa Mungu wetu.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>3.Miisho yote ya dunia imeuona
wokovu wa Mungu wetu.</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Mshangilieni Bwana, nchi yote;
pigeni kelele za furaha; imbeni zaburi. K.</s></f>"},{ID:24,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Miisho yote ya dunia imeuona wokovu wa Mungu wetu.</k></c></s></f>"},{ID:25,
Text:"<fArial Black><s1846>Mwimbieni Bwana kwa kinubi,
kwa kinubi na sauti ya vinanda.</s></f>"},{ID:26,
Text:"<fArial Black><s1846>Kwa tarumbeta na sauti ya baragumu
shangilieni mbele ya Mfalme, Bwana. K.</s></f>"},{ID:27,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Miisho yote ya dunia imeuona wokovu wa Mungu wetu.</k></c></s></f>"},{ID:28,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Waebrania 1:1-6</k></c></s></f>"},{ID:29,
Text:"<fArial Black><s1846>Somo katika barua kwa Waebrania</s></f>"},{ID:30,
Text:"<fArial Black><s1846>Nyakati zilizopita, mara nyingi na kwa namna nyingi, 
Mungu alisema nà mababu zetu kwa njia ya manabii.</s></f>"},{ID:31,
Text:"<fArial Black><s1846>Siku hizi za mwisho amesema nasi kwa njia ya Mwanae, aliyemweka</s></f>"},{ID:32,
Text:"<fArial Black><s1846>kuwa mrithi wa vyote, na kwa njia yake aliuumba ulimwengu.</s></f>"},{ID:33,
Text:"<fArial Black><s1846>Huyu ni mng’ao wa utukufu wake na mfano wa hali yake. </s></f>"},{ID:34,
Text:"<fArial Black><s1846>na ambaye anauhifadhi ulimwengu wote kwa neno la uwezo wake</s></f>"},{ID:35,
Text:"<fArial Black><s1846>Na baada ya kufuta dhambi, ameketi mkono wa kulia wa Mtukufu,</s></f>"},{ID:36,
Text:"<fArial Black><s1846>mbinguni. Ametukuka kupita malaika kwa kadiri ya jina alilolirithi linavyopita lao.</s></f>"},{ID:37,
Text:"<fArial Black><s1846>Je, Mungu alimwambia malaika gani mmojawapo: “Wewe u mwana</s></f>"},{ID:38,
Text:"<fArial Black><s1846>wangu, mimi nimekuzaa leo?”” Au: Mimi nitakuwa kwake Baba.
na yeye atakuwa kwangu mwana?””</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Tena baada ya kumwingiza mzaliwa wa kwanza hapa dunianí,</s></f>"},{ID:40,
Text:"<fArial Black><s1846>anasema: “Malaika wote wa Mungu wamwabudu.”</s></f>"},{ID:41,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:42,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI</s></f>"},{ID:43,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000> W.</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Aleluya</k></c></s></f>"},{ID:44,
Text:"<fArial Black><s1846>K. Siku takatifu imetung’aria:
enyi mataifa njoni mkamwabudu Bwana,</s></f>"},{ID:45,
Text:"<fArial Black><s1846>kwa sababu leo mwanga mkubwa umeshuka duniani.</s></f>"},{ID:46,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>W. Aleluya.</k></c></s></f>"},{ID:47,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Yohane 1:1-18</k></c></s></f>"},{ID:48,
Text:"<fArial Black><s1846>Mwanzo wa Injili takatifu ilivyoandikwa na Yohane</s></f>"},{ID:49,
Text:"<fArial Black><s1846>Mwanzoni kulikuwako Neno,
naye Neno alikuwa kwa Mungu.</s></f>"},{ID:50,
Text:"<fArial Black><s1846>Na Neno huyu alikuwa Mungu.
Huyu mwanzoni alikuwako kwa Mungu.</s></f>"},{ID:51,
Text:"<fArial Black><s1846>Kwa Neno vyote vimeumbwa,
na pasipo Neno hakikuumbwa chochote kilichoumbwa.</s></f>"},{ID:52,
Text:"<fArial Black><s1846>Ndani yake ulikuwamo uzima,
na uzima ulikuwa ni mwanga wa wanadamu;</s></f>"},{ID:53,
Text:"<fArial Black><s1846>na mwanga huo uliangaza gizani,</s></f>"},{ID:54,
Text:"<fArial Black><s1846>lakini giza halikuupokea.Palitokea mtu, ametumwa na</s></f>"},{ID:55,
Text:"<fArial Black><s1846>Mungu, jina lake Yohane.
Huyo alikuja kutoa ushuhuda.</s></f>"},{ID:56,
Text:"<fArial Black><s1846>apate kuushuhudia mwanga
ili wote wasadiki kwa sababu yake.</s></f>"},{ID:57,
Text:"<fArial Black><s1846>Yeye hakuwa ule mwanga,
ila wajibu wake ulikuwa kuushuhudia ule mwanga.</s></f>"},{ID:58,
Text:"<fArial Black><s1846>Alikuwako mwanga halisi amwangazaye kila mtu,
alikuwa ulimwenguni humu.</s></f>"},{ID:59,
Text:"<fArial Black><s1846>Alikuwako ulimwenguni,
nao ulimwengu uliumbwa kwa njia yake,</s></f>"},{ID:60,
Text:"<fArial Black><s1846>lakini ulimwengu haukumtambua.
Alifika kwa walio wake,</s></f>"},{ID:61,
Text:"<fArial Black><s1846>nao walio wake hawakumpokea.
Lakini wote waliompokea</s></f>"},{ID:62,
Text:"<fArial Black><s1846>aliwapa uwezo wa kuwa watoto wa Mungu,
ndio wale wasadikio kwa jina lake,</s></f>"},{ID:63,
Text:"<fArial Black><s1846>waliozaliwa, si kwa damu, wala kwa tamaa ya mwili,</s></f>"},{ID:64,
Text:"<fArial Black><s1846>wala kwa tamaa ya mwanadamu bali kwa mapenzi ya Mungu.</s></f>"},{ID:65,
Text:"<fArial Black><s1846>Neno akafanyika mwili, akakaa kwetu;
nasi tumeuona utukufu wake,</s></f>"},{ID:66,
Text:"<fArial Black><s1846>utukufu kama wa mzaliwa wa pekee wa Baba,
amejaa neema na kweli.</s></f>"},{ID:67,
Text:"<fArial Black><s1846>Yohane alimshuhudia na alipaza sauti akasema,
“Huyu ndiye niliyemtaja niliposema,</s></f>"},{ID:68,
Text:"<fArial Black><s1846>“Anayekuja nyuma yangu amekuwa mbele yangu,
kwa maana alikuwa kabla yangu.”</s></f>"},{ID:69,
Text:"<fArial Black><s1846>Katika ukamilifu wake
Sisi sote tumepokea neema juu ya neema.</s></f>"},{ID:70,
Text:"<fArial Black><s1846>Kwa maana sheria imetolewa kwa njia ya Musa,</s></f>"},{ID:71,
Text:"<fArial Black><s1846>lakini neema na kweli zimepatikana kwa Yesu Kristo.</s></f>"},{ID:72,
Text:"<fArial Black><s1846>Hakuna aliyemwona Mungu.
Mwana wa pekee, Mungu,</s></f>"},{ID:73,
Text:"<fArial Black><s1846>aliye kifuani mwa Baba,
amemtambulisha kwetu.</s></f>"},{ID:74,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"},{ID:75,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>AU SOMO FUPI:
Yohane 1:1-5,9-14</k></c></s></f>"},{ID:76,
Text:"<fArial Black><s1846>Mwanzo wa Injili takatifu ilivyoandikwa na Yohane</s></f>"},{ID:77,
Text:"<fArial Black><s1846>Mwanzoni kulikuwako Neno,</s></f>"},{ID:78,
Text:"<fArial Black><s1846>naye Neno alikuwa kwa Mungu.
Na Neno huyu alikuwa Mungu.</s></f>"},{ID:79,
Text:"<fArial Black><s1846>Huyu mwanzoni alikuwako kwa Mungu.
Kwa Neno vyote vimeumbwa,</s></f>"},{ID:80,
Text:"<fArial Black><s1846>na pasipo Neno hakikuumbwa chochote kilichoumbwa.
Ndani yake ulikuwamo uzima,</s></f>"},{ID:81,
Text:"<fArial Black><s1846>na uzima ulikuwa ni mwanga wa wanadamu;
na mwanga huo uliangaza gizani,</s></f>"},{ID:82,
Text:"<fArial Black><s1846>lakini giza halikuupokea.
Alikuwako mwanga halisi amwangazaye kila mtu,</s></f>"},{ID:83,
Text:"<fArial Black><s1846>alikuwa ulimwenguni humu.
Alikuwako ulimwenguni,</s></f>"},{ID:84,
Text:"<fArial Black><s1846>nao ulimwengu uliumbwa kwa njia yake,
lakini ulimwengu haukumtambua.</s></f>"},{ID:85,
Text:"<fArial Black><s1846>Alifika kwa walio wake,
nao walio wake hawakumpokea.</s></f>"},{ID:86,
Text:"<fArial Black><s1846>Lakini wote waliompokea
aliwapa uwezo wa kuwa watoto wa Mungu,</s></f>"},{ID:87,
Text:"<fArial Black><s1846>ndio wale wasadikio kwa jina lake, waliozaliwa,
si kwa damu, wala kwa tamaa ya mwili,</s></f>"},{ID:88,
Text:"<fArial Black><s1846>wala kwa tamaa ya mwanadamu
bali kwa mapenzi ya Mungu.</s></f>"},{ID:89,
Text:"<fArial Black><s1846>Neno akafanyika mwili,
akakaa kwetu,</s></f>"},{ID:90,
Text:"<fArial Black><s1846>nasi tumeona utukufu wake,
utukufu kama wa mzaliwa wa pekee wa Baba,</s></f>"},{ID:91,
Text:"<fArial Black><s1846>amejaa neema na kweli.</s></f>"},{ID:92,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"OIP (4).jpg",Luminosity:-50}},
Text:"MISA YA MCHANA"}],Guid:"3rGdHoTc1UqAB8iG6Vg1IA",
Text:"KUZALIWA KWAKE BWANA YESU"}