{Songs:[{Guid:"42cxKOToTUOJp/Lfh5LZmA",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF0000>MITHA YA VIGILIA YA ICIARĪRO</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GITHOM0 KIA MBERE
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaia 62: 1 - 5</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>GŪTHOMA KUUMA MŪRATHI ISAIA :</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Atīrīrī, ha ūhoro wa kūrūïrīra Sion, ndigatumia kanua, o na kana ndigithīrie gūtetera Jerusalemu, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>o nginya hīĩndī irīa ūhoro wakuo wa ūthingu űkoimbüka ware o ta ütheri, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>o naguo ühoro wakwo kūhonokania woneke o ta tawa ürīa wakanaga mũno. Nacio ndūrīri nĩ ikona ūthingu waku, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>o nao athamaki othe mone riri waku; wee nawe ücoke gwitwo rīïtwa rīngī rieru, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>o riria rīkagwetwo kanua ka Mwathani. Ningī ūgatuĩka ta tanji ya ūthaka ūnyitītwo na guoko kwa Miwathani, </s></f>"},{ID:9,Style:{Background:{Image:"chrisimg.jpg"}},
Text:"<fArial Black><s1846>na ühaane ta thũmbī ya ūthamaki únyitītwo na guoko kwa Ngai waku. Wee nawe-rī, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>ndūgacoka gwĩtwo Mütirike, o na kana būrūri waku wītwo Mükiru Ihooru; </s></f>"},{ID:11,
Text:"<fArial Black><s1846>no rĩrī, ürīitagwo Hefiziba, 
o naguo būrūri waku wĩ tagwo Beula; </s></f>"},{ID:12,
Text:"<fArial Black><s1846>nĩ gūkorūo Mwathani nĩ akenagio nīwe, 
o naguo būrūri waku ūgatuīka o ta műhiki ūrĩa ūhikītio. </s></f>"},{ID:13,
Text:"<fArial Black><s1846>Nĩ gükorūo o ta ũrīa mwanake ahikagia műirītu, </s></f>"},{ID:14,
Text:"<fArial Black><s1846>üguo noguo aanake aku magakūhikia, ningī o ta üría mūhikania ekenagīra nī műhiki wake-rī, </s></f>"},{ID:15,
Text:"<fArial Black><s1846>o üguo noguo Ngai waku arīīkenagīra nīwe.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>THABURI YA GŪCOKERUO 
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Thaburi 89: 3-4; 15-1 6; 26; 28.</k></c></s></f>"},{ID:18,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ngainīira hĩndī ciothe, Mwathani, mawega maku.</k></c></s></f>"},{ID:19,
Text:"<fArial Black><s1846>1. Nií ri, nĩ ndīkaniire na mūthurūo wakwa, 
ndungata yakwa Davide nī kwihita ndīhitite ngamīrkiria atiri: </s></f>"},{ID:20,
Text:"<fArial Black><s1846>Mbeū yaku ngũmĩtūūria íí nũmu o nginya tene na tene, </s></f>"},{ID:21,
Text:"<fArial Black><s1846>ngiake giti giaku kīa ünene gīkinyagīrire njiarūa na njiarūa.</s></f>"},{ID:22,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ngainīira hĩndī ciothe, Mwathani, mawega maku.</k></c></s></f>"},{ID:23,
Text:"<fArial Black><s1846>2. Gūkena-ri, ni kirindi kirīa kimenyete riugiririo rirīa rīa gīkeno; </s></f>"},{ID:24,
Text:"<fArial Black><s1846>kĩu nĩ githiaga o na ūtheri wa
githithi giaku, wee Mwathani., </s></f>"},{ID:25,
Text:"<fArial Black><s1846>Gītindaga gīcanjamūkīte mūthenya wothe nĩ ūndū </s></f>"},{ID:26,
Text:"<fArial Black><s1846>wa ritwa riu riaku, na tondū wa ūthingu waku gigagītūūgīra.</s></f>"},{ID:27,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ngainīira hĩndī ciothe, Mwathani, mawega maku.</k></c></s></f>"},{ID:28,
Text:"<fArial Black><s1846>3.Wee ariitanaga na kūri niî ta ü</s></f><fSegoe UI Black><s1846>ủ</s></f><fArial Black><s1846>: Wee niwe awa, nowe Ngai wakwa, </s></f>"},{ID:29,
Text:"<fArial Black><s1846>o na ndūmba ya ihiga irĩa
nyene ūhonokio wakwa, </s></f>"},{ID:30,
Text:"<fArial Black><s1846>Utugi wakwa ngūtūūra ndīmūrũmiirie kinya o tene na tene, </s></f>"},{ID:31,
Text:"<fArial Black><s1846>nakīo kirīikaniro giakwa gitūūre kirĩo gīa kwīhokeka nīwe.</s></f>"},{ID:32,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ngainīira hĩndī ciothe, Mwathani, mawega maku.</k></c></s></f>"},{ID:33,
Text:"<fArial Black><s1846>GITHOMO KIA IGIRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Atumwo 13: 16-l7; 22-25.</k></c></s></f>"},{ID:34,
Text:"<fArial Black><s1846>GUTHOMA KUUMA IBUKU RIA ATUMWO:</s></f>"},{ID:35,
Text:"<fArial Black><s1846>Paul agīkīrügama, na aarīkia kūmakiria na guoko, akiuga atīrī: Andū aya a Israeli, na inyuī mwītigagīra </s></f>"},{ID:36,
Text:"<fArial Black><s1846>Ngai, ta thikīrīriai. Ngai wa rūrĩrī rürű rűa lsraeli nĩ aathurire maithe maitū, agītūūgīria andū</s></f>"},{ID:37,
Text:"<fArial Black><s1846>a rūrīrī rũu hĩndī írĩa maatūire būrüri wa Misri, agīcoka akīmoimia kuo na guoko gwake kwĩ na ūhoti.</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Na aarīkia kümweheria, agíükīria Davide atuīīke mūthamaki wao; nīwe Ngai oimbūrire ühoro wake</s></f>"},{ID:39,
Text:"<fArial Black><s1846>akiuga atīĩrí : Ní nyonete Davide, műrű wa Jesii, arī mūndũ ürīa ngoro yakwa yendeire o ngoga, </s></f>"},{ID:40,
Text:"<fArial Black><s1846>ürĩa ūríikaga maündű marīa mothe ndīriendaga mekwo, </s></f>"},{ID:41,
Text:"<fArial Black><s1846>Na rīrī, Ngai nī aarehithīirie Aisraeli Muhonokia</s></f>"},{ID:42,
Text:"<fArial Black><s1846>oimīte rűciaro-inī rüa műndű ücio, o ta üria eranĩire, nake nīwe Yesu. Ocio atanoka-rī ,</s></f>"},{ID:43,
Text:"<fArial Black><s1846>John, nĩ aambire kühunjíria andű othe a Israeli ühoro wa atī andū merire na mabatithio.</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Nake John, riria akiriī kühingia rügendo rüake rüa gükü thĩ, akiuga atirī : Mägükīī gereria ati</s></f>"},{ID:45,
Text:"<fArial Black><s1846>niĩ ndĩ ű ? Nĩ ti níĩ ürĩa ügüüka. No atirī, nĩ harí ügüüka thutha wakwa, </s></f>"},{ID:46,
Text:"<fArial Black><s1846>ürīa niĩ itaigaine wa kuohora 
mĩkwa ya iratű ciake.</s></f>"},{ID:47,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:48,
Text:"<fArial Black><s1846>RUIMBO RUA ALLELUYA</s></f>"},{ID:49,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya, Alleluya. </k></c></s></f>"},{ID:50,
Text:"<fArial Black><s1846>Rüciù ūru wa th</s></f><fSegoe UI Black><s1846>ỉ</s></f><fArial Black><s1846> nĩ ūgathario, na Niūthamaki wa thĩ agathana igūrű ritū.</s></f>"},{ID:51,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya.</k></c></s></f>"},{ID:52,
Text:"<fArial Black><s1846>(LONG)</s></f>"},{ID:53,
Text:"<fArial Black><s1846>GITHOMO KIA INJIRI 
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mathayo 1: 1 -25. </k></c></s></f>"},{ID:54,
Text:"<fArial Black><s1846>lbuku rirīnīrīo rīandīkītwo ühoro wa rūciaro rűrīa Yesu Kristũ, mũrũ wa Davide, műrű wa Abraham, </s></f>"},{ID:55,
Text:"<fArial Black><s1846>oimire. Abraham nīwe waciarire Isaaka; nake lsaaka agīciara Jakobu; nake Jakobu agīciara Juda o na </s></f>"},{ID:56,
Text:"<fArial Black><s1846>ariũ a ithe; nake Juda agīciara Fares na Zaram, na nyina wao aarī Tamar; nake Fares agīciara Esrom; </s></f>"},{ID:57,
Text:"<fArial Black><s1846>nake Esrom agīciara Aram; Aram agīciara Aminadab; nake Aminadab agíciara Naasson;</s></f>"},{ID:58,
Text:"<fArial Black><s1846>nake Naasson agīciara Salmon; nake Salmon agīciara Booz, na nyina aarī Rahab; nake Booz agīciara</s></f>"},{ID:59,
Text:"<fArial Black><s1846>Obed, na nyina aarĩ Ruth; nake Booz agīciara Jesse; nake Jesse agīciara Davide, ūrīa warī mūthamaki.</s></f>"},{ID:60,
Text:"<fArial Black><s1846>Nake Davide agīciara Salomon, na nyina aarī mütumia ürīa warī o mbere wa Uria; nake</s></f>"},{ID:61,
Text:"<fArial Black><s1846>Salomon agīciara Rohoboamu; nake Rohoboamu agīciara Abia; nake Abia agīciara Asa; nake Asa</s></f>"},{ID:62,
Text:"<fArial Black><s1846>agīciara Josaphat; nake Josaphat agīciara Yoram; nake Yoram agīciara Ozia; nake Ozia agīciara </s></f>"},{ID:63,
Text:"<fArial Black><s1846>Yoatam; nake Yoatam agīciara Akaz; nake Akaz agīciara Ezekia; nake Ezekia agīciara Manasse: nake</s></f>"},{ID:64,
Text:"<fArial Black><s1846>Manasse agīciara Amon; nake Amon agĩciara Josia; nake Josia agīciara Yekonia na ariũ a ithe, hĩndī</s></f>"},{ID:65,
Text:"<fArial Black><s1846>īrīa andū maatahirūo magī twarűo Babilonia.</s></f>"},{ID:66,
Text:"<fArial Black><s1846>O na andũ maarīkia gūtahwo magītwarűo kūu Babilonia, Yekonia űcio agīciara Salatiel; nake Salatiel </s></f>"},{ID:67,
Text:"<fArial Black><s1846>agīciara Zorobabel; nake Zorobabel agīciara Abiud; nake Abiud agīciara Eliacim; nake Eliacim</s></f>"},{ID:68,
Text:"<fArial Black><s1846>agīciara Azor; nake Azor agíciara Sadok; nake Sadok agīciara Akim; nake Akim agīciara Eliud;</s></f>"},{ID:69,
Text:"<fArial Black><s1846>nake Eliud agīciara Eleazar; nake Eleazar agīciara Mattan; nake Mattan agīciara Yakobu; </s></f>"},{ID:70,
Text:"<fArial Black><s1846>nake Yakobu  agīciara Joseph, ürīa warī müthuri wa Maria, ürīa waciarire Yesu, ürīa wītagwo Kristo.</s></f>"},{ID:71,
Text:"<fArial Black><s1846>Noguo njiaro ciothe gwata Abraham kinya Davide, nĩ ikūmi na inya; ningī gwata Davide kinya andũ </s></f>"},{ID:72,
Text:"<fArial Black><s1846>maatahwo magītwarūo Babilonia, nĩ njiaro ikūũmi na inya; na ningĩ gwata andū maatahwo </s></f>"},{ID:73,
Text:"<fArial Black><s1846>magītwarűo kūu Babilonia, kinya Kristū, nī njiaro ikūmi na inya,</s></f>"},{ID:74,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani,</s></f>"},{ID:75,Style:{Background:{BodyRect:"0,0,10000,9300"}},
Text:"<fArial Black><s1846>(SHORT FORM)</s></f>"},{ID:76,
Text:"<fArial Black><s1846>GITHOM0 KIA INJIRI 
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mathayo 1: 18- 25</k></c></s></f>"},{ID:77,
Text:"<fArial Black><s1846>Rīu-rī, gūciarūo kwa Yesu Kristū gwatariï üű: nyina Maria orio nĩ Joseph, matanonana, akīonwo</s></f>"},{ID:78,
Text:"<fArial Black><s1846>arī na ihu rīa Muoyo Mütheru. Nake mūthuri-we Joseph, tondū aarī mūndű mūthingu, na ndendaga</s></f>"},{ID:79,
Text:"<fArial Black><s1846>gūconorithia mūirītu ūcio kūrĩ andu akīenda atigane nake na hitho. Na hĩndĩ ĩrĩa eciragia maündū</s></f>"},{ID:80,
Text:"<fArial Black><s1846>macio, atīrīrī, mūraika wa Mwathani akĩmuumīrira kīroto-inī, akĩmwīra atīrí: Joseph, mūrũ wa</s></f>"},{ID:81,
Text:"<fArial Black><s1846>Davide, ndūgetigīre kūhikia Maria atuīke műtumia waku, tondü-ī, ihu rīu arī narīo nĩ rīa Muoyo</s></f>"},{ID:82,
Text:"<fArial Black><s1846>Mütheru. Nake nī agaciara kahī , nako nī ügagatua Yesu, nĩ ündū nīwe ükahonokia andü ake me-</s></f>"},{ID:83,
Text:"<fArial Black><s1846>hia-inī mao. Na rīrī, maūndū macio mekirūo nĩ getha ciugo iria cioigirūo nĩ Mwathani na kanua ka</s></f>"},{ID:84,
Text:"<fArial Black><s1846>mūnabii ikinye, rīrīa oigire atīrī: Onei, mũirītu nī akagīa ihu, na aciare kahī, nako gatuwo Emanueli; </s></f>"},{ID:85,
Text:"<fArial Black><s1846>üguo naguo ūgītaūrūo, nĩ kuuga: Ngai hamwe na ithuĩ. Nake Joseph agiukīra toro, agīīka o ta</s></f>"},{ID:86,
Text:"<fArial Black><s1846>ürīa mūraika wa Mwathani aamwathire, akīhikia mūtumia wake, </s></f>"},{ID:87,
Text:"<fArial Black><s1846>na ndaigana kūmūmenya kinya 
aaciara kahīí; agīgatua Yesu.</s></f>"},{ID:88,
Text:"<fArial Black><s1846>Injiri theru ya Mwathani,</s></f>"}],VideoDuration:0,Style:{Background:{Image:"chrisimg.jpg",Luminosity:-45}},
Text:"MITHA YA VIGILIA YA ICIARIRO (MWERI 24 HWAINI)"},{Guid:"GkWq5CDP3EORtD7xpjFvEA",Verses:[{Style:{Background:{Luminosity:-45}},
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF0000>MITHA YA KĪROKO YA ICIARIRO</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GiTHOMO KĪA MBERE
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaia : 62: 11 - 12.</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>GUTHOMA KUUMA MURATHI ISAIA :</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Mwathani nĩ ahunjītie ūhoro üyũ o nginya ituri ciothe cia thĩ: atīrīrī: írai mwarí wa Sion úú,</s></f>"},{ID:5,
Text:"<fArial Black><s1846>rĩa ūgūkūhonokia akiriī gūūka, naguo ūtungati wake enaguo, o na irīhanīria rīake rīrĩ o mbere yake.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Acio mariīitagwo andū arīa aamūre, o arīa akūüre nĩ Mwathani; </s></f>"},{ID:7,
Text:"<fArial Black><s1846>ningī wee üriītagwwo üū: itüüra
rīria rīrongorie, o na itūüra rīrĩa rītagacoka gūthamwo.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>THABURI YA GŪCOKERŪO
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Thaburi 97: 1. 6. 11. 12.</k></c></s></f>"},{ID:10,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA: </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Úmūthĩ twathīirīirūo nī ütheri wa Mwathani.</k></c></s></f>"},{ID:11,
Text:"<fArial Black><s1846>1. Mwathani agwatite gūthamaka; thĩ ta nĩ ícanjamūke; </s></f>"},{ID:12,
Text:"<fArial Black><s1846>maburūri marīa ma iria-inī o namo
nĩ magīkene o ūguo maingīhīte</s></f>"},{ID:13,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA: </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Úmūthĩ twathīirīirūo nī ütheri wa Mwathani.</k></c></s></f>"},{ID:14,
Text:"<fArial Black><s1846>2.Igūrú nĩ riraanīrira ūthingu wake, riri wake nĩ muoneku nĩ irindī ciothe cia thĩ.</s></f>"},{ID:15,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA:</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000> Úmūthĩ twathīirīirūo nī ütheri wa Mwathani.</k></c></s></f>"},{ID:16,
Text:"<fArial Black><s1846>3.Mūndű üria mūthingu nĩ ahurñirūo ūtheri, arīa a ngoro nūngīriru-ri, ni ahurīre gikeno.</s></f>"},{ID:17,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA: </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Úmūthĩ twathīirīirūo nī ütheri wa Mwathani.</k></c></s></f>"},{ID:18,
Text:"<fArial Black><s1846>3.No gīkenerei Mwathani, inyuī athingu, </s></f>"},{ID:19,
Text:"<fArial Black><s1846>Riítwa rīake riamūre műkirīcokerie ngatho.</s></f>"},{ID:20,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA: </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Úmūthĩ twathīirīirūo nī ütheri wa Mwathani.</k></c></s></f>"},{ID:21,
Text:"<fArial Black><s1846>GiTHOMO KIA IGIRÍ
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Tito 3: 4-7.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>GŪTHOMA MARŪA NA MŪTHURE PAUL KŪRĪ TITO :</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Mwendwo wakwa, índí rirīa ūtugi wa Ngai Mühonokia witű naguo wendani ürīa endete andũ naguo</s></f>"},{ID:24,
Text:"<fArial Black><s1846>ciaguūkire nī kūhonokia aatūhonokirie, ti tondũ wa ciīko iria twekaga ithuene cia gwiītua athingu,</s></f>"},{ID:25,
Text:"<fArial Black><s1846>no nĩ ūndū wa tha ciake, nī gūtūthambia o gūthambio kürĩa gűtümaga mūndũ aciarūo rīngī na erühio </s></f>"},{ID:26,
Text:"<fArial Black><s1846>na Muoyo Mūtheru. Na nĩ Muoyo ūcio aatüitīríirie na ūtana na ündű wa Yesu Kristū Mūhonokia witü, </s></f>"},{ID:27,
Text:"<fArial Black><s1846>nī getha tütuwo athingu nĩ ündü wa Wega wake, </s></f>"},{ID:28,
Text:"<fArial Black><s1846>na agai a gūkagaīrũo muoyo ürĩa ütagathi
ra, kūringana na ürīa tūtūire tũwīrīgiřīire.</s></f>"},{ID:29,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:30,
Text:"<fArial Black><s1846>RŪIMBO RUA ALLELUYA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Luka 2, 14.</k></c></s></f>"},{ID:31,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya, Alleluya. </k></c></s></f>"},{ID:32,
Text:"<fArial Black><s1846>Ngai arokumagio igūrű ma, naguo thayű ürogia gükū thĩí kürī andū arīa akenagīra. </s></f>"},{ID:33,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya.</k></c></s></f>"},{ID:34,
Text:"<fArial Black><s1846>GITHOMO KIA INJIRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Luka 2: 15 - 20.</k></c></s></f>"},{ID:35,
Text:"<fArial Black><s1846>GÍCUNJÍ KIA INJIRI THERU TA ŪRĪA YANDIKITWO NI MŪTHURE LUKA :</s></f>"},{ID:36,
Text:"<fArial Black><s1846>Gügīkinya atirī, ririĩa araika maatiganire nao macoke lgūrű, arīithi acio makīīrana atīrī: Thií i t</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>thiĩ</s></f>"},{ID:37,
Text:"<fArial Black><s1846>o rīu tūkinye o Betlehem, tūkone ūhoro üyū ükinyīte, ūcio Mwathani atūmenyithītie.</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Nao magīthi mahiühīte, magīkora Maria na Joseph, o erī, o na gakenge kau gakometio mūharatī -inī.</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Na maakona, makī heana ühoro wa ciugo iria maarīirio ūndū wa kaana kau. </s></f>"},{ID:40,
Text:"<fArial Black><s1846>Nao andū othe arīa maaüiguire makī gega nī ündũ wa maūndū </s></f>"},{ID:41,
Text:"<fArial Black><s1846>marīa maarīirio ni arīithi acio. Nowe Maria agīikara </s></f>"},{ID:42,
Text:"<fArial Black><s1846>maūndū macio mothe, akamacūranagia na ngoro yake. Nao arīithi acio makīhūndūka, makīgoocaga </s></f>"},{ID:43,
Text:"<fArial Black><s1846>Ngai na makīmūkumagia nĩ ündū wa maūndű marīa mothe maaiguire na marīa monire, o ta ürīa merītwo.</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Icio nĩcio ciugo cia Mwathani.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"OIP (3).jpg",Luminosity:-50}},
Text:"MITHA YA KĪROKO
 YA ICIARIRO"},{Guid:"8zdxLXh0mEaKf6qDbN0G4Q",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF0000>MITHA YA MUTHENYA</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GÍTHOMO KIA MBERE
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaia 52: 7 - 10</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>GŪTHOMA KUUMA MŪRATHI ISAIA :</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Kūu irīma-inī igūrū-rĩ, kaï magūrű ma mündū üría ürarehe ūhoro mwega nĩ maagīrīire-ī, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>o ücio ürahunjanīria ūhoro wa thayū, na akarehe ühoro mwega wa maündūmaagīrīru, \\</s></f>"},{ID:6,
Text:"<fArial Black><s1846>o na akahunjanīria ūhoro wa kūhonokanio, o we ürīa ürera Sion atīrī: </s></f>"},{ID:7,
Text:"<fArial Black><s1846>Ngai waku nīwe ürathamaka! Ta igua mūgambo wa</s></f>"},{ID:8,
Text:"<fArial Black><s1846>arangīri aku ! Nĩ maūhaicītie na igūrũ, na meküina me hamwe; </s></f>"},{ID:9,
Text:"<fArial Black><s1846>nĩ ündū nĩ mekuonana nake ūthi</s></f><fSegoe UI Black><s1846>ữ
</s></f><fArial Black><s1846>na ūthiũ hĩndī īria Mwathani egūcoka Sion. </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Atīrĩrī, inyuī kündū kwanangīku kwa Jerusalem, ītīkanai na gũkena mūine hamwe; </s></f>"},{ID:11,
Text:"<fArial Black><s1846>nĩ gūkorűo Mwathani nĩ ahoreretie andūake na agakūũra Jerusalem .</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Mwathani nĩ aguűrīirie ndūrīrĩ ciothe guoko gwake gūtheru, </s></f>"},{ID:13,
Text:"<fArial Black><s1846>ikuone na maitho macio; nacio ituri
ciothe cia thĩ nĩ irīona ūhonokanio wa Ngai witü.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:15,
Text:"<fArial Black><s1846>THABURI YA GŪCOKERŪO
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Thaburi 98: 1: 2-3a; 3b-4: 5-6.</k></c></s></f>"},{ID:16,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ituri ciothe cia thĩ nĩ cionete Ühonokia wa Mwathaní.</k></c></s></f>"},{ID:17,
Text:"<fArial Black><s1846>1. Îkīarükei kūinīra Mwathani rūimbo rúerú, tondū nĩ ekíte maűndũ ma magegania; </s></f>"},{ID:18,
Text:"<fArial Black><s1846>guoko gwake kwa ürío, gwake mwene, nikuo kūmūhonokanīirie, o kuo gicoka kīu gīake githeru.</s></f>"},{ID:19,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ituri ciothe cia thĩ nĩ cionete Ühonokia wa Mwathaní.</k></c></s></f>"},{ID:20,
Text:"<fArial Black><s1846>2. Mwathani nĩ atúmīte ühonokania wake ūmenyeke wega; 
ūthingu wake nĩ aügu</s></f><fSegoe UI Black><s1846>ứ</s></f><fArial Black><s1846>ririe maitho-inī</s></f>"},{ID:21,
Text:"<fArial Black><s1846>ma nd</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>rirí Kuririkana ni akiririkanīte ūtugi wake o na wihokeku wake, iria onagia nyūmba ya Israéli.</s></f>"},{ID:22,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ituri ciothe cia thĩ nĩ cionete Ühonokia wa Mwathaní.</k></c></s></f>"},{ID:23,
Text:"<fArial Black><s1846>3. Uhonokania wa Ngai witū-rī, ituri ciothe cia thĩ rĩu nĩciwonete. </s></f>"},{ID:24,
Text:"<fArial Black><s1846>Inyuĩ andū othe a thĩ, anīrīrai
Mwathani na gīkeno; tumūkai, mūkūngūiye; ii-ni, mūkimūgooce na nyimbo.</s></f>"},{ID:25,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ituri ciothe cia thĩ nĩ cionete Ühonokia wa Mwathaní.</k></c></s></f>"},{ID:26,
Text:"<fArial Black><s1846>4. Inirai Mwathani mūkimugoocaga na inanda cia mūgeto; inanda-ni, o na mugambo wa kuina
thaburi. </s></f>"},{ID:27,
Text:"<fArial Black><s1846>Inai na tũrumbeta, na ūgambi wa coro, mūkīanĩrire na gīkeno mwi mbere ya Mūthamaki, o we Mwathani.</s></f>"},{ID:28,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Ituri ciothe cia thĩ nĩ cionete Ühonokia wa Mwathaní.</k></c></s></f>"},{ID:29,
Text:"<fArial Black><s1846>GĪTHOMO KĪA IGĪRĪ
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aheberea 1: 1 -6</k></c></s></f>"},{ID:30,
Text:"<fArial Black><s1846>GŪTHOMA MARUA MARIA MAANDIKĪIRUO KURI ANDŪ AHEBEREA :</s></f>"},{ID:31,
Text:"<fArial Black><s1846>Ngai ürīa waaragīria maithe maitü matukū- inī m</s></f><fSegoe UI Black><s1846>ạ</s></f><fArial Black><s1846> tene na tũnua twaanabii, </s></f>"},{ID:32,
Text:"<fArial Black><s1846>akaaragia na ikīro nyingí na njíra nyingī- rĩ, 
o matukū-inī maya ma kürigirīria nĩ atwarīirie ithuí na kanua ka múriú, </s></f>"},{ID:33,
Text:"<fArial Black><s1846>ūrīa aatuire mūgai wa kūgaya indo ciothe; o nacio thĩ ciothe aaciümbire na njīra ya Müriũ o ūcio.</s></f>"},{ID:34,
Text:"<fArial Black><s1846>Nake we, tondū wa ürīa akengete, nĩ onithanagia riri wa Ngai, na nīwe mūhianīre kūna</s></f>"},{ID:35,
Text:"<fArial Black><s1846>wa ürīa Ngai atarii, na ningī nīwe ūtiragīrīra indo ciothe na kiugo gīake nĩ üria kīí na ūhoti.</s></f>"},{ID:36,
Text:"<fArial Black><s1846>úcio-rī, aarīkia kūhoroheria andū mehia, 
agīīkara thi guoko-inī kwa ūrīo kwa ürīa Miwene Ükaru o</s></f>"},{ID:37,
Text:"<fArial Black><s1846>kūu lgūrū. Nake nĩ gūtuwo aatuirüo mũnene gūkīra araika, </s></f>"},{ID:38,
Text:"<fArial Black><s1846>o küringana na ūrīa aagaīirūo rīitwa rīagirīte cwa. Nĩ ündũ araika-rī , </s></f>"},{ID:39,
Text:"<fArial Black><s1846>nĩ ürikű wao aanera üü o na rĩ, atī : Wee, nīwe Mūrũ wakwa, ni ümüthĩ nĩ ndagūciara ? </s></f>"},{ID:40,
Text:"<fArial Black><s1846>O na kana ningī- rī, nĩ niĩ ngūtuika Ithe, nake atuike wakwa ? </s></f>"},{ID:41,
Text:"<fArial Black><s1846>Na ningī, aarehe irigithathi rīake gūkū thĩ, akoiga atīrī : 
Na araika othe a Ngai nī mamūturagīrie ndu.</s></f>"},{ID:42,
Text:"<fArial Black><s1846>Icio nĩcio ciugo cia Mwathani.</s></f>"},{ID:43,
Text:"<fArial Black><s1846>RÜIMBO RŪA ALLELUYA</s></f>"},{ID:44,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya, Alleluya. </k></c></s></f>"},{ID:45,
Text:"<fArial Black><s1846>Müthenya mwega nĩ ütwarīire űmüthĩ.
Okai inyui othe mütīe Mwathani; ütheri műnene nī üikürūükīire thī, </s></f>"},{ID:46,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya .</k></c></s></f>"},{ID:47,
Text:"<fArial Black><s1846>GĪTHOMO KIA INJIRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>John l: 1 - 18,</k></c></s></f>"},{ID:48,
Text:"<fArial Black><s1846>KĪAMBĨRIRIA INJIRI THERU TA ŪRÍA YANDĪKÍTWO NĪ MŪTHURE JOHN</s></f>"},{ID:49,
Text:"<fArial Black><s1846>O kīambīriria-rī, Uge warī o kuo, naguo Uge watüire o hari Ngai, o naguo Uge warí o Ngai. </s></f>"},{ID:50,
Text:"<fArial Black><s1846>Ocio Uge -ri, nĩ aggītūire harī Ngai o kīambirīria. Indo ciothe ikīgīa ciagĩire nĩ ündũ wake, </s></f>"},{ID:51,
Text:"<fArial Black><s1846>na kīndú o gīothe kīrīa kīgite, gūtirī kīagīire we atarī ho, o na kīmwe. </s></f>"},{ID:52,
Text:"<fArial Black><s1846>Thĩinī wake nīkuo kwarī muoyo, naguo muoyo ücio nīguo warī ūtheri wa andū. </s></f>"},{ID:53,
Text:"<fArial Black><s1846>Naguo ūtheri nĩ ütūire o ütherete nduma-inī, nayo nduma ndīaūhootire. </s></f>"},{ID:54,
Text:"<fArial Black><s1846>Nĩ gwokire mũndű wareketio nĩ Ngai, wetagwo John, Mündũ ücio okire nĩ ündū wa ūira, </s></f>"},{ID:55,
Text:"<fArial Black><s1846>oimbūre ūhoro wa ūtheri ücio, nĩ getha andū othe metikie nĩ ündūũ wake.</s></f>"},{ID:56,
Text:"<fArial Black><s1846>Na tiwe ūtheri ūcio; okire nĩ getha oimbūre űhoro waguo, ūtheri ūcio. </s></f>"},{ID:57,
Text:"<fArial Black><s1846>Utheri küna, üria ümūrīkagīra mũndū o wo the, nĩ warī kuo ügīūkaga thĩ. </s></f>"},{ID:58,
Text:"<fArial Black><s1846>We, Otheri ūcio, aarī gūkū thĩ, o nayo thĩ ikīgīa yagīire nĩ ūndũ wake, </s></f>"},{ID:59,
Text:"<fArial Black><s1846>nakīo kīrīndĩ gīa gükũ thĩ gīkīaga kūmūmenya. Okire gwake mwene ,</s></f>"},{ID:60,
Text:"<fArial Black><s1846>nao andū ake mwene matiigana kümwītiīkīra. No arĩa othe maamwītikīrire, </s></f>"},{ID:61,
Text:"<fArial Black><s1846>nĩo arīa mehokete ríítwa rīake, acio akīmahotithia gütuika ciana cia Ngai, </s></f>"},{ID:62,
Text:"<fArial Black><s1846>itaaciarirūonĩ thakame, kana igīciarūo nĩ
kwenda kwa mwīrī kana kwenda kwa mūndū, no Ngai. </s></f>"},{ID:63,
Text:"<fArial Black><s1846>We, Uge - rĩ, agīgītuīka mūndū, agītūürania na ithuĩ aiyũirűo nĩ ütugi </s></f>"},{ID:64,
Text:"<fArial Black><s1846>na ühoro-ūrīa-wa-ma na ithuĩ tūkīionera riri wake, 
riri o ta wa mwana wa mūmwe oimīte kūrī ithe.</s></f>"},{ID:65,
Text:"<fArial Black><s1846>John nĩ oimbūrīte ühoro wake, akaanīrīra akoiga atīrī : </s></f>"},{ID:66,
Text:"<fArial Black><s1846>Ücio nowe ndoigire, atī, Üria ügūüka thutha wakwa nĩ agīīte mbere yakwa, </s></f>"},{ID:67,
Text:"<fArial Black><s1846>nī gūkorūo aarī kuo mbere yakwa. Amu-rī, thĩinĩ wa kūiyūrūo</s></f>"},{ID:68,
Text:"<fArial Black><s1846>kūu gwake twanaheo ithuothe, tügītugagwo rīngĩ na rĩngī. </s></f>"},{ID:69,
Text:"<fArial Black><s1846>Tondū watho watūmirūo na Musa; ütugi na ūhoro-ūrīa-wa-ma mokire na Yesu Kristū, </s></f>"},{ID:70,
Text:"<fArial Black><s1846>Gütirī mündū ürī ona Ngai; Müriũ wa mūmwe, ūria wĩ gīthūri-inī gĩa Ithe, nīwe uumbürīte ühoro wake,</s></f>"},{ID:71,
Text:"<fArial Black><s1846>Injiri Theru ya Mwathani</s></f>"}],VideoDuration:0,Style:{Background:{Image:"OIP (2).jpg"}},
Text:"MITHA YA MUTHENYA
"}],Guid:"XzrLSTjdvUGOMnXSWmYosg",
Text:"VIGILIA YA ICIARIRO MWAKA A "}