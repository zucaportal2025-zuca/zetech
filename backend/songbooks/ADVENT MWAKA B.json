{Songs:[{Guid:"HxauO/Clxk+28NLRSl9HQg",Verses:[{Style:{Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_cb1061b1.jpg",Luminosity:5}}},{ID:2,Style:{Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.09_0d0d3c61.jpg"}},
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF3F3F>DOMINIKA YA KWANZA YA MAJILIO 
MWAKA B</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200>Isaya 63:16b-17, 19b; 64:2b-7</c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Wewe, Ee Bwana, ndiwe Baba yetu, 
mkombozi wetu, ndilo jina lako tangu milele!</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Ee Bwana, kwa nini umetuacha sisi kutangatanga mbali na njia zako, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>mioyo yetu kuwa migumu hata hatukuabudu tena?</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Urudi, kwa ajili ya watumishi wako, na makabila yaliyo urithi wako. </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Kama ungepasua mbingu na kushuka chini,</s></f>"},{ID:6,
Text:"<fArial Black><s1846> milima ingetetemeka mbele yako. Ulipotenda miujiza isiyotazamiwa,</s></f>"},{ID:7,
Text:"<fArial Black><s1846> ulishuka nayo milima ilitetemeka mbele yako.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Hakuna mtu aliyearifiwa wala kusikia, hakuna jicho lililoona Mungu yeyote ila wewe tu,</s></f>"},{ID:9,
Text:"<fArial Black><s1846> alitenda hivyo, kwa ajili ya waamini wake.</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Wewe unawaendea kuwapokea watenda mema kwa furaha, </s></f>"},{ID:11,
Text:"<fArial Black><s1846>wale wanaokujali wewe wanapofuata njia zako!</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Tulipokuwa tukitenda dhambi, ulikasirika juu ya watendao maovu, lakini tutaokoka.</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Sisi wote tulikuwa kama watu wachafu mbele yako, </s></f>"},{ID:13,
Text:"<fArial Black><s1846>matendo yetu mema yalikuwa kama nguo chafu;</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Wote tulikuwa tumekauka kama majani, makosa yetu yametupeperusha kama upepo.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Hakuna hata mmoja aliyetaja jina lako, wala mtu aliyeamka ashikamane nawe;</s></f>"},{ID:15,
Text:"<fArial Black><s1846> Maana ulituficha uso wako mbele yetu, na kutuacha katika enzi ya maovu yetu.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Lakini, ee Bwana, ndiwe Baba yetu; nasi ni udongo, </s></f>"},{ID:17,
Text:"<fArial Black><s1846>wewe ndiwe mfinyanzi wetu: sisi sote tu kazi ya mikono yako.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA 
</s></f><fArial Black><s1846><cFFF2F200>Zaburi 80:2ac na 3b, 15-16, 18-19 (K. 4)</c></s></f>"},{ID:2,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Ee Mungu, utuangazishie uso wako, nasi tutaokoka.</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Ewe mchungaji wa Israeli, usikilize,
unayekaa juu ya makerubi, ujionyeshe.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Uamshe nguvu zako kuu, uje, utusaidie tuwe salama. K.</s></f>"},{ID:4,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Ee Mungu, utuangazishie uso wako, nasi tutaokoka.</k></c></s></f>"},{ID:5,
Text:"<fArial Black><s1846>Ee Mungu wa majeshi, urudi;
uangalie toka mbinguni, uone;</s></f>"},{ID:6,
Text:"<fArial Black><s1846>uje kuutazama mzabibu wako,
mche ulioupanda kwa mkono wako wa kulia.(K)</s></f>"},{ID:6,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Ee Mungu, utuangazishie uso wako, nasi tutaokoka.</k></c></s></f>"},{ID:7,
Text:"<fArial Black><s1846>Msaada wako na uwe juu ya mtu aliye mkono wako wa kulia,</s></f>"},{ID:8,
Text:"<fArial Black><s1846>juu ya mwanadamu uliyemtia nguvu kwa ajili yako.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Basi hatutakuacha tena kamwe;
utuhuishe, nasi tutaliitia jina lako. (K)</s></f>"},{ID:9,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Ee Mungu, utuangazishie uso wako, nasi tutaokoka.</k></c></s></f>"},{
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200>1 Wakorintho 1:3-9</c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika barua ya kwanza ya Mtakatifu Paulo kwa Wakorintho</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Ndugu zangu:</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Neema na amani kutoka kwa Mungu Baba yetu na kwa Bwana Yesu Kristo ziwe nanyi. </s></f>"},{ID:5,
Text:"<fArial Black><s1846>Namshukuru Mungu wangu daima kwa ajili yenu, </s></f>"},{ID:6,
Text:"<fArial Black><s1846> kwa sababu ya neema ya Mungu mliyopewa katika Kristo Yesu.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Ndiyo maana katika yeye mmetajirika katika yote, katika kila neno na kila utambuzi.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Kwa hiyo, ushuhuda wa Kristo umethibitika ndani yenu. </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Hivyo hamkosi kipaji cha Roho ninyi mnaotazamia </s></f>"},{ID:10,
Text:"<fArial Black><s1846>kufunuliwa kwake  Bwana wetu Yesu Kristo. </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Naye atawaimarisheni mpaka mwisho, msiwe na kosa siku ya Bwana wetu Yesu Kristo.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Ni Mungu mwaminifu aliyewaita katika ushirika wa Mwanawe Yesu Kristo, Bwana wetu.</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Zaburi 85:8</k></c></s></f>"},{ID:14,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.
Aleluya.</k></c></s></f>"},{ID:15,
Text:"<fArial Black><s1846>Utuonyeshe wema wako, ee Bwana; utuletee wokovu wako.</s></f>"},{ID:16,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f>"},{
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200>Marko 13:33-37</c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Marko</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Wakati ule:
Yesu aliwaambia wafuasi wake: \"Angalieni!</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Kesheni! Kwa maana  hamjui wakati wa kutendeka hayo.</s></f>"},{ID:4,
Text:"<fArial Black><s1846> Ni kama kwa mtu aliyetoka nyumbani aende safarini. Anawapa watumishi wake mamlaka, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>kila
mmoja kazi yake, na bawabu amemwamuru akeshe.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Kesheni basi, kwa maana hamjui bwana wa nyumba atarudi lini, labda jioni, au katikati ya usiku,</s></f>"},{ID:7,
Text:"<fArial Black><s1846> au wakati wa kuwika jogoo, au alfajiri.  Akifika ghafla, asiwakute mmelala usingizi.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Ninayowaambia ninyi, nawaambia watu wote: 'Kesheni!’”</s></f>"},{ID:9,Style:{Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_80a6444a.jpg"}},
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_dd6cdcec.jpg"}},
Text:"DOMINIKA YA KWANZA YA MAJILIO MWAKA B"},{Guid:"0YOg2B5YBUWLuXzUNJ0x1w",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF3F3F>DOMINIKA YA PILI YA MAJILIO MWAKA B</k></c></s></f></u>",IsDisplayed:0},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaya 40:1- 5, 9-11</k></c></s></f>",IsDisplayed:0},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Watulizeni, wapeni tulizo watu wangu, asema Mungu wenu. Semeni na moyo wa Yerusalemu,</s></f>"},{ID:4,
Text:"<fArial Black><s1846> utangazieni ya kwamba: huduma yake ngumu imekwisha, dhambi yake imeondolewa, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>maana kwa mkono wa Bwana amepokea adhabu </s></f>"},{ID:6,
Text:"<fArial Black><s1846>maradufu kwa maovu yake yote. Mtu analia: </s></f>"},{ID:6,
Text:"<fArial Black><s1846>tengenezeni jangwani njia ya Bwana! Nyosheni nyikani </s></f>"},{ID:7,
Text:"<fArial Black><s1846>barabara kwa Mungu wetu! Kila bonde lifukiwe,</s></f>"},{ID:7,
Text:"<fArial Black><s1846> kila mlima na kilima kishushwe, Njia zenye kupotoka zinyoshwe, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>na njia zenye mashimo zisawazishwe.</s></f>"},{ID:8,
Text:"<fArial Black><s1846> Hapo utukufu wa Bwana utafunuliwa, na watu wote </s></f>"},{ID:9,
Text:"<fArial Black><s1846>watauona mara; maana kinywa cha Bwana kimenena haya.</s></f>"},{ID:9,
Text:"<fArial Black><s1846> Panda juu ya mlima mrefu, uutangaziye Sioni habari njema!  </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Paza sauti kwa nguvu, uutangaziye Yerusalemu habari njema! Paza sauti, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>usiogope!  Sema kwa miji ya Yuda: Tazama, Mungu wenu! </s></f>"},{ID:11,
Text:"<fArial Black><s1846>Yupo hapa Bwana Mungu: anakuja kwa uwezo, na mkono wake utatawala;</s></f>"},{ID:11,
Text:"<fArial Black><s1846> tuzo ya ushindi wake litamsindikiza, mateka yake, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>yatamtangulia. Kama mchungaji, atachunga kundi lake; </s></f>"},{ID:12,
Text:"<fArial Black><s1846>mkononi mwake atawakusanya wanakondoo, atawachukua,</s></f>"},{ID:13,
Text:"<fArial Black><s1846>kifuani mwake, atawaongoza kondoo wenye kunyonyesha.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Zaburi 85:9ab na 10, 11-12, 13-14 (K.8)</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Utuonyeshe wema wako, ee Bwana; utuletee wokovu wako.</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Ninasikia anayosema Bwana Mungu;
hakika, anasema maneno ya amani.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Wokovu wake ni karibu nao wenye kumcha;
utukufu wake utakaa katika nchi yetu. (K)</s></f>"},{ID:4,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Utuonyeshe wema wako, ee Bwana; utuletee wokovu wako.</k></c></s></f>"},{ID:5,
Text:"<fArial Black><s1846>Wema na uaminifu zitakutana;
haki na amani zitabusiana.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Uaminifu utachipuka katika nchi;
na haki itachungulia kutoka mbinguni. (K)</s></f>"},{ID:6,
Text:"<fArial Black><s1846><kFFFF3F3F>(K) </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Utuonyeshe wema wako, ee Bwana; utuletee wokovu wako.</k></c></s></f>"},{ID:7,
Text:"<fArial Black><s1846>Naye Bwana atatoa yaliyo mema;
na nchi yetu itatoa mazao.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Haki itatangulia mbele ya Bwana,
Wokovu utafuata nyayo zake.(K)</s></f>"},{ID:8,
Text:"<fArial Black><s1846>(K) Utuonyeshe wema wako, ee Bwana; utuletee wokovu wako.</s></f>"},{
Text:"<fArial Black><s1846><kFFFF3F3F>SOMO LA PILI 
</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>2 Petro 3:8-14</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika barua ya pili ya Mtakatifu Petro</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Ndugu wapendwa, msipitiwe katika jambo hili: siku moja kwa Bwana ni kama miaka elfu, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>na miaka elfu ni kama siku moja.
Bwana,</s></f>"},{ID:5,
Text:"<fArial Black><s1846>hacheleweshi ahadi kama baadhi ya watu wanavyodhani  'anachelewa,' </s></f>"},{ID:5,
Text:"<fArial Black><s1846>bali anawasubiria ninyi kwa sababu hapendi wengine wenu wapotee, bali wote watubu.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Siku ya Bwana itakuja kama mwizi. Hapo mbingu zitatoweka kwa  kishindo kikubwa;</s></f>"},{ID:7,
Text:"<fArial Black><s1846> vitu vitaungua na kuteketea; dunia pamoja na matengenezo yake haitaonekana tena. </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Basi, vitu hivyo vikiharibiwa kwa namna hiyo, je haiwapasi,</s></f>"},{ID:9,
Text:"<fArial Black><s1846>ninyi kuishi kitakatifu zaidi na kumcha Mungu,</s></f>"},{ID:9,
Text:"<fArial Black><s1846> kungoja na kuukimbilia ujio wa siku ya Mungu, ambapo,</s></f>"},{ID:10,
Text:"<fArial Black><s1846>mbingu zitakapoteketea moto na kutoweka, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>na viumbe vitakapoyeyushwa na kuteketezwa?</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Kisha tunatazamia kama alivyoahidi- mbingu mpya na nchi mpya zenye uadilifu. Mkisubiri hayo, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>ndugu wapendwa, mjibidishe kuishi bila mawaa ili mkutwe katika amani.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Luka 3:4, 6</k></c></s></f>"},{ID:15,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya
Aleluya</k></c></s></f>"},{ID:16,
Text:"<fArial Black><s1846>Itengenezeni njia ya Bwana, yanyosheni mapito yake, </s></f>"},{ID:17,
Text:"<fArial Black><s1846>na kila kiumbe kitauona wokovu wa Mungu.</s></f>"},{ID:17,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f>"},{
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Marko 1:1-8</k></c></s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Marko</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Mwanzo wa Injili ya Yesu Kristo, Mwana wa Mungu.  Kama ilivyoandikwa katika nabii Isaya:</s></f>"},{ID:3,
Text:"<fArial Black><s1846>\"Tazama, namtuma mjumbe wangu; akutangulie na kukutayarishia njia. </s></f>"},{ID:4,
Text:"<fArial Black><s1846>Ndiyo sauti ya mtu aliaye nyikani: \"Itayarisheni njia ya Bwana, yanyoosheni mapito yake.\"\"</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Yohane Mbatizaji alitokea nyikani akibatiza na kuutangaza,</s></f>"},{ID:6,
Text:"<fArial Black><s1846>ubatizo wa toba kwa maondoleo ya dhambi. </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Watu wa kutoka sehemu yote ya Yudea na wenyeji wote wa Yerusalemu,</s></f>"},{ID:7,
Text:"<fArial Black><s1846> walikuwa wakimwendea kuungama dhambi zao, naye akawabatiza katika Mto Yordani.</s></f>"},{ID:8},{ID:9,
Text:"<fArial Black><s1846>Yohane alikuwa akivaa singa za ngamia, na mshipi wa ngozi kiunoni mwake. </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Chakula chake kilikuwa nzige na asali ya mwituni. </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Alihubiri akisema, \"Anayekuja baada yangu ni mwenye nguvu  kunipita mimi.</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Kwake sifai hata kuinama na kumfungulia gidamu,</s></f>"},{ID:11,
Text:"<fArial Black><s1846> ya viatu vyake. Mimi nimewabatiza kwa maji; </s></f>"},{ID:11,
Text:"<fArial Black><s1846>yeye lakini atawabatiza kwa Roho Mtakatifu.\"</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_ddf7796b.jpg"}},
Text:"DOMINIKA YA PILI YA MAJILIO MWAKA B"},{Guid:"C5eZ5GR7EkqQ+iVI2bom8g",Verses:[{
Text:"<fArial Black><s1846>DOMINIKA YA TATU YA MAJILIO MWAKA B</s></f>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
Isaya 61:1-2a, 10-11</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Roho wa Bwana Mungu yupo juu yangu,
kwa sababu Bwana amenipaka mafuta.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Amenituma niwahubirie maskini habari njema, kuwaponya waliovunjika moyo:</s></f>"},{ID:6,
Text:"<fArial Black><s1846>kuwatangazia mateka uhuru,
na wafungwa kuvwa huru,</s></f>"},{ID:7,
Text:"<fArial Black><s1846>kutangaza mwaka wa rehema ya Bwana.
Nitafurahi sana katika Bwana,</s></f>"},{ID:8,
Text:"<fArial Black><s1846>roho yangu itamshangilia Mungu wangu.
Maana amenivika mavazi ya wokovu,</s></f>"},{ID:9,
Text:"<fArial Black><s1846>amenifunika vazi la utakatifu,
kama bwana harusi anavyojipamba taji,</s></f>"},{ID:10,
Text:"<fArial Black><s1846>na kama bibi harusi
anavyojivika mapambo yake.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Kama vile udongo unavyotoa machipuko yake,
na kama vile bustani inavyootesha mbegu zake,</s></f>"},{ID:12,
Text:"<fArial Black><s1846>hivyo Bwana Mungu ataotesha utakatifu,
na sifa mbele ya mataifa yote.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
Luka 1:46 48, 49 50, 53 54 </s></f>"},{ID:15,
Text:"<fArial Black><s1846>K. Roho yangu itamshangilia Mungu wangu.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>1.Moyo wangu wamtukuza Bwana;
na roho yangu imeshangilia katika Mungu, 
Mkombozi wangu.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Kwa kuwa ameangalia unyonge wa mtumishi wake;
tazama, toka sasa vizazi vyote wataniita mwenye heri. K.</s></f>"},{ID:18,
Text:"<fArial Black><s1846>K. Roho yangu itamshangilia Mungu wangu.
2.Kwa maana amenitendea makubwa Aliye Mwenyezi, na jina lake ni takatifu.</s></f>"},{ID:19,
Text:"<fArial Black><s1846>Na huruma yake ipo toka kizazi hata kizazi
kwa wale wenye kumcha. K.</s></f>"},{ID:20,
Text:"<fArial Black><s1846>K. Roho yangu itamshangilia Mungu wangu.</s></f>"},{ID:21,
Text:"<fArial Black><s1846>3.Wenye njaa amewashibisha mema,
matajiri amewarudisha mikono mitupu.</s></f>"},{ID:22,
Text:"<fArial Black><s1846>Amemsaidia Israeli, mtumishi wake,
akiikumbuka huruma yake. K.</s></f>"},{ID:23,
Text:"<fArial Black><s1846>K. Roho yangu itamshangilia Mungu wangu.</s></f>"},{ID:24,
Text:"<fArial Black><s1846>SOMO LA PII
1 Wathesalonike 5:16-24</s></f>"},{ID:25,
Text:"<fArial Black><s1846>Somo katika barua ya kwanza ya Mtakatifu Paulo
kwa Wathesalonike</s></f>"},{ID:26,
Text:"<fArial Black><s1846>Ndugu zangu: Furahini kila wakati. Salini bila kuchoka. </s></f>"},{ID:27,
Text:"<fArial Black><s1846>Fanyeni shukrani katika yote: hayo ndiyo atakayo Mungu kwenu katika Kristo Yesu.</s></f>"},{ID:28,
Text:"<fArial Black><s1846>Msimzime Roho. Msiidharau karama ya unabii.
Kagueni yote: yaliyo mema yashikilieni. </s></f>"},{ID:29,
Text:"<fArial Black><s1846>Mabaya ya kila namna yaepukeni.
Naye Mungu wa amani awatakase na kuwakamilisha,</s></f>"},{ID:30,
Text:"<fArial Black><s1846> mpate kuhifadhivwa salama roho, moyo na mwili bila </s></f>"},{ID:31,
Text:"<fArial Black><s1846>hitilafu mpaka kuja kwake Bwana wetu Yesu Kristo.
Yeye aliyetuita ni mwaminifu, atatimiza neno lake.</s></f>"},{ID:32,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:33,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
Isaya 61:1 </s></f>"},{ID:34,
Text:"<fArial Black><s1846>K. Aleluya.
W. Aleluya.</s></f>"},{ID:35,
Text:"<fArial Black><s1846>K. Roho wa Bwana yu juu yangu,
amenituma niwahubirie maskini
habari njema.</s></f>"},{ID:36,
Text:"<fArial Black><s1846>W. Aleluya.</s></f>"},{ID:37,
Text:"<fArial Black><s1846>INJILI
Yohane 1:6-8, 19-28</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Yohane</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Palitokea mtu, ametumwa na Mungu, jina lake Yohane.</s></f>"},{ID:40,
Text:"<fArial Black><s1846>Huyo alikuja kutoa ushuhuda, apate kuushuhudia mwanga ili wote wasadiki kwa sababu yake. </s></f>"},{ID:41,
Text:"<fArial Black><s1846>Yeye hakuwa ule mwanga, ila wajibu
wake ulikuwa kuushuhudia ule mwanga.</s></f>"},{ID:42,
Text:"<fArial Black><s1846>Huu ndio ushuhuda wa Yohane. Wayahudi walipowatuma makuhani</s></f>"},{ID:43,
Text:"<fArial Black><s1846>na Walawi kutoka Yerusalemu waende kwake na kumwuliza, “Wewe u nani?” </s></f>"},{ID:44,
Text:"<fArial Black><s1846>Naye alikiri, wala hakukana; basi akakiri akajibu, “Mimi si Kristo.”</s></f>"},{ID:45,
Text:"<fArial Black><s1846>Wakamwuliza, “Wewe u nani basi? Wewe u Eliya?”
Akasema, “Hapana,”</s></f>"},{ID:46,
Text:"<fArial Black><s1846>“Wewe u nabii yule?”
Akajibu, “La!”
Basi, wakamwambia,</s></f>"},{ID:47,
Text:"<fArial Black><s1846>U nani wewe? Tupate kuwapa majibu wale waliotutuma.</s></f>"},{ID:48,
Text:"<fArial Black><s1846>Wewe mwenyewe wajisema kuwa nani?”
Akasema, </s></f>"},{ID:49,
Text:"<fArial Black><s1846>“Mimi, ni kama alivyonena nabii Isaya – ‘ndiyo sauti ya mtu aliaye nyikani, inyosheni njia ya Bwana.”</s></f>"},{ID:50,
Text:"<fArial Black><s1846>Nao wajumbe walikuwa wa jamii ya Mafarisayo. Wakaendelea kumhoji na kumwambia, </s></f>"},{ID:51,
Text:"<fArial Black><s1846>“Mbona basi, wabatiza, ikiwa wewe si
Kristo, wala Eliya, wala nabii yule?”</s></f>"},{ID:52,
Text:"<fArial Black><s1846>Yohane akawajibu,
“Mimi nabatiza kwa maji”</s></f>"},{ID:53,
Text:"<fArial Black><s1846>Katikati yenu amesimama yeye msiyemjua ninyi,
yeye ndiye anayekuja nyuma yangu,</s></f>"},{ID:54,
Text:"<fArial Black><s1846>ambaye sistahili kufungua ukanda wa kiatu chake.”
Mambo hayo yalitendeka Bethania, </s></f>"},{ID:55,
Text:"<fArial Black><s1846>ng’ambo ya Yordani,
alikobatiza Yohane.</s></f>"},{ID:56,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,
Text:"DOMINIKA YA TATU YA MAJILIO MWAKA B
"},{Guid:"Xdud7z1tfUqvbzFRf2WDmA",Verses:[{
Text:"<fArial Black><s1846>DOMINIKA YA NNE YA MAJILIO MWAKA B</s></f>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
2 Samueli 7:1-5, 8b-12, 14a, 16</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha pili cha Samueli</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Mfalme Daudi, alipokuwa akikaa katika nyumba yake, na Bwana</s></f>"},{ID:5,
Text:"<fArial Black><s1846>akiwa amemstarehesha, asibughudhiwe na adui zake waliomzunguka </s></f>"},{ID:6,
Text:"<fArial Black><s1846>pande zote, alimwambia Nathani nabii, \"Tazama, mimi ninakaa</s></f>"},{ID:7,
Text:"<fArial Black><s1846>katika nyumba ya mierezi, na sanduku la Bwana linakaa katika</s></f>"},{ID:8,
Text:"<fArial Black><s1846>hema!\" Nathani akamjibu mfalme, \"Haya, nenda ukafanye yote</s></f>"},{ID:9,
Text:"<fArial Black><s1846>yaliyomo moyoni mwako, maana Bwana yu pamoja nawe.\"</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Lakini usiku huo huo neno la Bwana likamjia Nathani kusemna:</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Nenda ukamwambie mtumishi wangu Daudi, Bwana anasema</s></f>"},{ID:12,
Text:"<fArial Black><s1846>hivi: Je, wewe utanijengea nyumba, nikae ndani yake? </s></f>"},{ID:13,
Text:"<fArial Black><s1846>Mimi nalikutwaa katika kazi ya kuwalisha na kuwaandama kondoo ili</s></f>"},{ID:14,
Text:"<fArial Black><s1846>uwe mkuu juu ya watu wangu Israeli; nimekuwa pamoja nawe</s></f>"},{ID:15,
Text:"<fArial Black><s1846>popote ulipokwenda na nimewaondosha maadui zako wote mbele yako.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Nami nitakufanyia jina kuu, kama jina la wakuu waliopo duniani.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Nami nitawawekea mahali watu wangu Israeli, nitawapanda</s></f>"},{ID:18,
Text:"<fArial Black><s1846>wapate kukaa mahali pao wenyewe, wasiweze kuondolewa tena,</s></f>"},{ID:19,
Text:"<fArial Black><s1846>wala wana wa uovu hawatawasumbua tena, kama hapo zamani,</s></f>"},{ID:20,
Text:"<fArial Black><s1846>tangu nilipowaweka waamuzi juu ya Israeli watu wangu. </s></f>"},{ID:21,
Text:"<fArial Black><s1846>Nami nitakustarehesha mbele ya adui zako wote.</s></f>"},{ID:22,
Text:"<fArial Black><s1846>Tena, Bwana anakufunulia kuwa atakujengea nyumba.</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Na siku zako Zitakapotimia, nawe umejipumzisha na baba zako, </s></f>"},{ID:24,
Text:"<fArial Black><s1846>nitamwinua mzao wako, baada yako atokaye viunoni mwako, </s></f>"},{ID:25,
Text:"<fArial Black><s1846>nami nitauimarisha ufalme wake. Mimi nitakuwa baba yake, naye atakuwa mwanangu.</s></f>"},{ID:26,
Text:"<fArial Black><s1846>Nayo nyumba yako na ufalme wako vitadumu milele mbele yangu,</s></f>"},{ID:27,
Text:"<fArial Black><s1846>na kiti chako kitakaa imara milele.\"</s></f>"},{ID:28,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:29,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
Zaburi 89:2-3. 45, 27 na 29 </s></f>"},{ID:30,
Text:"<fArial Black><s1846>K. Fadhili zako nitaziimba milele, ee Bwana.
Fadhili za Bwana nitaziimba milele,</s></f>"},{ID:31,
Text:"<fArial Black><s1846>1.kwa kinywa changu nitavijulisha vizazi vyote uaminifu wako.</s></f>"},{ID:32,
Text:"<fArial Black><s1846>Maana ulisema: Wema wangu wadumu milele;
uaminifu wangu umesimikwa katika mbingu. K.</s></f>"},{ID:33,
Text:"<fArial Black><s1846>K. Fadhili zako nitaziimba milele, ee Bwana.
Fadhili za Bwana nitaziimba milele,</s></f>"},{ID:34,
Text:"<fArial Black><s1846>2.Nimefunga agano na mteule wangu,
nimemwapia Daudi, mtumishi wangu:</s></f>"},{ID:35,
Text:"<fArial Black><s1846>nitawasimika wazao wako hata milele,
nitaimarisha kiti cha ufalme wako kwa vizazi vyote. K.</s></f>"},{ID:36,
Text:"<fArial Black><s1846>K. Fadhili zako nitaziimba milele, ee Bwana.
Fadhili za Bwana nitaziimba milele,</s></f>"},{ID:37,
Text:"<fArial Black><s1846>3.Yeye ataniita, ‘Wewe ni Baba yangu,
Mungu wangu na mwamba wa wokovu wangu!”</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Nitamhifadhia fadhili zangu hata milele,
na agano langu kwake litadumu imara milele. K.</s></f>"},{ID:39,
Text:"<fArial Black><s1846>K. Fadhili zako nitaziimba milele, ee Bwana.
Fadhili za Bwana nitaziimba milele,</s></f>"},{ID:40,
Text:"<fArial Black><s1846>SOMO LA PILI
Warumi 16:25-27
 
Somo katika barua ya Mtakatifu Paulo kwa Warumi</s></f>"},{ID:41,
Text:"<fArial Black><s1846>Ndugu zangu: Asifiwe mwenye enzi ya kuwaimarisha ninyi kadiri</s></f>"},{ID:42,
Text:"<fArial Black><s1846>ya Injili yangu na tangazo la Yesu Kristo, pia kadiri ya ufunuo</s></f>"},{ID:43,
Text:"<fArial Black><s1846>wa fumbo lile lililofichika tangu karne za milele.</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Sasa lakini limefunuliwa kwa njia ya Maandiko ya manabii</s></f>"},{ID:45,
Text:"<fArial Black><s1846>kama Mungu wa milele alivyotaka ili kuwaongoza mataifa yote</s></f>"},{ID:46,
Text:"<fArial Black><s1846>wapate kuitii imani. Mungu mmoja mwenye hekima aheshimiwe</s></f>"},{ID:47,
Text:"<fArial Black><s1846>na kusifiwa kwa njia ya Yesu Kristo, milele na milele. Amina.</s></f>"},{ID:48,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:49,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
Luka 1:38</s></f>"},{ID:50,
Text:"<fArial Black><s1846>K. Aleluya.
W. Aleluya.</s></f>"},{ID:51,
Text:"<fArial Black><s1846>K. Tazama mimi ni mtumishi wa Bwana,
nitendewe ulivyonena.</s></f>"},{ID:52,
Text:"<fArial Black><s1846>W. Aleluya.</s></f>"},{ID:53,
Text:"<fArial Black><s1846>INJILI
Luka 1:26-38</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Luka</s></f>"},{ID:55,
Text:"<fArial Black><s1846>Wakati ule: Malaika
Gabrieli alitumwa na Mungu aende katika mji</s></f>"},{ID:56,
Text:"<fArial Black><s1846>wa Galilaya uitwao Nazareti, kwa mwanamwali bikira, mchumba wa mtu. </s></f>"},{ID:57,
Text:"<fArial Black><s1846>jina lake Yosefu, wa nyumba ya Daudi, na jina la huyo bikira lilikuwa Maria. </s></f>"},{ID:58,
Text:"<fArial Black><s1846>Na malaika akaingia kwake, akasema,
“Salamu, uliyejaa neema! Bwana yu nawe.”</s></f>"},{ID:59,
Text:"<fArial Black><s1846>Naye akashtuka kwa sababu ya maneno hayo, na akawaza maana ya maamkio hayo.</s></f>"},{ID:60,
Text:"<fArial Black><s1846>Malaika akamwambia,
“Usiogope, Maria, kwa maana umebarikiwa na Mungu.</s></f>"},{ID:61,
Text:"<fArial Black><s1846>Tazama, utachukua mimba na kumzaa mwana,
na utampa jina Yesu.</s></f>"},{ID:62,
Text:"<fArial Black><s1846>Huyo atakuwa mkubwa na kuitwa Mwana wa Aliye Juu,</s></f>"},{ID:63,
Text:"<fArial Black><s1846>na Bwana Mungu atampa kiti cha enzi cha Daudi baba yake,</s></f>"},{ID:64,
Text:"<fArial Black><s1846>ataitawala nyumba ya Yakobo hata milele,
na utawala wake hautakuwa na mwisho.”</s></f>"},{ID:65,
Text:"<fArial Black><s1846>Maria akamwambia malaika,
“Litakuwaje neno hili maana sijui mume?”</s></f>"},{ID:66,
Text:"<fArial Black><s1846>Malaika akamjibu akisema,
“Roho Mtakatifu atakushukia,</s></f>"},{ID:67,
Text:"<fArial Black><s1846>na nguvu ya yule Aliye Juu itakufunika kwa kivuli chake.</s></f>"},{ID:68,
Text:"<fArial Black><s1846>Kwa hiyo kitakatifu kitakachozaliwa kitaitwa Mwana wa Mungu.</s></f>"},{ID:69,
Text:"<fArial Black><s1846>Hata jamaa yako Elizabeti amepata mimba ya mtoto
mwanamume katika uzee wake:</s></f>"},{ID:70,
Text:"<fArial Black><s1846>na huu ni mwezi wake wa sita kwa yeye aliyeitwa tasa;
kwa maana hakuna neno lisilowezekana kwa Mungu.”</s></f>"},{ID:71,
Text:"<fArial Black><s1846>Maria akasema,
Tazama, mimi ni mtumishi wa Bwana, nitendewe ulivyonena.”</s></f>"},{ID:72,
Text:"<fArial Black><s1846>Kisha malaika akamwacha, akaenda zake.</s></f>"},{ID:73,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,
Text:"DOMINIKA YA NNE YA MAJILIO MWAKA B
"}],Guid:"d1MAAliUr0mphUDesuYROQ",
Text:"ADVENT MWAKA B"}