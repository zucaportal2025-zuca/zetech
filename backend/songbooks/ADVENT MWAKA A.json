{Songs:[{Guid:"VsgYm4acX0W7J/A2OUiOhA",Verses:[{Style:{Background:{Image:"nydrlzvzwanr03apkw91gt9bx4f.jpg"}},
Text:"<u><fArial Black><s1846><cFFFFFF66><kFFFF0000>DOMINIKA YA KWANZA YA MAJILIO MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Isaya 2:1-5</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Haya ndiyo aliyoyaona Isaya, mwana wa Amosi,
kuhusu Yuda na Yerusalemu.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Itatukia siku za mwisho ya kuwa
mlima wa hekalu la Bwana</s></f>"},{ID:6,
Text:"<fArial Black><s1846>utawekwa imara juu ya milima,
na kuinuliwa juu kupita vilima.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Mataifa yote watauendea kwa wingi.
Na makabila mengi</s></f>"},{ID:8,
Text:"<fArial Black><s1846>watafika huko, wakisema,
\"Haya, tuupande mlima wa Bwana,</s></f>"},{ID:9,
Text:"<fArial Black><s1846>tuiendee nyumba ya Mungu wa Yakobo,
ili atufundishe njia zake,</s></f>"},{ID:10,
Text:"<fArial Black><s1846>nasi tufuate mapito yake.\"
Maana toka Sioni sheria itatokea,</s></f>"},{ID:11,
Text:"<fArial Black><s1846>na neno la Bwana kutoka Yerusalemu.
Naye atafanya hukumu kati ya mataifa,</s></f>"},{ID:12,
Text:"<fArial Black><s1846>atawaamua makabila mengi.
Nao watafua panga zao ziwe majembe,</s></f>"},{ID:13,
Text:"<fArial Black><s1846>na mikuki yao kuwa mapanga;
taifa halitainua upanga juu ya taifa jingine,</s></f>"},{ID:14,
Text:"<fArial Black><s1846>wala hawatajifunza ufundi wa vita tena.
Enyi watu wa nyumba ya Yakobo, njoni,</s></f>"},{ID:15,
Text:"<fArial Black><s1846>tutembee katika mwanga wa Bwana!</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Zaburi 122: 1-2, 4-5, 6-7, 8-9 </k></c></s></f>"},{ID:18,
Text:"<fArial Black><s1846><kFFFF0000>K.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000> Twende nyumbani kwa Bwana, tukiimba kwa shangwe.</k></c></s></f>"},{ID:19,
Text:"<fArial Black><s1846>1.Nalifurahi waliponiambia,
“Twende nyumbani kwa Bwana.’”</s></f>"},{ID:20,
Text:"<fArial Black><s1846>Sasa miguu yetu imesimama
ndani ya malangoni yako, ee Yerusalemu. K.</s></f>"},{ID:21,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Twende nyumbani kwa Bwana, tukiimba kwa shangwe.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>2.Ndiko wanakopanda makabila,
makabila ya Bwana,</s></f>"},{ID:23,
Text:"<fArial Black><s1846>kama ilivyo sheria ya Israeli,
ya kulitukuza jina la Bwana.</s></f>"},{ID:24,
Text:"<fArial Black><s1846>Humo vimewekwa viti vya hukumu,
viti vya nyumba ya Daudi. K.</s></f>"},{ID:25,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Twende nyumbani kwa Bwana, tukiimba kwa shangwe.</k></c></s></f>"},{ID:26,
Text:"<fArial Black><s1846>3.Uombeeni Yerusalemu amani:
wakupendao wawe salama.</s></f>"},{ID:27,
Text:"<fArial Black><s1846>Amani na iwe ndani ya kuta zako,
baraka kwa nyumba zenu! K.</s></f>"},{ID:28,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Twende nyumbani kwa Bwana, tukiimba kwa shangwe.</k></c></s></f>"},{ID:29,
Text:"<fArial Black><s1846>4.Kwa ajili ya ndugu zangu na rafiki zangu,
nitasema, “Amani kwako.”</s></f>"},{ID:30,
Text:"<fArial Black><s1846>Kwa ajili ya nyumba ya Bwana, Mungu wetu,
nitakuombea upate fanaka. K.</s></f>"},{ID:31,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Twende nyumbani kwa Bwana, tukiimba kwa shangwe.</k></c></s></f>"},{ID:32,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Warumi 13:11-14a</k></c></s></f>"},{ID:33,
Text:"<fArial Black><s1846>Somo katika barua ya Mtakatifu Paulo kwa Warumi</s></f>"},{ID:34,
Text:"<fArial Black><s1846>Ndugu zangu: Mnautambua wakati, saa ya kuamka katika usingizi imefika. </s></f>"},{ID:35,
Text:"<fArial Black><s1846>Kwa maana sasa wokovu wetu u karibu zaidi kuliko wakati tulipoanza kusadiki. </s></f>"},{ID:36,
Text:"<fArial Black><s1846>Usiku umekwisha, mchana umekaribia.
Basi, tuyavue matendo ya giza na tuzivae silaha za mwanga.</s></f>"},{ID:37,
Text:"<fArial Black><s1846>Tuenende kwa adabu kama inavyopasa mchana, si kwa ulafi au ulevi, </s></f>"},{ID:38,
Text:"<fArial Black><s1846>si kwa ufisadi wala uasherati, si kwa ugomvi wala wivu. Bali, mvaeni Bwana Yesu Kristo.</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:40,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Zaburi 85:8</k></c></s></f>"},{ID:41,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:42,
Text:"<fArial Black><s1846>K. Utuonyeshe wema wako,
ee Bwana;utuletee wokovu wako.</s></f>"},{ID:43,
Text:"<fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:44,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Mathayo 24:37-44</k></c></s></f>"},{ID:45,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:46,
Text:"<fArial Black><s1846>Wakati ule: Yesu aliwaambia wafuasi wake,</s></f>"},{ID:47,
Text:"<fArial Black><s1846>“Ujio wa Mwana wa Mtu itakuwa kama ilivyokuwa siku za Nuhu. </s></f>"},{ID:47,
Text:"<fArial Black><s1846>Kwa maana siku zile zilizotangulia gharika kuu, watu
waliendelea kula na kunywa, </s></f>"},{ID:48,
Text:"<fArial Black><s1846>kuoa na kuolewa mpaka siku Nuhu alipoingia katika safina. </s></f>"},{ID:49,
Text:"<fArial Black><s1846>Wasituhumu mambo mabaya hata gharika
kuu ikawaghafilisha na kuwachukua wote.</s></f>"},{ID:50,
Text:"<fArial Black><s1846>Ndivyo kutakavyokuwa pia kuja kwake Mwana wa Mtu. </s></f>"},{ID:51,
Text:"<fArial Black><s1846>Wakati ule watu wawili watakuwako shambani; mmoja atatwaliwa, </s></f>"},{ID:52,
Text:"<fArial Black><s1846>mmoja ataachwa. Wanawake wawili watakuwa katika kusaga; </s></f>"},{ID:53,
Text:"<fArial Black><s1846>mmoja atatwaliwa, mmoja ataachwa.
Kwa hiyo kesheni, </s></f>"},{ID:54,
Text:"<fArial Black><s1846>kwa maana hamjui siku atakayokuja Bwana wenu. </s></f>"},{ID:55,
Text:"<fArial Black><s1846>Basi, fahamuni haya; kama mwenye nyumba angelijua saa ajapo mwizi, </s></f>"},{ID:56,
Text:"<fArial Black><s1846>angelikesha asimpe nafasi ya kuvunja nyumba yake.
Kwa hiyo nanyi muwe tayari, </s></f>"},{ID:57,
Text:"<fArial Black><s1846>kwa kuwa Mwana wa Mtu atakuja
saa msiyoidhania.”</s></f>"},{ID:58,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"nydrlzvzwanr03apkw91gt9bx4f.jpg"}},
Text:"DOMINIKA YA KWANZA YA MAJILIO MWAKA A
"},{Guid:"nMFhj9gWK0i3oy+2y7p3jw",Verses:[{Style:{Background:{Image:"SACRED HEART OF JESUS GAKIRA CATHOLIC KSW 17.jpg",Luminosity:0}}},{ID:2,
Text:"<u><fArial Black><s1846><cFFFFFF66><kFFFF0000>DOMINIKA YA PILI YA MAJILIO MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Isaya 11:1-10</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Siku ile:Chipukizi litatokea katika shina la Yese,
kitawi kitaota katika mizizi yake.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Juu yake itakaa roho ya Bwana,
roho ya hekima na ufahamu,</s></f>"},{ID:6,
Text:"<fArial Black><s1846>roho ya shauri na nguvu,
roho ya elimu na kumcha Bwana.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Na furaha yake itakuwa katika kumcha Bwana.
Hatakata shauri kadiri ya mtazamo,</s></f>"},{ID:8,
Text:"<fArial Black><s1846>bali, atawaamua wanyonge kwa haki kamili,
atawapatia maskini wa nchi hukumu sawa.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Neno lake litakuwa fimbo ya kuipiga nchi,
O pumzi ya midomo yake itamwua mwovu.</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Haki itakuwa ukanda wa viuno vyake,
uaminifu utakuwa ukanda wake wa kujifungia.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Mbwamwitu atakaa pamoja na mwanakondoo,
chui atalala karibu na mwanambuzi;</s></f>"},{ID:12,
Text:"<fArial Black><s1846>ndama na mwanasimba watakuwa pamoja,
mtoto mdogo atawachunga.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Ng'ombe na dubu jike watakula pamoja,
wana wao watalala pamoja;</s></f>"},{ID:14,
Text:"<fArial Black><s1846>simba atakula majani kama ng'ombe.
Mtoto mchanga atacheza penye tundu la nyoka,</s></f>"},{ID:15,
Text:"<fArial Black><s1846>na juu ya shimo la firi mtoto atatia mkono wake.
Uovu hautatendeka tena wala uharibifu,</s></f>"},{ID:16,
Text:"<fArial Black><s1846>juu ya mlima wangu wote mtakatifu;
maana nchi yote itajaa elimu ya Bwana,</s></f>"},{ID:17,
Text:"<fArial Black><s1846>sawa kama maji yanavyojaza bahari.
Itakuwa katika siku hiyo,</s></f>"},{ID:18,
Text:"<fArial Black><s1846>shina la Yese litasimama kama bendera ya mataifa
makabila watalitafuta; kikao chake kitakuwa na utukufu.</s></f>"},{ID:19,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:20,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Zaburí 72:1-2,7 8. 12-13, 17</k></c></s></f>"},{ID:21,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Njoo, Bwana, mfalme wa haki na amani.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>1.Ee Mungu, umpe mfalme hukumu yako,
na mwana wa mfalme haki yako;</s></f>"},{ID:23,
Text:"<fArial Black><s1846>ahukumu taifa lako kwa haki,
na wanyonge kwa usawa. K.</s></f>"},{ID:24,
Text:"<fArial Black><s1846><kFFFF0000>K.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000> Njoo, Bwana, mfalme wa haki na amani.</k></c></s></f>"},{ID:25,
Text:"<fArial Black><s1846>2.Katika siku zake haki iendelee,
na amani izidi mpaka mwezi ukome.</s></f>"},{ID:26,
Text:"<fArial Black><s1846>Atawale toka bahari hata bahari,
na toka mto hata miisho ya dunia. K.</s></f>"},{ID:27,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Njoo, Bwana, mfalme wa haki na amani.</k></c></s></f>"},{ID:28,
Text:"<fArial Black><s1846>3.Maana atamkomboa maskini mwenye kumlilia,
na mnyonge asiye na msaidizi.</s></f>"},{ID:29,
Text:"<fArial Black><s1846>Atamhurumia dhaifu na mhitaji,
ataziokoa nafsi za wahitaji. K.</s></f>"},{ID:30,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Njoo, Bwana, mfalme wa haki na amani.</k></c></s></f>"},{ID:31,
Text:"<fArial Black><s1846>4.Jina lake na lidumu milele;
kumbukumbu yake idumu pindi liangazapo jua.</s></f>"},{ID:32,
Text:"<fArial Black><s1846>Watu wa mataifa yote watabarikiwa katika yeye;
na watamwita mwenye heri. K.</s></f>"},{ID:33,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Njoo, Bwana, mfalme wa haki na amani.</k></c></s></f>"},{ID:34,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Warumi 15:4-9</k></c></s></f>"},{ID:35,
Text:"<fArial Black><s1846>Somo katika barua ya Mtakatifu Paulo kwa Warumi</s></f>"},{ID:36,
Text:"<fArial Black><s1846>Ndugu zangu: Yote yaliyoandikwa ni kwa kutufundisha sisi, </s></f>"},{ID:37,
Text:"<fArial Black><s1846>ili kwa Subira na faraja ya Maandiko hayo tuwe na matumaini.</s></f>"},{ID:38,
Text:"<fArial Black><s1846>Mungu wa subira na wa faraja awajalie kuwa na nia moja mkilingana</s></f>"},{ID:39,
Text:"<fArial Black><s1846>nà nia ya Kristo Yesu, mpate kumtukuza Mungu na Baba wa </s></f>"},{ID:40,
Text:"<fArial Black><s1846>Bwana wetu Yesu Kristo kwa moyo mmoja na kwa ulimi mmoja.</s></f>"},{ID:41,
Text:"<fArial Black><s1846>Kwa hiyo mpokeane kama Kristo alivyowapokea ninyi kwa kumheshimu Mungu. </s></f>"},{ID:42,
Text:"<fArial Black><s1846>Nasema hivi: kwa ajili ya ukweli wa Mungu,
Kristo amekuwa mtumishi wa tohara, </s></f>"},{ID:43,
Text:"<fArial Black><s1846>ili atekeleze ahadi walizopewa mababu. </s></f>"},{ID:44,
Text:"<fArial Black><s1846>Bali watu wa mataifa wamtukuze Mungu kwa sababu ya huruma yake kama ilivyoandikwa: </s></f>"},{ID:45,
Text:"<fArial Black><s1846>“Kwa hiyo nitakusifu, ee Bwana.
kati ya mataifa nitaliimbia jina lako,”</s></f>"},{ID:46,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:47,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Luka 3:4, 6</k></c></s></f>"},{ID:48,
Text:"<fArial Black><s1846><kFFFF0000>K. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:49,
Text:"<fArial Black><s1846>K. Itengenezeni njia ya Bwana,
yanyosheni mapito yake,</s></f>"},{ID:50,
Text:"<fArial Black><s1846>na kila kiumbe kitauona wokovu wa Mungu.
“Tubuni, kwa maana ufalme wa mbingu umekaribia.”</s></f>"},{ID:51,
Text:"<fArial Black><s1846><kFFFF0000>W. </k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aleluya.</k></c></s></f>"},{ID:52,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Mathayo 3:1-12</k></c></s></f>"},{ID:53,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Siku zile Yohane Mbatizaji alitokea.
Akahubiri katika nyika ya Yudea akisema,</s></f>"},{ID:55,
Text:"<fArial Black><s1846>“Tubuni, kwa maana ufalme wa mbingu umekaribia.”
“Sauti ya mtu aliaye nyikani,</s></f>"},{ID:56,
Text:"<fArial Black><s1846>‘Mtayarishieni Bwana njia,
yanyosheni mapito yake.</s></f>"},{ID:57,
Text:"<fArial Black><s1846>Huyo ndiye aliyeaguliwa na nabii Isaya kwa maneno haya:</s></f>"},{ID:58,
Text:"<fArial Black><s1846>Yohane alivaa singa za ngamia na ukanda wa ngozi kiunoni mwake.</s></f>"},{ID:59,
Text:"<fArial Black><s1846>Chakula chake kilikuwa nzige na asali ya porini.</s></f>"},{ID:60,
Text:"<fArial Black><s1846>Hapo watu wa Yerusalemu, Yudea yote, nchi zote za jirani na Yordani</s></f>"},{ID:61,
Text:"<fArial Black><s1846>walimwendea. Wakabatizwa naye katika Mto Yordani wakiungama dhambi zao.</s></f>"},{ID:62,
Text:"<fArial Black><s1846>Lakini alipoona Mafarisayo na Masadukayo wengi wanaujia ubatizo wake, aliwauliza,</s></f>"},{ID:63,Style:{Background:{Image:"SACRED HEART OF JESUS GAKIRA CATHOLIC KSW 17.jpg",Luminosity:0}},
Text:"<fArial Black><s1846>\"Enyi kizazi cha nyoka, nani amewaonya kujiepusha na hukumu ya hasira inayokuja? </s></f>"},{ID:64,
Text:"<fArial Black><s1846>Sasa zaeni matunda yafaayo kwa kutubu.
Msifikiri mioyoni mkijiambia, </s></f>"},{ID:65,
Text:"<fArial Black><s1846>Tunaye Abrahamu, ndiye baba
yetu. </s></f>"},{ID:66,
Text:"<fArial Black><s1846>Nawaambieni, Mungu aweza kutumia mawe haya kumfanyia Abrahamu watoto. </s></f>"},{ID:67,
Text:"<fArial Black><s1846>Shoka limekwisha kuwekwa kwenye mzizi wa
miti. </s></f>"},{ID:68,
Text:"<fArial Black><s1846>Kila mti usiozaa matunda mema utakatwa na kutupwa motoni.</s></f>"},{ID:69,
Text:"<fArial Black><s1846>Mimi nawabatiza kwa maji kwa ajili ya toba, lakini anayekuja</s></f>"},{ID:70,
Text:"<fArial Black><s1846>nyuma yangu ana nguvu kubwa zaidi kuliko mimi.</s></f>"},{ID:71,
Text:"<fArial Black><s1846>Sistahili mimi kumbebea viatu.</s></f>"},{ID:72,
Text:"<fArial Black><s1846>Yeye atawabatiza kwa Roho Mtakatifu na kwa mnoto. </s></f>"},{ID:73,
Text:"<fArial Black><s1846>Ana pepeo mkononi asafishe uwanda wake: </s></f>"},{ID:74,
Text:"<fArial Black><s1846>ngano yake ataiweka ghalani,</s></f>"},{ID:75,
Text:"<fArial Black><s1846>bali makapi atayateketeza kwa moto usiozimika.\"</s></f>"},{ID:76,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"},{ID:63,
Text:"<fArial Black><s1846>.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"nydrlzvzwanr03apkw91gt9bx4f.jpg"}},
Text:"DOMINIKA YA PILI YA MAJILIO MWAKA A"},{Guid:"hGc0wP5LI0CZ1/VqPzm7NA",Verses:[{Style:{Background:{Image:"DOMINIKA YA TATU.jpg",Luminosity:0}}},{ID:2,
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF3F3F>DOMINIKA YA TATU YA MAJILIO MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaya 35:1 -6a.10</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Jangwa na pori vitafurahi;
nyika itashangilia na kuchanua majani;</s></f>"},{ID:5,
Text:"<fArial Black><s1846>itatoa maua mengi kama yasmini, itaimba,
na itashangilia kwa furaha.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Itapewa uzuri wa Lebanoni,
utukufu wa Karmeli na wa Sharoni;</s></f>"},{ID:7,Style:{Background:{Luminosity:-45}},
Text:"<fArial Black><s1846>utukufu wa Bwana utaonekana, ukuu wa Mungu wetu.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Itieni nguvu mikono iliyo dhaifu,
fanyeni imara magoti yaliyolegea.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Wale waliovunjika moyo, waambieni:
mjipe moyo, msiogope!</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Tazameni, Mungu wenu yupo hapa atalipiza kisasi;
adhabu itakuja kutoka kwa Mungu,</s></f>"},{ID:11,
Text:"<fArial Black><s1846>naye atakuja kuwaokoa ninyi.
Ndipo macho ya vipofu yatafumbuliwa,</s></f>"},{ID:12,
Text:"<fArial Black><s1846>masikio ya viziwi yatafunguliwa;
ndipo kiwete atarukaruka kama swala,</s></f>"},{ID:13,
Text:"<fArial Black><s1846>na ulimi wa bubu utaimba kwa furaha.
Nao waliokombolewa na Bwana watarudi,</s></f>"},{ID:14,
Text:"<fArial Black><s1846>watafika Sioni wakishangilia.
Furaha ya milele itapamba vichwa vyao;</s></f>"},{ID:15,
Text:"<fArial Black><s1846>nao watafanya sherehe na shangwe, huzuni na kilio vitakimbia.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA 
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Zaburi l46:6c-7, 8-9a, 9bc 10</k></c></s></f>"},{ID:18,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Njoo, Bwana, utuokoe.</k></c></s></f>"},{ID:19,
Text:"<fArial Black><s1846>Ni Bwana ashikaye uaminifu hata milele.
Huwarudishia haki waliodhulumiwa,</s></f>"},{ID:20,
Text:"<fArial Black><s1846>huwapa wenye njaa chakula.
Bwana huwafungua wafungwa. K.</s></f>"},{ID:21,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Njoo, Bwana, utuokoe.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>Bwana huyafumbua macho ya vipofu.
Bwana huwainua waliokandamizwa;</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Bwana huwapenda wenye haki.
Bwana huwalinda wageni. K.</s></f>"},{ID:24,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Njoo, Bwana, utuokoe.</k></c></s></f>"},{ID:25,
Text:"<fArial Black><s1846>Huwategemeza yatima na mjane,
bali huipotosha njia ya waovu.</s></f>"},{ID:26,
Text:"<fArial Black><s1846>Bwana atatawala milele,
Mungu wako, ee Sioni, kizazi hata kizazi! K.</s></f>"},{ID:27,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Njoo, Bwana, utuokoe.</k></c></s></f>"},{ID:28,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Yakobo 5:7-10</k></c></s></f>"},{ID:29,
Text:"<fArial Black><s1846>Somo katika barua ya Mtakatifu Yakobo</s></f>"},{ID:30,
Text:"<fArial Black><s1846>Ndugu, muwe na subira mpaka Bwana atakapokuja.</s></f>"},{ID:31,
Text:"<fArial Black><s1846>Hata mkulima anangojea mazao mazuri ya ulimwengu. </s></f>"},{ID:32,
Text:"<fArial Black><s1846>Anangojea kwa subira mvua
ya vuli na masika.</s></f>"},{ID:33,
Text:"<fArial Black><s1846>Nanyi pia mnapaswa kuwa na subira na kuimarisha mioyo yenu, </s></f>"},{ID:34,
Text:"<fArial Black><s1846>kwani ujio wa Bwana umekaribia.
Ndugu, msinung’unikiane,</s></f>"},{ID:35,
Text:"<fArial Black><s1846> msije mkahukumiwa. Tazameni, hakimu
amesimama mbele ya mlango. </s></f>"},{ID:36,
Text:"<fArial Black><s1846>Ndugu, manabii waliosema kwa jina la
Bwana wawe mfano wenu katika kuvumilia mateso.</s></f>"},{ID:37,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:38,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaya 61:1</k></c></s></f>"},{ID:39,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f><fArial Black><s1846><kFFFF3F3F> 
W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f>"},{ID:40,
Text:"<fArial Black><s1846>K. Roho wa Bwana yu juu yangu,
henituma niwahubirie maskini habari njema.</s></f>"},{ID:41,
Text:"<fArial Black><s1846><kFFFF3F3F>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f>"},{ID:42,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mathayo 11:2-11</k></c></s></f>"},{ID:43,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Siku zile:
Yohane aliposikia gerezani matendo ya Kristo,</s></f>"},{ID:45,
Text:"<fArial Black><s1846>aliwatuma wanafunzi wake wamwulize swali hili,</s></f>"},{ID:46,
Text:"<fArial Black><s1846>“Je, ni wewe atakayekuja, au tumtazamie mwingine?”
Yesu akajibu akawaambia, </s></f>"},{ID:47,
Text:"<fArial Black><s1846>“Nendeni mkamweleze Yohane habari za
mambo mnayosikia na kuyaona: </s></f>"},{ID:48,
Text:"<fArial Black><s1846>vipofu wanaona, viwete wanatembea,
wenye ukoma wanatakata, viziwi wanasikia, </s></f>"},{ID:49,
Text:"<fArial Black><s1846>wafu wanafufuka, na maskini wanahubiriwa habari njema.</s></f>"},{ID:50,
Text:"<fArial Black><s1846>Heri mtu yule asiyekwazwa nami.”
Baada ya kuondoka hao, </s></f>"},{ID:51,
Text:"<fArial Black><s1846>Yesu alianza kuzungumza na watu juu ya
Yohane,</s></f>"},{ID:52,
Text:"<fArial Black><s1846>“Mlikwenda nyikani kuona nini? Tete likitikiswa na upepo?</s></f>"},{ID:53,
Text:"<fArial Black><s1846>Basi, mlikwenda huko kuona nini?
Mtu aliyevaa mavazi maridadi?</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Watu wavaao mavazi maridadi wamo katika majumba ya wafalme.</s></f>"},{ID:55,
Text:"<fArial Black><s1846>Basi, mlikwenda huko kwa nini? Je, kwa kuona nabii?</s></f>"},{ID:56,
Text:"<fArial Black><s1846>Ndiyo, nawaambieni, hata zaidi ya nabi.
Huyo ndiye aliyeandikiwa:</s></f>"},{ID:57,
Text:"<fArial Black><s1846>Tazama, ninamtuma mjumbe wangu,
akutangulie na kukutengenezea njia.’</s></f>"},{ID:58,
Text:"<fArial Black><s1846>Amin, nawaambieni, katika wote waliozaliwa na mwanamke hajapata</s></f>"},{ID:59,
Text:"<fArial Black><s1846>kutokea mtu aliye mkubwa kuliko Yohane Mbatizaji. Lakini katika</s></f>"},{ID:60,
Text:"<fArial Black><s1846>ufalme wa mbingu, mdogo wa mwisho ni mkubwa kuliko yeye.”</s></f>"},{ID:61,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"},{ID:62,Style:{Background:{Image:"DOMINIKA YA TATU.jpg",Luminosity:0}},
Text:"<fArial><s846>.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"images (2) - Copy.jpg"}},
Text:"DOMINIKA YA TATU YA MAJILIO MWAKA A
"},{Guid:"VPhJWCEJ/kSygMSr6Wwvhg",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF3F3F>DOMINIKA YA NNE YA MAJILIO MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846><kFFFF3F3F>SOMO LA KWANZA
</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaya 7:10-14</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>Somo katika kitabu cha Nabii Isaya</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Siku zile: Bwana alimwambia Ahazi maneno haya:
\"Ujiombee ishara kwa Bwana Mungu wako;</s></f>"},{ID:5,
Text:"<fArial Black><s1846>iwe ni kutoka chini kuzimu au juu mbinguni!\"
Ahazi akajibu,</s></f>"},{ID:6,
Text:"<fArial Black><s1846>\"Sitaomba! Wala sitamjaribu Bwana!\"
Hapo BwANA akamwambia:</s></f>"},{ID:7,
Text:"<fArial Black><s1846>\"Sikilizeni sasa, enyi nyumba ya Daudi!
Haiwatoshi kuwachokoza watu!</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Hata na mtake kumjaribu Mungu wangu pia?
Kwa hiyo Bwana Mwenyewe atawapa ninyi ishara:</s></f>"},{ID:9,
Text:"<fArial Black><s1846>tazameni, bikira atapata mimba, atamzaa mwana,
jina lake atamwita Immanueli.\"</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Zaburi 24:1-2, 3-4ab, 5-6 </k></c></s></f>"},{ID:12,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Bwana apate kuingia;
yeye ni mfalme wa utukufu.</k></c></s></f>"},{ID:13,
Text:"<fArial Black><s1846>1.Nchi ni yake Bwana na vyote vinavyoijaza,
dunia yote na wakaaji waliomo.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Maana Mungu ameweka misingi yake juu ya bahari,
ameisimika juu ya mito ya maji. K.</s></f>"},{ID:15,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Bwana apate kuingia;
yeye ni mfalme wa utukufu</k></c></s></f>"},{ID:16,
Text:"<fArial Black><s1846>2.Ni nani atakayepanda mlima wa Bwana?
Ni nani atakayesimama mahali pake patakatifu?</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Mtu aliye na mikono safi na moyo mweupe,
asiyeuinua moyo wake kwa mambo ya miungu. K.</s></f>"},{ID:18,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Bwana apate kuingia;
yeye ni mfalme wa utukufu</k></c></s></f>"},{ID:19,
Text:"<fArial Black><s1846>3.Huyo atapata baraka kwa Bwana,
na tuzo ya Mungu Mwokozi wake.</s></f>"},{ID:20,
Text:"<fArial Black><s1846>Hiki ni kizazi cha wenye kumtafuta,
cha wenye kutafuta uso wako, ee Mungu wa Yakobo. K.</s></f>"},{ID:21,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Bwana apate kuingia;
yeye ni mfalme wa utukufu.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>SOMO LA PILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mathayo 1:23</k></c></s></f>"},{ID:23,
Text:"<fArial Black><s1846>Somo katika barua ya Mtakatifu Paulo kwa Warumi</s></f>"},{ID:24,
Text:"<fArial Black><s1846>Mimi Paulo, mtumishi wa Kristo Yesu, mtume kwa wito wake,</s></f>"},{ID:25,
Text:"<fArial Black><s1846>nimechaguliwa kuihubiri Injili ya Bwana.</s></f>"},{ID:26,
Text:"<fArial Black><s1846>Mungu ameitangaza zamani kwa ujumbe wa manabii wake katika Maandiko Matakatifu. </s></f>"},{ID:27,
Text:"<fArial Black><s1846>Hii ndiyo Injili inayohusu Mwanaye
aliyezaliwa katika ukoo wa Daudi mintarafu mwili.</s></f>"},{ID:28,
Text:"<fArial Black><s1846>lakini Mwana wa Mungu mintarafu roho ya utakatifu, ndiye Yesu Kristo,</s></f>"},{ID:29,
Text:"<fArial Black><s1846>Bwana wetu aliyewekwa katika mamlaka yake kwa ufufuko katika wafu.</s></f>"},{ID:30,
Text:"<fArial Black><s1846>Kwake tumepata neema na utume wa kuyahubiria mataifa yote utii wa imani kwa kuheshimu jina lake.</s></f>"},{ID:31,
Text:"<fArial Black><s1846> Nanyi ni moja ya mataifa hayo,
kwa kuwa mmeitwa na Yesu Kristo.</s></f>"},{ID:32,
Text:"<fArial Black><s1846>Basi, salamu zangu kwenu nyote mkaao Roma, wapendwa wa Mungu, </s></f>"},{ID:33,
Text:"<fArial Black><s1846>mlioitwa kuwa watakatifu. Neema na amani zitokazo kwa Mungu, </s></f>"},{ID:34,
Text:"<fArial Black><s1846>Baba yetu, na kwa Bwana Yesu Kristo ziwe nanyi.</s></f>"},{ID:35,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:36,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Warumi 1:1-7</k></c></s></f>"},{ID:37,
Text:"<fArial Black><s1846><kFFFF3F3F>K. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.
</k></c></s></f><fArial Black><s1846><kFFFF3F3F>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f>"},{ID:38,
Text:"<fArial Black><s1846>K. Tazama, bikira atachukua mimba
na kumzaa mwana, naye watamwita </s></f>"},{ID:39,
Text:"<fArial Black><s1846>“Emanueli,”
maana yake, “Mungu pamoja nasi.”</s></f>"},{ID:40,
Text:"<fArial Black><s1846><kFFFF3F3F>W. </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aleluya.</k></c></s></f>"},{ID:41,
Text:"<fArial Black><s1846>INJILI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mathayo 1:18-24</k></c></s></f>"},{ID:41,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Mathayo</s></f>"},{ID:42,
Text:"<fArial Black><s1846>Kuzaliwa kwa Yesu Kristo kulikuwa hivi.
Maria, mama yake, alipokuwa ameposwa na Yosefu,</s></f>"},{ID:43,
Text:"<fArial Black><s1846>kabla hawajakaa pamoja
alionekana ana mimba kwa uwezo wa Roho Mtakatifu.</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Mumewe Yosefu akiwa mntu mwadilifu,
hakupenda kumwaibisha hadharani.</s></f>"},{ID:45,
Text:"<fArial Black><s1846>Basi, akanuia kumwacha kwa siri.
Alipokuwa akifikiria hayo, tazama, malaika wa Bwana</s></f>"},{ID:46,
Text:"<fArial Black><s1846>alimtokea ghafla katika ndoto, akasema,</s></f>"},{ID:47,
Text:"<fArial Black><s1846>“Yosefu, mwana wa Daudi, usiogope kumpokea Maria kuwa mke wako, </s></f>"},{ID:48,
Text:"<fArial Black><s1846>maana mimba yake ameipata kwa uwezo wa Roho Mtakatifu.</s></f>"},{ID:49,
Text:"<fArial Black><s1846>Atamzaa mwana, nawe utampa jina lake “Yesu”. Maana yeye</s></f>"},{ID:50,
Text:"<fArial Black><s1846>atawaokoa watu wake katika dhambi zao.”
Hayo yote yametendeka, </s></f>"},{ID:51,
Text:"<fArial Black><s1846>ili neno alilonena Bwana kwa njia ya nabii litimie, kwamba:</s></f>"},{ID:52,
Text:"<fArial Black><s1846>Tazama, bikira atachukua mimba na kumzaa mwana,
naye watamwita Emanueli,’</s></f>"},{ID:53,
Text:"<fArial Black><s1846>maana yake, “Mungu pamoja nasi.”
Yosefu alipoamka kutoka usingizini,</s></f>"},{ID:54,
Text:"<fArial Black><s1846>alifanya kama malaika wa Bwana alivyomwagiza,
akampokea mkewe nyumbani kwake.</s></f>"},{ID:55,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"images (2).jpg",Luminosity:-45}},
Text:"DOMINIKA YA NNE YA MAJILIO MWAKA A
"},{Reference:"GUTHOMA",Guid:"0swgppxP2EGVBwMK+EGXQA",Verses:[{Style:{Background:{Image:"kiuuumiiiia.jpg"}},
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF0000>KIUMIA KIA MBERE KIA RIUKIRO MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GITHOMO KIA MBERE
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Isaia 2: 1 -5</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>GUTHOMA KUUMA MÜRATHI ISAIA :</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Uyū nīguo ūhoro ūrīa Isaia, mūrũ wa Amozu, onire ükonií Juda na Jerusalemu.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Ní gūgakinya atīrī, atī matukū ma kūrigīrīria, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>kīrīma kīrīa nyūmba ya Mwathani yakītwo nĩ gīgatūűgīrio na igūrū, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>gīkīrūke tūcũmbĩrī twa irīma iria ingī, na gītūűgīrio gīkīrūke ithūngūri iria ingī:</s></f>"},{ID:8,
Text:"<fArial Black><s1846>nacio ndūriri ciothe nīikuo ikomokagīra. Na irīndī nyingī nĩ igathiï kuo ikiugaga üũ:</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Ukai twambate kīrīma-inī kīa Mwathani, tūthiï nyűmba ya Ngai wa Jakobu, atūrute mīthiīre yake, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>na ithuĩ tūthiage na njīra ciake; nĩ gükorūo Sion nĩ gūkoima ūtaarani, </s></f>"},{ID:11,
Text:"<fArial Black><s1846>o naguo ūhoro wa Mwathani ūhunje uumīte Jerusalemu. </s></f>"},{ID:12,
Text:"<fArial Black><s1846>Nake nĩ agatuithanagia ndūrīrī macira, na arüithie irīindī nyingi ;</s></f>"},{ID:13,
Text:"<fArial Black><s1846>nacio icoke gütura hiű ciacio cia njora ituīke hiũ cia mĩraũ, </s></f>"},{ID:14,
Text:"<fArial Black><s1846>o namo matimū ma cio matuīke hiü cia gūceha mītī. </s></f>"},{ID:15,
Text:"<fArial Black><s1846>Hĩndī ío gűtirī rürĩrī rügacoka gücomorera rürīrĩ rürīa rüngī rühi</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846> rũa njora, </s></f>"},{ID:16,
Text:"<fArial Black><s1846>ona kana nd</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>rīrī icoke kwiigithia mbaara rīngī o na rī. Atirirī, inyuí? </s></f>"},{ID:17,
Text:"<fArial Black><s1846>andũ a nyümba ya Jakobu, ükai tūthiage tümürīkīirūo nĩ ūtheri wa Mwathani.</s></f>"},{ID:18,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani,</s></f>"},{ID:19,
Text:"<fArial Black><s1846>THABURI YA GÜCOKERUO.
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Thaburi 122: 1-2: 3-4a; 6-7; 8-9</k></c></s></f>"},{ID:20,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Nĩ tūthií nyūmba-inī ya Mwathani na gīkeno.</k></c></s></f>"},{ID:21,
Text:"<fArial Black><s1846>1.Nigūkena ndirakenire maanjīra tūthii nyūmba-inī ya Mwathani. </s></f>"},{ID:22,
Text:"<fArial Black><s1846>Magūrū maitū riu nīkuo marūngii, ihingo cialku na thiini, wee Jerusalemu.</s></f>"},{ID:23,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Nĩ tūthií nyūmba-inī ya Mwathani na gīkeno.</k></c></s></f>"},{ID:24,
Text:"<fArial Black><s1846>2.Jerusalemu, o wee wakitwo ta gitūūro gītumaine o wega. </s></f>"},{ID:25,
Text:"<fArial Black><s1846>Nīkuo mīhirīga īthiaga îkīambatagirira,
mīhiriga o io ya Mwathani: nĩ ūira harī Israeli.</s></f>"},{ID:26,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Nĩ tūthií nyūmba-inī ya Mwathani na gīkeno.</k></c></s></f>"},{ID:27,
Text:"<fArial Black><s1846>3. Kíīhoerei Jerusalemu thayū; arīa wee makwende te-ri, marotūüra magacirūo. </s></f>"},{ID:28,
Text:"<fArial Black><s1846>Gwaku o üguo küi rigītwo kūroikara o thayū, thiinī wa </s></f>"},{ID:29,
Text:"<fArial Black><s1846>nyūmba ciaku cia ūnene kūrotūūra gwī kūhoro</s></f>"},{ID:29,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Nĩ tūthií nyūmba-inī ya Mwathani na gīkeno.</k></c></s></f>"},{ID:30,
Text:"<fArial Black><s1846>4.Tondū wa andū aitū, o na arata arīa tūikaranagia nao, ngūkiuga atīrīrĩ: </s></f>"},{ID:31,
Text:"<fArial Black><s1846>Thiini waku kūrotūūra o na thayū ! Tondū wa nyūmba wa </s></f>"},{ID:32,
Text:"<fArial Black><s1846>Mwathani Ngai wit-rī, ndigūcaragīria o maūndū ma wega.</s></f>"},{ID:33,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Nĩ tūthií nyūmba-inī ya Mwathani na gīkeno.</k></c></s></f>"},{ID:34,
Text:"<fArial Black><s1846>GÍTHOMO KÍA IGİRÍ
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Aroma 13: 11 - 14</k></c></s></f>"},{ID:35,
Text:"<fArial Black><s1846>GŨTHOMA MARŪA MA MÜTHURE PAUL KŪRĪ ANDŪ A ROMA :</s></f>"},{ID:36,
Text:"<fArial Black><s1846>Aruna aitũ, mũnyite ühoro ūcio nĩ kümenya ürīa hĩndĩ ino türi ítariï, </s></f>"},{ID:37,
Text:"<fArial Black><s1846>atī rīu thaa nĩ nginyu mūgurumūke toro,</s></f>"},{ID:38,
Text:"<fArial Black><s1846>nĩ gükorūo rīu ūhoro witũ wa kühonokio ürī hakuhī kürī riria twaambīrīirie gwītikia.</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Utukü niĩ ta ūthirīte, naguo mūthenya ní űkirií gūkinya: </s></f>"},{ID:40,
Text:"<fArial Black><s1846>nĩ tügīteaniei maūndū marīa mekagwo nduma-inī,</s></f>"},{ID:41,
Text:"<fArial Black><s1846>twīohe indo-cia-ita iria cia ütheri. Nĩ tūthiage na mīthiíre mīega, </s></f>"},{ID:42,
Text:"<fArial Black><s1846>ta írīa yagiřiire güikarūo nayo mūthenya; </s></f>"},{ID:43,
Text:"<fArial Black><s1846>tūtigagītuike a gũikaraga maruga-inî marīa mainagīrüo nyîmbo itagīrüre, kana tũrī arīu,</s></f>"},{ID:44,
Text:"<fArial Black><s1846>na tūtigatuike arümīrīri ühoro wa gükomania, o na kana wa u</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>ra-thoni, </s></f>"},{ID:45,
Text:"<fArial Black><s1846>kana tūgĩage na njūgitano, o na kana tūiguanagĩre üiru, </s></f>"},{ID:46,
Text:"<fArial Black><s1846>No rĩrī, wihumbei Mwathani Yesu Kristū, na mūtigatūüre </s></f>"},{ID:47,
Text:"<fArial Black><s1846>mūhaaragīria ūhoro wa mwirī, nīguo mūhünagie merirīria maguo.</s></f>"},{ID:48,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:49,
Text:"<fArial Black><s1846>RŪĪMBO RŪA ALLELUYA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Thaburi 85, 7</k></c></s></f>"},{ID:50,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya, Alleluya. </k></c></s></f>"},{ID:51,
Text:"<fArial Black><s1846>Tüonie ūtugi waku, Mwathani, ügītwītīkīrie ühonokio waku, </s></f>"},{ID:52,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF0000>Alleluya.</k></c></s></f>"},{ID:53,
Text:"<fArial Black><s1846>GITHOMO KIA INJIRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF0000>Mathayo 24: 37- 44</k></c></s></f>"},{ID:54,
Text:"<fArial Black><s1846>GīCUNJĨ KĪA INJIRI THERU TA ŪRĪA YANDĪKĪTWO NĪ MŪTHURE MA THAYO:</s></f>"},{ID:55,
Text:"<fArial Black><s1846>Hĩndī īyo Yesu akīīra arūmīrīri ake: Na ta ürĩa gwatariī matukū ma Nuhu, </s></f>"},{ID:56,
Text:"<fArial Black><s1846>no taguo güüka kwa Múrũ wa mũndü gūkahaana. Nĩ gükorüo, </s></f>"},{ID:57,
Text:"<fArial Black><s1846>o ta ūria gwatarit matukū marīa maarī mbere ya kīguũ kīria kīnene, </s></f>"},{ID:58,
Text:"<fArial Black><s1846>o rîrĩa andū maarīaga, na maanyuaga, na maagūranaga, </s></f>"},{ID:59,
Text:"<fArial Black><s1846>na mendagia airītu ao, o nginya müthenya ürīa Nuhu aatonyire ngarawa-inī, </s></f>"},{ID:60,
Text:"<fArial Black><s1846>nao matiamenyire kinya rīrīa kīguū kīu kīnene gīokire gikimatwara othe-rī; </s></f>"},{ID:61,
Text:"<fArial Black><s1846>o üguo noguo güüka kwa Mūrũ wa mūndū gükahaana. </s></f>"},{ID:62,
Text:"<fArial Black><s1846>Hīndī io arūme erī magakorūo mūgũnda; ümwe nĩ agatwarűo, na ūrīa üngī atigwo: </s></f>"},{ID:63,
Text:"<fArial Black><s1846>atumia erī magakorūo magīthĩa gīthi-inī; ümwe nĩ agatwarūo, </s></f>"},{ID:64,
Text:"<fArial Black><s1846>na ürīa üngī atigwo. Nĩ ündū ücio wihügagei, nĩ gükorūo </s></f>"},{ID:65,
Text:"<fArial Black><s1846>mūtiu mũthenya ürīa Mwathani wanyu agoka. </s></f>"},{ID:65,
Text:"<fArial Black><s1846>Índĩ menyai üũ, at</s></f><fSegoe UI Black><s1846>ỉ</s></f><fArial Black><s1846> mwene mūcií angīamenyete thaa </s></f>"},{ID:66,
Text:"<fArial Black><s1846>irīia müici egüüka, nīĩ angīakorirüo eiguīte, </s></f>"},{ID:66,
Text:"<fArial Black><s1846>na ndangīarekire nyūmba yake yenjwo. </s></f>"},{ID:67,
Text:"<fArial Black><s1846>Ní ündū ücio o na inyu ikaragai mwihaaríirie: </s></f>"},{ID:67,
Text:"<fArial Black><s1846>nĩ gükorűo Műrű wa mũndű nĩ agoka thaa īrīĩa mūtegereirie.</s></f>"},{ID:68,
Text:"<fArial Black><s1846>Injiri theru ya Mwathani.</s></f>"},{ID:69,Style:{Background:{Image:"kimmm 2.jpg",Luminosity:5}},
Text:"<fArial Black><s1846>      </s></f>"}],VideoDuration:0,Style:{Background:{Image:"WhatsApp Image 2025-10-04 at 07.57.08_dd6cdcec.jpg",Luminosity:-5}},
Text:"KIUMIA KIA MBERE KIA RIUKIRO MWAKA A"},{Guid:"EVFNd3MpR06TMKqbDpBZfw",Verses:[{Style:{Background:{Image:"SACRED HEART OF JESUS GAKIRA CATHOLIC   SUNDAY 17.jpg",Luminosity:0}}},{ID:2,Style:{Background:{Image:"SACRED HEART OF JESUS GAKIRA CATHOLIC   SUNDAY 17.jpg",Luminosity:0}},
Text:"<u><fArial Black><s1846><cFFFFFF66><kFFFF0000>KIUMIA GIA KERI KIA RIUKIRO MWAKA A  </k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GĪTHOMO KIA MBERE
</s></f><b><i><fAlgerian><s1846><cFFFFFF66><kFFFF0000>(Isaia 11:1-10)</k></c></s></f></i></b>"},{ID:3,
Text:"<fArial Black><s1846>GÜTHOMA KUUMA MURATHI ISAIA :</s></f>"},{ID:4,Style:{Background:{BodyRect:"0,0,10000,9300"}},
Text:"<fArial Black><s1846>Müthenya ücio, kïruka-inï kïa Jesse nï hakoima mündü, ta arï we thuuna.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>ïcomokete mütï-inï, na rü-honge rüu rükoima mïri-inï yake nï rügaciara.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Muoyo wa Mwathani nï ügaikara ümühubïte, o muoyo wa üügï na wa ümenyi maündü.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Muoyo wa ütaarani na hinya, na nïguo muoyo wa küühïgania, na gwïtigïrithia Mwathani.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>O namo maündü marïa makamükenagia makoimana na gwïtigïra Mwathani, ningï ndagatuaga.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Cira na gïthiithi, o na kana arüithanie na ündü wa küigua njukü, no rïrï athïni.</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Akamatuagïra cira na üthingu, nao arïa ahoreri a gükü thï amarüïrïre na kïhooto.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Rïrï andü a thï arïa ahinyanïrïria akamahüra na rüthanju rüa kanua gake.</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Nao arïa aaganu amorage na mïhümu ya mïromo yake, üthingu nïguo ügatuïka mwïhotoro wake.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>O naguo wïhokeki ütüïke mücïbi wa njohero yake, njüi ïgatüüranagia na kagondu.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Ngarï ïkomanagie na kori, ningï gacaü ka ng'ombe o na ka mürüthi, o na kanyamü ga gïcegü.</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Tuikaranagie hamwe, na rïrï tügatongoragio nï kaana kanini, ng'ombe na nduba ikarïaga.</s></f>"},{ID:16,
Text:"<fArial Black><s1846>Hamwe na tücaü twacio tükomanagie, ningï mürüthi ükarïaga nyeki o ta ndegwa.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Kaana gekuonga-rï, gagathaakagïra irima-inï rïa nduïra, o nako kaana karïa gatuïte.</s></f>"},{ID:18,
Text:"<fArial Black><s1846>Iria gaikagie guoko gwako irima-inï rïa gïïko, gütikageranwo ngero, kana kündinanwo.</s></f>"},{ID:19,
Text:"<fArial Black><s1846>Küü kïrïma-inï gïakwa kïrïa gïtheru guothe, nï gükorüo thï yothe nï ïkaiyürüo.</s></f>"},{ID:20,Style:{Background:{BodyRect:"0,0,10000,9300"}},
Text:"<fArial Black><s1846>Ühoro wa kümenya Mwathani o ta ürïa maaï maiyürïte iria-inï, na nïgügakinya atïrï.</s></f>"},{ID:21,
Text:"<fArial Black><s1846>Müthenya ücio, atï mündü ücio ükoima mïri-inï ya Jesse, o we ürïa ükarügama atuike.</s></f>"},{ID:22,
Text:"<fArial Black><s1846>Ta kïbebero harï ndürïrï, nïwe ükarongoragio nï ndürïrï icio; naguo ütüüro wake wonagwo ürï riri.</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Icio nicio ciugo cia Mwathani.</s></f>"},{ID:24,
Text:"<fArial Black><s1846>THABURl YA GUCOKERUO
</s></f><b><i><fAlgerian><s1846><cFFFFFF66><kFFFF0000>(Thaburi 72: 1-2; 7-8; 12-13; 17)</k></c></s></f></i></b>"},{ID:25,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Uka Wee Mwathani Muthamaki
wa waragania na ruendo.</k></c></s></f>"},{ID:26,
Text:"<fArial Black><s1846>1 Ï Ngai he müthamaki mïtuïre yaku, o we
müriü wa müthamaki-rï ükïmühe üthingu waku.</s></f>"},{ID:27,
Text:"<fArial Black><s1846>Nake no aciragïre kïrïndï gïaku na
mïcirïre ya üthingu, agïtuagïra athïnïki aku
matua ma kïhooto.</s></f>"},{ID:28,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Uka Wee Mwathani Muthamaki
wa waragania na ruendo</k></c></s></f><fArial Black><s1846><kFFFF0000>.</k></s></f>"},{ID:29,
Text:"<fArial Black><s1846>2 Matukü make ürïa müthingu nï kühamba
arïhambaga, na gütüüre na thayü müingï,</s></f>"},{ID:30,
Text:"<fArial Black><s1846>nginya o hingo mweri ükarindüka. Nï agïe na
watho </s></f>"},{ID:31,
Text:"<fArial Black><s1846>kuuma iria-inï rïmwe o nginya rïrïa rïngï, na
kuuma Rüüï-inï o nginya ituri cia thï.</s></f>"},{ID:32,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Uka Wee Mwathani Muthamaki
wa waragania na ruendo.</k></c></s></f>"},{ID:33,
Text:"<fArial Black><s1846>3 Nï ündü mündü mükïa aakaya, we nï
arïmüteïthüraga, </s></f>"},{ID:34,
Text:"<fArial Black><s1846>gwata ona müthïnïki ütakïrï na wa kümüteithia, 
Ücio ütärï na hinya, </s></f>"},{ID:35,
Text:"<fArial Black><s1846>o ücio mwagi-rï, nï arïmüiguagïra tha;
andü acio akïa, akïhonokie mïoyo yao.</s></f>"},{ID:36,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Uka Wee Mwathani Muthamaki
wa waragania na ruendo.</k></c></s></f>"},{ID:37,
Text:"<fArial Black><s1846>4 Rïïtwa rïake rïrotüüra tene o na tene; rïüa
rïtarindükïte-rï, </s></f>"},{ID:38,
Text:"<fArial Black><s1846>rïïtwa rïu rïake nï rïtüüre o
rïtambaga; </s></f>"},{ID:39,
Text:"<fArial Black><s1846>andü nï marathimanage nake,
ndürïrï ciothe ikïmwïtage mükenu.</s></f>"},{ID:40,
Text:"<fArial Black><s1846><kFFFF0000>ICOKIA.</k></s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Uka Wee Mwathani Muthamaki
wa waragania na ruendo.</k></c></s></f>"},{ID:41,
Text:"<fArial Black><s1846>GĪTHOMO KĪA IGĪRĪ
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Aroma 15:4-9</k></c></s></f>"},{ID:42,
Text:"<fArial Black><s1846>GÜTHOMA KUUMA MARÜA MA MÜTHURE
PAUL KÕRĪ ANDÜ A ROMA :</s></f>"},{ID:43,
Text:"<fArial Black><s1846>Aruna aitü, mündü mothe mana maandïkirüo tene, maandïkirüo marï ma kwïruta na ithuï.</s></f>"},{ID:44,
Text:"<fArial Black><s1846>Nï getha tütüre na kïïrïgïrïro nï ündü wa ürïa tühotithagio nï Maandïko macio gükirïrïria.</s></f>"},{ID:45,
Text:"<fArial Black><s1846>O na ürïa tüümagï-rïrio nïmo, na rïrï Ngai o we ütümaga andü mahote gükirïrïria.</s></f>"},{ID:46,
Text:"<fArial Black><s1846>O na mahotage küümïrïria, aroetïkïra gütüma müiguanage </s></f>"},{ID:47,
Text:"<fArial Black><s1846>o mündü na ürïa üngï o ta ürïa Kristü Yesu aatuonereirie.</s></f>"},{ID:48,
Text:"<fArial Black><s1846>Nï getha mükoragwo mwï ngoro o ïmwe, mükïgoocage Ngai na kanua o ro kamwe.</s></f>"},{ID:49,
Text:"<fArial Black><s1846>O We Ngai wa Mwathani witü Yesu Kristü, na nowe Ithe. </s></f>"},{ID:50,
Text:"<fArial Black><s1846>Tondü ücio-rï, gïïtïkïranagei o ta ürïa inyuï mwetïkïrirüo nï Kristü.</s></f>"},{ID:51,
Text:"<fArial Black><s1846>Nïguo Ngai agoocithagio. Amu ürïa nguuga nï atïrï, atï Kristü, tondü wa ma ïrïa ya Ngai.</s></f>"},{ID:52,
Text:"<fArial Black><s1846>Nï aatuïkire ndungata ya ühoro ürïa wa kürua, </s></f>"},{ID:53,
Text:"<fArial Black><s1846>nï getha ekïre ciïranïro hinya iria Ngai erïire maithe maitü arïa a tene.</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Na ningï nï getha andü a Ndürïrï magoocage Ngai nï ündü wa tha ciake; </s></f>"},{ID:55,
Text:"<fArial Black><s1846>o ta ürïa kwandïkïtüwo, atïrï: Tondü wa üguo no ngücokagïrie ngatho o nginya Ndürïrï-inï.</s></f>"},{ID:56,
Text:"<fArial Black><s1846>Rïïtwa rïaku ndïrïïnagïre ngïrïkumagia. Cugo cia Mwathani.</s></f>"},{ID:57,
Text:"<fArial Black><s1846>RÜÏMBO RÜA ALLELUYA
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Luka 3:4,6</k></c></s></f>"},{ID:58,
Text:"<fArial Black><s1846><cFFFFFF66><kFFFF0000>Alleluya, Alleluya. </k></c></s></f>"},{ID:59,
Text:"<fArial Black><s1846>Thondekai kïng'aratua kïa Mwathani, rüngariani njïra ciake o na andü othe.</s></f>"},{ID:60,
Text:"<fArial Black><s1846>Nï makona kühonokania kürüa kwa Ngai. </s></f>"},{ID:61,
Text:"<fArial Black><s1846><cFFFFFF66><kFFFF0000>Alleluya.</k></c></s></f>"},{ID:62,
Text:"<fArial Black><s1846>GĪTHOMO KĪA INJIRI
</s></f><fArial Black><s1846><cFFFFFF66><kFFFF0000>Mathayo 3:1-12</k></c></s></f>"},{ID:63,
Text:"<fArial Black><s1846>GĪCUNJÏ KĪA INJIRI THERU TA ÜRÏA
YANDÏKÏTWO NÏ MÜTHURE MATHAYO :</s></f>"},{ID:64,
Text:"<fArial Black><s1846>Matukü macio-rï, gügïüka John ürïa Mübatithania </s></f>"},{ID:65,
Text:"<fArial Black><s1846>akïhunjagia ühoro werü-inï wa Judea, akiugaga a-tïrï: Wïrirei.</s></f>"},{ID:66,
Text:"<fArial Black><s1846>Tondü üthamaki wa Igüro nï ükuhïhïirie. Nï ündü-rï, ücio nïwe wagwetirüo nï Isaia ürïa münabii.</s></f>"},{ID:67,
Text:"<fArial Black><s1846>Rïrïa oigire: He mügambo wa mündü ükwanïrïra werü-inï, akoiga: </s></f>"},{ID:68,
Text:"<fArial Black><s1846>Thondekai kïng'aratua kïa Mwathani; rüngariani njïra ciake.</s></f>"},{ID:69,
Text:"<fArial Black><s1846>Nake John we mwene ehumbaga nguo ya guoya wa ngamira, </s></f>"},{ID:70,
Text:"<fArial Black><s1846>na nï eohaga kamükwa njohero, ningï irüo ciake no ngigï, na üükï wa hako.</s></f>"},{ID:71,
Text:"<fArial Black><s1846>Na hïndï ïo andü a Jerusalemu, o na andü a Judea guothe, o na a bürüri wothe ürïa ürï hakühï na Jordano, </s></f>"},{ID:72,
Text:"<fArial Black><s1846>makiuma kwao, magïthiï kürü we, nao makïbatithio nïwe thïinï wa rüüi rüa Jordano.</s></f>"},{ID:73,
Text:"<fArial Black><s1846>No rïrïa onire Afarisei na Asaducei aingï magüüka kïbatithanio-inï gïake, akïmoria atïrï:</s></f>"},{ID:74,
Text:"<fArial Black><s1846>Ciana ici cia nduïra, nõ wamükinyïirie inyuï ühoro atï müürïre marakara marïa maguka?</s></f>"},{ID:75,
Text:"<fArial Black><s1846>Nï ündü ücio ciarai maciaro maringaine na kwïrira, </s></f>"},{ID:76,
Text:"<fArial Black><s1846>na mütikeïrage na ngoro cianyu atï: Ithe witü nï Abraham.</s></f>"},{ID:77,
Text:"<fArial Black><s1846>Nï gükorüo ngümwïra atï: Ngai aahota gütüma ciana cia Abraham ciume mahiga-inï maya.</s></f>"},{ID:78,
Text:"<fArial Black><s1846>Na rïu ithanwa nï rïrïkïtüe kügüwo itina-inï cia mïtï; tondü wa üguo mütï o wothe</s></f>"},{ID:79,
Text:"<fArial Black><s1846>ütaciaraga maciaro megü nï gütemwo ütemagüo, ügaiküo mwaki-inï.</s></f>"},{ID:80,
Text:"<fArial Black><s1846>Niï-rï, ndïmübatithagia na maaï nïguo mwïrire; no rïrï: </s></f>"},{ID:81,
Text:"<fArial Black><s1846>Ürïa ügüüka thütha wakwa arï na hinya kürü niï, na ndïigaine niï ndïmüküüïre iratü ciake.</s></f>"},{ID:82,
Text:"<fArial Black><s1846>Ücio-rï, nï akamübatithia na Müoyo Mütheru, o na mwaki, </s></f>"},{ID:83,
Text:"<fArial Black><s1846>Gïtarürü gïake arï nakïo guoko, na nï agatheria o wega kïhühïro gïake.</s></f>"},{ID:84,
Text:"<fArial Black><s1846>Na acokererie ngano ikümbï rïake, na acine müüngü na mwaki ürïa ütangïhoreka.</s></f>"},{ID:85,
Text:"<fArial Black><s1846>Injiri theru ya Mwathani.</s></f>"},{ID:86,Style:{Background:{Image:"SACRED HEART OF JESUS GAKIRA CATHOLIC   SUNDAY 17.jpg",Luminosity:0}},
Text:"<fArial Black><s1846>.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"nydrlzvzwanr03apkw91gt9bx4f.jpg"}},
Text:"KIUMIA GIA KERI KIA RIUKIRO MWAKA A"},{Guid:"+lMvJDJeBkSf3CKHItD5rw",Verses:[{Style:{Background:{Image:"KIUMIA GÍA ITHATU.jpg",Luminosity:0}}},{ID:2,
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF3F3F>KIUMIA GÍA ITHATU KÍA RÍÚKIRO 
MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GĪTHOMO KĪA MBERE
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaia 35 : 1 -6. 8, 10</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>GŪTHOMA KUUMA MŪRATHI ISAIA</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Atirirī, werü, o na kūndü kürīa kwagīte andūrī, nĩ gūgakena; o naruo rũng'ūrĩ no rügakena, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>na rũagire rümere mahüa ma nyeki-inī. Ti-itherű nĩ rükaagīra rürute kíro Kíingī mūno, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>rūkene gīkeno rükīinaga nyīmbo; naruo nĩ rükaheo riri o ta wa Lebanoni, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>o na rūagīre wega rūtuike o ta Karmeli na Saaroni; nakuo nĩ gūkona riri wa Mwathani, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>o na kuone ünene wa Ngai witũ wa ürīa ekagīrīrūo .</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Atīrīrī, andū arīa maagīte hinya moko-ri, mekīrei hinya,</s></f>"},{ID:10,
Text:"<fArial Black><s1846> o na arīa maregerete maru mūtūme mehande o wega. </s></f>"},{ID:11,
Text:"<fArial Black><s1846>Arīa marī na guoya ngoro merei atīrī: Wiümīrīriei, mūtige gwītigīra ; atīrī: </s></f>"},{ID:12,
Text:"<fArial Black><s1846>Ngai wanyu agoka na ūhoro wa kürīhanīria, we Ngai agerane ngero iringaine na ürīĩa gwikītwo. </s></f>"},{ID:13,
Text:"<fArial Black><s1846>Nīwe ügoka amūhonokie. Hindī ĩo maitho ma atumumu nĩ makahingūrūo, </s></f>"},{ID:14,
Text:"<fArial Black><s1846>o namo matű ma arīa mataiguaga nĩ magakunūrüo. </s></f>"},{ID:15,
Text:"<fArial Black><s1846>Hindī io mũndū ürĩa ūthuaga agacimbicaga o ta thwariga, </s></f>"},{ID:16,
Text:"<fArial Black><s1846>o naruo rürīmī rūa ürīa ütahotaga kwaria nĩ küina rūkaina.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Nakuo kūu nĩ gükagīa njīra njarií ya gītwari, o ya barabara, nayo íītagwo üū: </s></f>"},{ID:18,
Text:"<fArial Black><s1846>Njĩra īiria nyamüre; îndĩ arīa matarí atheru matikamīgera, </s></f>"},{ID:19,
Text:"<fArial Black><s1846>nao arīa makamīgera agakoragwo e hakuhĩ nao; tondü ücio, o na arīa akīgu matikamīhĩtia.</s></f>"},{ID:20,
Text:"<fArial Black><s1846>Nao andū a Mwathani arīa makūürītwo makahūndūrűo makinye Sion makīinaga. </s></f>"},{ID:21,
Text:"<fArial Black><s1846>Magatūüra makenete ta mekiritwo thūmbī ya gīkeno gītagathira; </s></f>"},{ID:22,
Text:"<fArial Black><s1846>nī gīkeno makona na macanjamüke ngoro, nakīo kīeha O na mūcayo nĩ ikora biū.</s></f>"},{ID:23,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:24,
Text:"<fArial Black><s1846>THABURI YA GÜCOKERŪO
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Thaburi 146: 7; 8-9a; 9b-10</k></c></s></f>"},{ID:25,
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mwathani ūka ūtūhonokie.</k></c></s></f>"},{ID:26,
Text:"<fArial Black><s1846>1.Mwathani, o we ūrīa ūtuagīra andũ arīa agūnîre matuiro ma kīhooto; </s></f>"},{ID:27,
Text:"<fArial Black><s1846>ūrīa ningī ūheaga arīa ahūtu irio. Mwathani-rī, aria ohe nî amohoraga.</s></f>"},{ID:28,
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mwathani ūka ūtūhonokie.</k></c></s></f>"},{ID:29,
Text:"<fArial Black><s1846>2.Mwathani nî ahingūraga arīa atumumu maitho, Mwathani nî ainamūraga aria mekonotete, </s></f>"},{ID:30,
Text:"<fArial Black><s1846>Mwathani nĩ enda arīa athingu; Mwathani-ri, nĩ amenyagīrīra ageni.</s></f>"},{ID:31,
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA :</k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F> Mwathani ūka ūtūhonokie.</k></c></s></f>"},{ID:32,
Text:"<fArial Black><s1846>3.Mwana wa ngoriai na mûtumia wa ndigwa, nīwe ūmanyitagirīra; </s></f>"},{ID:33,
Text:"<fArial Black><s1846>nayo njira ya and</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846> aaganu ni kūmĩhotomia amîhotomagia. </s></f>"},{ID:34,
Text:"<fArial Black><s1846>Mwathani egütūūra athamakaga tene na tene, </s></f>"},{ID:35,
Text:"<fArial Black><s1846>Ngai waku, wee Sion-ri, egūtūūra athamakaga nginya njiarüa na njiarũa.</s></f>"},{ID:36,
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mwathani ūka ūtūhonokie.</k></c></s></f>"},{ID:37,
Text:"<fArial Black><s1846>GĪTHOMO KĪA IGĪRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Jacob 5: 7-10</k></c></s></f>"},{ID:38,
Text:"<fArial Black><s1846>GŨTHOMA MARUA MA MÜTHURE JACOB</s></f>"},{ID:39,
Text:"<fArial Black><s1846>Aruna aitũ, kiragirīriai o nginya rīrīa Mwathani agoka. </s></f>"},{ID:40,
Text:"<fArial Black><s1846>Tarorai ürīa műrīmi etagirīra irio ciumaga thi</s></f>"},{ID:41,
Text:"<fArial Black><s1846>o iria irī bata,ategūcithethūkīra, o nginya ikoirīrūo nĩ mbura ya mbere, </s></f>"},{ID:42,
Text:"<fArial Black><s1846>o na īirīa ya kürigiriria, O na inyuī-rī, kiragirīriai; </s></f>"},{ID:43,
Text:"<fArial Black><s1846>na mwīkindire ngoro-inī cianyu, amu Mwathani akiriĩ gūūka. Ariũ a Ithe witũ,</s></f>"},{ID:44,
Text:"<fArial Black><s1846>tigagai gūtetania, nī getha mūtigacirithio: atīrī: Műtui cira nī arűngiī muromo-inī. </s></f>"},{ID:45,
Text:"<fArial Black><s1846>Ariŭ a Ithe witü, gwatai ūhoro wa maūndū marīa anabii mekirū</s></f><fSegoe UI Black><s1846>ủ</s></f><fArial Black><s1846>o, arĩa maaragia riîitwa-inī rĩa </s></f>"},{ID:46,
Text:"<fArial Black><s1846>Mwathani, ūhoro ūcio ütuke kīonereria kīanyu ūhoro-inī wa kūnyarirīka, na wa gūkirīrīria.</s></f>"},{ID:47,
Text:"<fArial Black><s1846>Icio nĩcio ciugo cia Mwathani ,</s></f>"},{ID:48,
Text:"<fArial Black><s1846>RUIMBO RUA ALLELUYA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaia 61,1</k></c></s></f>"},{ID:49,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Alleluya, Alleluya. </k></c></s></f>"},{ID:50,
Text:"<fArial Black><s1846>Muoyo wa Mwathani arĩ igűrű rīakwa, nĩgetha hunjagīrie arīa athiini ūhoro ürīa Mwega. </s></f>"},{ID:51,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Alleluya.</k></c></s></f>"},{ID:52,
Text:"<fArial Black><s1846>GĪTHOMO KIA INJIRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mathayo 11: 2-11</k></c></s></f>"},{ID:53,
Text:"<fArial Black><s1846>GÍCUNJI KĨA INJIRI THERU TA ŨRĪA YANDĪKITWO NĪ M</s></f><fSegoe UI Black><s1846>Ữ</s></f><fArial Black><s1846>THUKE MATHAYO :</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Hindi īiyo John arī korokoro-inī aigua ühoro wa maūũndű marīa Kristū ekaga, </s></f>"},{ID:55,
Text:"<fArial Black><s1846>akimürekeria arutwo ake, makamüürie atirī: Wee nīwe ūrīa ūgūüka, kana tweterere ūngī?</s></f>"},{ID:56,
Text:"<fArial Black><s1846> Nake Yesu akimacokeria akīmera atīrī: Withiírei, mūkere John ühoro wa maūnd</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846> marīa műiguaga, </s></f>"},{ID:57,
Text:"<fArial Black><s1846>na maria muonaga: atī atumumu nĩ macokete kuona, </s></f>"},{ID:58,
Text:"<fArial Black><s1846>na arīa mathuaga magacoka gwītwara wega, na arīa marī na mangű makahonio</s></f>"},{ID:59,
Text:"<fArial Black><s1846>magathera, na arīa mataiguaga magacoka kūigua, na arīa makuïte makariűkio,</s></f>"},{ID:60,
Text:"<fArial Black><s1846>o na arīa athini makahunjagīrio Ühoro-ūrīa-Mwega. </s></f>"},{ID:61,
Text:"<fArial Black><s1846>Na gūkena-rī, nĩ ürīa ūtonaga ündű wa kűmūhĩngithia nĩ ündū wakwa.</s></f>"},{ID:62,
Text:"<fArial Black><s1846>Nao maathii-rī, Yesu agītika kwaria ühoro wa John, akīūria kīrīndī kīrīa kīarí ho: Atiriri,</s></f>"},{ID:63,
Text:"<fArial Black><s1846> mwoimagarire mūgīthiî werū-inī mūkerorere kĩ? Anga nĩ kaműrangi kainainagio nĩ rūhuho ? </s></f>"},{ID:64,
Text:"<fArial Black><s1846>No rīri, mwoimagarire mūgīthiī kuona kī ? Hihi nĩ mündū wihumbīte nguo horo ?</s></f>"},{ID:65,
Text:"<fArial Black><s1846>Atīrīrī, arīa mehumbiīte nguo horo maikaraga nyümba-inī cia athamaki. </s></f>"},{ID:66,Style:{Background:{Luminosity:-50}},
Text:"<fArial Black><s1846>No rĩrī, mwoimagarire mūgīthiĩ nĩ ündū kĩ? Nĩ kuona mūnabii ? </s></f>"},{ID:67,
Text:"<fArial Black><s1846>íí-ni, na ngūmwira atīrī, o na nĩ ūrīa ükīrīte müno münabii.</s></f>"},{ID:68,
Text:"<fArial Black><s1846>Ücio nīwe ūhoro ūyũ wandikītwo nî ündū wake, ūű: </s></f>"},{ID:69,
Text:"<fArial Black><s1846>Atīrīrī, nĩ ngūtūma m</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>rekio wakwa athiĩ mbere yaku, </s></f>"},{ID:70,
Text:"<fArial Black><s1846>ūria ügūgüthondekera njĩra mbere yaku. </s></f>"},{ID:71,
Text:"<fArial Black><s1846>Ngũmwīra atīrī na ma, atī, Kūrīĩ arīa maanaciarüo nĩ andü-a-nja, </s></f>"},{ID:72,
Text:"<fArial Black><s1846>gütirī kwagīa mūnene kürī John Mübatithania :</s></f>"},{ID:73,
Text:"<fArial Black><s1846> no rīrī, ürīa wĩ mũnyinyi ūthamaki-inī wa igūrū nĩ mũnene kūrī we</s></f>"},{ID:74,
Text:"<fArial Black><s1846>Injiri theru ya Mwathani.</s></f>"},{ID:75,Style:{Background:{Image:"KIUMIA GÍA ITHATU.jpg",Luminosity:0}},
Text:"<fArial Narrow><s76>.</s></f>"}],VideoDuration:0,Style:{Background:{Image:"images (2) - Copy.jpg",Luminosity:-45}},
Text:"KIUMIA GÍA ITHATU KÍA RÍÚKIRO MWAKA A
"},{Guid:"XYz37nwvd0C9lyYZOx87zw",Verses:[{
Text:"<u><fArial Black><s1846><cFFF2F200><kFFFF3F3F>KIUMIA KÍA INYA KIA RIUKIRO MWAKA A</k></c></s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GĪTHOMO KĪA MBERE
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Isaia 7: 10- 14</k></c></s></f>"},{ID:3,
Text:"<fArial Black><s1846>GŪTHOMA KUUMA MURATHI ISAIA</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Matukü-inī macio, Mwathani agīcoka akīarīria Akaz, akīmwīra atirī : </s></f>"},{ID:5,
Text:"<fArial Black><s1846>Wítürie kīmenyithia he Mwathani Ngai waku, kiume kūndū kūriku műno, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>kana o igürű matu-inī. No rĩri, Akaz akiuga atīrī :</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Ndītia, kana ngerie Mwathanio na atīa. Nake Isaia agīkiuga atīrī: </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Ta thikīrīriai, inyuī andŭ nyūmba ya Davide, anga mūkuona </s></f>"},{ID:9,
Text:"<fArial Black><s1846>ta arī ündũ mũnyinyi mũno gūtūūra mūnogagia andū, at</s></f><fSegoe UI Black><s1846>ỉ</s></f><fArial Black><s1846> nīkio</s></f>"},{ID:10,
Text:"<fArial Black><s1846>mükwenda kūnogia Ngai wakwa o nake ? Mwathani we mwene nī akamūhe kīmenyithia. </s></f>"},{ID:11,
Text:"<fArial Black><s1846>Atirirī: Müirītu nī akagīa ihu, aciare kahīí, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>agatue Emmanuel, nĩ ta kuuga : Ngai hamwe na ithuĩ.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Icio nicio ciugo cia Mwathani.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>THABURI YA GŪCOKERUO
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Thaburi 24: 1-2; 3-4a; 5-6</k></c></s></f>"},{ID:15,
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Müthamaki wa riri atonye, nowe Müthamaki wa riri.</k></c></s></f>"},{ID:16,
Text:"<fArial Black><s1846>1.Thĩ nĩ ya Mwathani, o na indo iria ciiyūire kuo; mabūrūri mothe, o gwata arīa matūire mo.</s></f>"},{ID:17,
Text:"<fArial Black><s1846>Tondū we nīwe wakīte gītina kīayo maria-ini, agakimirūmia īikaire maái igūrū.</s></f>"},{ID:18,Style:{Background:{Luminosity:-50}},
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Müthamaki wa riri atonye, nowe Müthamaki wa riri.</k></c></s></f>"},{ID:19,Style:{Background:{Luminosity:-50}},
Text:"<fArial Black><s1846>2.Nũ ũngīambata kirima kīa Mwathani ? Nū üngikirūgama harīa hake haamūre ? </s></f>"},{ID:20,
Text:"<fArial Black><s1846>Nū üria wĩ na
moko matheru, na akaaga ūũru ngoro.</s></f>"},{ID:21,Style:{Background:{Luminosity:-50}},
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Müthamaki wa riri atonye, nowe Müthamaki wa riri.</k></c></s></f>"},{ID:22,
Text:"<fArial Black><s1846>3.Ücio nīwe wa kwamūkira kīrathimo harī Mwathani,
 akīamūkīre ūthingu harī Ngai mwene ühonokio wake.</s></f>"},{ID:23,
Text:"<fArial Black><s1846> Kĩu nīkio gethamba kīa arīa mamūmathaga, arīa marongoragia ūthi</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846> waku, wee Ngai wa Jacob.</s></f>"},{ID:24,Style:{Background:{Luminosity:-55}},
Text:"<fArial Black><s1846><kFFFF3F3F>ICOKIA : </k></s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Müthamaki wa riri atonye, nowe Müthamaki wa riri</k></c></s></f><fArial Black><s1846><kFFFF3F3F>.</k></s></f>"},{ID:25,
Text:"<fArial Black><s1846>GĪTHOMO KĪA IGĪRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Aroma 1:1-7</k></c></s></f>"},{ID:26,
Text:"<fArial Black><s1846>GÜTHOMA KUUMA MARŪA MA M</s></f><fSegoe UI Black><s1846>Ữ</s></f><fArial Black><s1846>THURE PAUL KŪRI ANDU AROMA :</s></f>"},{ID:27,
Text:"<fArial Black><s1846>Nĩ niĩ Paulo, ndungata ya Yesu Kristū, ngwandīka marüa maya, </s></f>"},{ID:28,
Text:"<fArial Black><s1846>o nií ndetirūo nduïte mūtūmwo, ngīkīamūrūo “hunjagie Ühoro-ürīa-Mwega wa Ngai, </s></f>"},{ID:29,
Text:"<fArial Black><s1846>ürīa eraniīire o mbere na tũnua twa anabii ake Maandīko-inī marīa matheru, </s></f>"},{ID:30,
Text:"<fArial Black><s1846>o ürīa ükonií Mūrū-we, waciarirūo arī wa mbeŭ ya Davide ha ühoro wa mwirí, </s></f>"},{ID:31,
Text:"<fArial Black><s1846>ningī ha űhoro wa muoyo ūrīa aarī naguo wa ūtheru akīonanio </s></f>"},{ID:32,
Text:"<fArial Black><s1846>na wīko wa hinya atī nīwe Mūrű wa Ngai tondū wa ürīa aariūkire akiuma kūrī arīa akuü, </s></f>"},{ID:33,
Text:"<fArial Black><s1846>o we Yesu Kristũ Mwathani witū. Niwe wanginyithĩire Wega wa Ngai </s></f>"},{ID:34,
Text:"<fArial Black><s1846>na agītüma nduīke mūtūmwo, nĩ getha andū a ndūrĩrī ciothe matuike aathīku </s></f>"},{ID:35,
Text:"<fArial Black><s1846>ūhoro-inī wa wītīkio, nīguo riïtwa rīake rīmkagīrīrūo ; na inyuī mürī aho, </s></f>"},{ID:36,
Text:"<fArial Black><s1846>mūgetwo o na inyuī mūtuike a Yesu Kristű. Inyuothe mütũire kūu Roma, </s></f>"},{ID:37,
Text:"<fArial Black><s1846>inyuí ende nī Ngai, mügagiītwo m</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>tuīke aamüre - rī,</s></f>"},{ID:38,
Text:"<fArial Black><s1846>nĩ inyuï ngwandikīra marüa maya. Mürogīa na Wega, o na thayũ, </s></f>"},{ID:39,
Text:"<fArial Black><s1846>ciumīte kwï Ngai lthe witü o na
Mwathani Yesu Kristū</s></f>"},{ID:40,
Text:"<fArial Black><s1846>Icio nīcio ciugo cia Mwathani.</s></f>"},{ID:41,
Text:"<fArial Black><s1846>RŪÍMBO RŪA ALLELUYA
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mathayo 1, 23</k></c></s></f>"},{ID:42,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Alleluya, Alleluya.</k></c></s></f><fArial Black><s1846><kFFFF3F3F> </k></s></f>"},{ID:43,
Text:"<fArial Black><s1846>Onei Thingi nĩ īkagīa ihu, na íciare kahiī , nako gagetwo Emmanuel,na nĩ ta kuuga : Ngai hamwe na ithuí. </s></f>"},{ID:44,
Text:"<fArial Black><s1846><cFFF2F200><kFFFF3F3F>Alleluya.</k></c></s></f>"},{ID:45,
Text:"<fArial Black><s1846>GĪTHOMO KIA INJIRI
</s></f><fArial Black><s1846><cFFF2F200><kFFFF3F3F>Mathayo 1: 18- 24</k></c></s></f>"},{ID:46,
Text:"<fArial Black><s1846>GÍCUNJĨ KĪA INJIRI THERU TA ŪRĪA YANDĪKĪTWO NĪ MŪTHURE MATHAYO:</s></f>"},{ID:47,
Text:"<fArial Black><s1846>Rīu-ī, gūciarūo kwa Yesu Kristũ gwatarií üū: Nyina Maria orio nĩ Joseph, matano nana, </s></f>"},{ID:48,
Text:"<fArial Black><s1846>akīonwo ari na ihu rīa Muoyo Mūtheru. Nake mūthuri-we Joseph, tondū aarī mũndũ m</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>thingu, </s></f>"},{ID:49,
Text:"<fArial Black><s1846>na ndendaga gūconorithia mūirītu ūcio kūrī andū, akīenda atigane nake na hitho. </s></f>"},{ID:50,
Text:"<fArial Black><s1846>Na hĩndĩ îrĩa eciragia maūndū macio, atĩrīrī, mūraika wa Mwathani akīmuumirīra kīroto-inī, </s></f>"},{ID:51,
Text:"<fArial Black><s1846>akīmwĩra atīrī: Joseph, mūrű wa Davide, ndūgetigīre kūhikia Maria atuīke mūtumia waku, </s></f>"},{ID:52,
Text:"<fArial Black><s1846>tondū-rĩ, ihu rĩu arī narīo nĩ ria Muoyo Mütheru. Nake nī agaciara kahiī, nako nĩ ügagatua Yesu, </s></f>"},{ID:53,
Text:"<fArial Black><s1846>nĩ ündū nīwe ükahonokia andū ake mehia-inī mao.</s></f>"},{ID:54,
Text:"<fArial Black><s1846>Na rīrī, ma ūndū macio mekirūo nĩ getha ciugo iria cioigirūo nī </s></f>"},{ID:55,
Text:"<fArial Black><s1846>Mwathani na kanua ka mūrathi ikinye, rirīa oigire atīrī: Onei, </s></f>"},{ID:56,
Text:"<fArial Black><s1846>műirītu thingi nĩ akagīa ihu, na aciare kahīī, nako gatuwo Emmanuel; </s></f>"},{ID:57,
Text:"<fArial Black><s1846>ūguo naguo ūgītaūrűo, nĩ kuuga: </s></f>"},{ID:58,
Text:"<fArial Black><s1846>Ngai hamwe na ithuĩ. Nake Joseph agiükīra toro, agiīka o ta ürīa </s></f>"},{ID:59,
Text:"<fArial Black><s1846>müraika wa Mwathani aamwathire, akīhikia m</s></f><fSegoe UI Black><s1846>ữ</s></f><fArial Black><s1846>tumia wake.</s></f>"},{ID:60,
Text:"<fArial Black><s1846>Injiri theru ya  Mwathani,</s></f>"}],VideoDuration:0,Style:{Background:{Image:"nydrlzvzwanr03apkw91gt9bx4f.jpg",Luminosity:-45}},
Text:"KIUMIA KÍA INYA KIA RIUKIRO MWAKA A
"}],Guid:"7a1U3QDSnUeY4RfODcKdrA",
