{Songs:[{Guid:"L9aVT+nbr0iEIjUuXNuxww",Verses:[{
Text:"<fArial Black><s1846>DOMINIKA YA NNE YA PASAKA MWAKA C</s></f>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA</s></f>"},{ID:2,Style:{Background:{BodyRect:"0,0,10000,9300"}},
Text:"<fArial Black><s1846>Matendo ya Matume 13:14, 43-52</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha Matendo ya Mitume</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Siku zile:</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Paulo na Barnaba walitoka Perge, wakaendelea na safari, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>wakafika Antiokia katika Pisidia Siku ya Sabato </s></f>"},{ID:6,
Text:"<fArial Black><s1846>walingia katika Sinagogi, wakaketi.</s></f>"},{ID:4,Style:{Background:{BodyRect:"0,0,10000,9300"}},
Text:"<fArial Black><s1846> Wengi wa Wayahudi na waabudu </s></f>"},{ID:5,
Text:"<fArial Black><s1846>wageni wakawafuata Paulo na Barnaba, nao walisema nao, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>wakawatia moyo waishikilie neema ya Mungu. </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Sabato iliyofuata watu karibu wote wa mjini </s></f>"},{ID:7,
Text:"<fArial Black><s1846>walikutana ili kulisikia neno la Mungu. </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Wayahudi walipoona umati wa watu walijaa wivu, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>wakayapinga maneno ya Paulo na kutukana.</s></f>"},{ID:7,
Text:"<fArial Black><s1846> Paulo na Barnaba walihubiri waziwazi wakisema, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>\"Ilikuwa haki yenu kuhubiriwa kwanza neno la Mungu,</s></f>"},{ID:8,
Text:"<fArial Black><s1846> lakini kwa sababu mnalikataa, na kwa hukumu yenu wenyewe </s></f>"},{ID:9,
Text:"<fArial Black><s1846>hamstahili uzima wa milele, 
haya basi, tunawaendea Watu wa Mataifa. </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Kwa maana ni hayo alıyotuagizia Bwana aliposema, </s></f>"},{ID:11,
Text:"<fArial Black><s1846>‘Nimekuweka uwe mwanga wa Watu wa Mataifa,</s></f>"},{ID:10,
Text:"<fArial Black><s1846> na mjumbe wa wokovu hata miisho ya dunia.’’’</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Watu wa mataifa waliposikia hayo walifurahi, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>wakalitukuza Neno la Bwana. </s></f>"},{ID:13,
Text:"<fArial Black><s1846>Na wote waliokuwa wamewekewa uzima wa milele walisadiki, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>na neno la Bwana likaenea katika nchi ile yote. Lakini Wayahudi, </s></f>"},{ID:13,
Text:"<fArial Black><s1846>waliwachochea wanawake mashuhuri </s></f>"},{ID:14,
Text:"<fArial Black><s1846>wacha Mungu na wasimamizi wa mji,</s></f>"},{ID:13,
Text:"<fArial Black><s1846> wakasababisha kuwadhulumu Paulo na Barnaba, </s></f>"},{ID:14,
Text:"<fArial Black><s1846>wakawafukuza katika eneo lao. </s></f>"},{ID:15,
Text:"<fArial Black><s1846>Nao wakakung'uta mavumbi ya miguu kwa kuwasuta, wakaenda Ikonia.</s></f>"},{ID:14,
Text:"<fArial Black><s1846> Wafuasi lakini walijaa furaha na Roho Mtakatifu.</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Zaburi 
100:2, 3. 5 (K. 3c)</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Sisi tu watu wake, taifa lake na kondoo wa malisho yake.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Mshangilieni Bwana, ee nchi yote;</s></f>"},{ID:5,
Text:"<fArial Black><s1846>mtumikieni Bwana kwa furaha;</s></f>"},{ID:6,
Text:"<fArial Black><s1846>njoni mbele zake kwa kuimba. (K)</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Sisi tu watu wake, taifa lake na kondoo wa malisho yake.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Jueni kwamba Bwana ndiye Mungu,
ndiye aliyetuumba, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>nasi tu watu wake,
taifa lake na kondoo wa malisho yake. (K)</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Sisi tu watu wake, taifa lake na kondoo wa malisho yake.</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Kwa maana Bwana ndiye mwema,
wema wake wadumu milele,</s></f>"},{ID:11,
Text:"<fArial Black><s1846>uaminifu wake unadumu kizazi hata kizazi. (K)</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Sisi tu watu wake, taifa lake na kondoo wa malisho yake.</s></f>"},{
Text:"<fArial Black><s1846>SOMO LA PILI</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Ufunuo 
7:9, 14b-17</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha Ufunuo wa Mtakatifu Yohane</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Mimi, Yohane, nilitazama nikauona umati mkubwa asioweza mtu
kuuhesabu, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>watu wa kila taifa, kabila, ukoo na lugha.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Walikuwa wamesimama mbele ya kiti cha enzi na mbele ya Mwanakondoo, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>wamevikwa mavazi meupe na kushika matawi ya mitende mikononi mwao.</s></f>"},{ID:5,
Text:"<fArial Black><s1846> Mmojawapo wa wale wazee akaniambia, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>\"Hawa wanatoka katika dhulumu kubwa; </s></f>"},{ID:7,
Text:"<fArial Black><s1846>wamefua mavazi yao na kuyafanya meupe katika damu ya Mwanakondoo.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Ndio wako mbele ya kiti cha enzi cha Mungu </s></f>"},{ID:7,
Text:"<fArial Black><s1846>wakimtumikia mchana na usiku hekaluni mwake;</s></f>"},{ID:7,
Text:"<fArial Black><s1846> na yeye anayekaa katika kiti cha enzi atatanda hema yake Juu yao.  </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Hawataona tena njaa wala kiu.
Jua kali na upepo wa hari havitawachoma tena. </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Kwani Mwanakondoo aliye katikati mbele ya kiti cha enzi atawachunga </s></f>"},{ID:9,
Text:"<fArial Black><s1846>na kuwaongoza kwenye chemchemi za maji ya uzima. </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Mungu mwenyewe atayafuta machozi yote
katika macho yao.\"</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Yohane 
10:14</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Aleluya. Aleluya.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Mimi ndimi mchungaji mwema, asema Bwana;</s></f>"},{ID:14,
Text:"<fArial Black><s1846> 
nawajua walio wangu, nao walio wangu wanijua mimi.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Aleluya.</s></f>"},{
Text:"<fArial Black><s1846>INJILI</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Yohane 
10:27-30</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Yohane</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Wakati ule:
Yesu alisema, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>\"Kondoo wangu husikia sauti yangu; 
nami nawajua, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>nao wanifuata.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Nawapa uzima w\\a milele, hawataangamia milele.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Hakuna awezaye kuwapokonya katika mkono wangu. </s></f>"},{ID:5,
Text:"<fArial Black><s1846>Baba yangu aliyenipa hao, ni mkubwa kuliko wote, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>na hakuna awezaye kuwapokonya katika mkono wa Baba yangu.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Mimi na Baba tu umoja.\"</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,
Text:"DOMINIKA YA NNE YA PASAKA MWAKA C"},{Guid:"IbnLx4jpEEKNpcVh73+Nug",Verses:[{Style:{Body:{FontStyle:{Fill:{Type:0,Color:"FF9BBB59"},Stroke:{Type:0,Color:"FFFEFEFE"},ShadowColor:"FFCCCCCC",ShadowRadius:35,ShadowDirection:-135,ShadowDepth:24}}},
Text:"<u><fArial Black><s1846>DOMINIKA YA TANO 
YA PASAKA MWAKA C</s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>SOMO LA KWANZA </s></f>"},{ID:2,
Text:"<fArial Black><s1846>Matendo ya Mitume 
14:21b-27</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha Matendo ya Mitume</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Siku zile: Paulo na Barnaba walirudi Listra, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>na Ikonia, na Antiokia katika Pisidia. </s></f>"},{ID:4,
Text:"<fArial Black><s1846>Waliwaimarisha wafuasi roho na </s></f>"},{ID:5,
Text:"<fArial Black><s1846>kuwatia moyo waishikilie imani, wakiwaambia,</s></f>"},{ID:5,
Text:"<fArial Black><s1846> \"Yatupasa kuingia katika ufalme  wa Mungu </s></f>"},{ID:6,
Text:"<fArial Black><s1846>kwa kupitia masumbufu mengi na taabu nyingi.\" </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Kila mahali waliweka wazee, kwa kufunga na kusali waliwaweka  </s></f>"},{ID:7,
Text:"<fArial Black><s1846>katika ulinzi wa Bwana waliyemsadiki.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Walipita nchi ya Pisidia, wakafika Pamfilia. </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Huko wakalihubiri neno katika Perge, wakashukia Atalia.</s></f>"},{ID:8,
Text:"<fArial Black><s1846> Kutoka huko wakisafiri kwa meli mpaka Antiokia, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>ndipo walipokuwa wameombewa neema ya Mungu </s></f>"},{ID:10,
Text:"<fArial Black><s1846>kwa kazi waliyotimiza tayari.</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Baada ya kufika, walifanya mkutano na Kanisa la huko, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>wakatoa taarifa ya mambo aliyofanya Mungu pamoja nao,</s></f>"},{ID:10,
Text:"<fArial Black><s1846> na ya kuwa amewafungulia Watu wa Mataifa mlango wa imani.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>Neno la Bwana</s></f>"},{
Text:"<fArial Black><s1846>ZABURI YA KUITIKIZANA</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Zaburi 
145:8-9, 10-11, 12-13ab)</s></f>"},{ID:2,
Text:"<fArial Black><s1846>K. Nitalisifu jina lako daima na milele, ee Mungu wangu, mfalme.</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Bwana ni mwenye huruma na mpole,
si mwepesi wa hasira, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>ni mwingi wa fadhili.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Bwana ni mwema kwa wote, 
na huruma yake i juu ya viumbe vyake vyote. (K)</s></f>"},{ID:4,
Text:"<fArial Black><s1846>K. Nitalisifu jina lako daima na milele, ee Mungu wangu, mfalme.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Kazi zako zote zinakutukuza, ee Bwana,</s></f>"},{ID:6,
Text:"<fArial Black><s1846>wachaji wako wanakusifu.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Wanautaja utukufu wa ufalme wako, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>wanauhadithia uwezo wako. (K)</s></f>"},{ID:7,
Text:"<fArial Black><s1846>K. Nitalisifu jina lako daima na milele, 
ee Mungu wangu, mfalme.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Ili wawajulishe wanadamu matendo yako makuu,</s></f>"},{ID:9,
Text:"<fArial Black><s1846>na fahari tukufu ya ufalme wako. </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Ufalme wako ni ufalme wa nyakati zote, 
na </s></f>"},{ID:10,
Text:"<fArial Black><s1846>utawala wako wadumu kwa vizazi vyote, K.</s></f>"},{ID:10,
Text:"<fArial Black><s1846>K. Nitalisifu jina lako daima na milele, ee Mungu wangu, mfalme.</s></f>"},{
Text:"<fArial Black><s1846>SOMO LA PILI</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Ufunuo 
21:1-5a</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo katika kitabu cha Ufunuo wa Mtakatifu Yohane</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Mimi, Yohane, niliona mbingu mpya na nchi mpya </s></f>"},{ID:4,
Text:"<fArial Black><s1846>kwani mbingu ya kwanza na ulimwengu wa kwanza vilikuwa vimepita, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>na bahari haipo tena.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Nikauona mji mtakatifu, Yerusalemu mpya, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>ukishuka kutoka mbinguni kwa Mungu.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Umetayarishwa kama bibi harusi aliyejipamba kwa ajili ya mume wake.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Nikasikia sauti kubwa kutoka kiti cha enzi ikisema,</s></f>"},{ID:6,
Text:"<fArial Black><s1846> \"Tazama hema ya Mungu kati ya wanadamu.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Naye atakaa kwao, nao watakuwa taifa lake </s></f>"},{ID:8,
Text:"<fArial Black><s1846>na Mungu mwenyewe atakuwa pamoja nao. </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Atafuta kila chozi katika macho yao. </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Hakutakuwa tena wala mauti, wala sikitiko, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>wala kilio, wala maumivu kwa kuwa mambo ya kwanza yatakuwa yamepita.\"</s></f>"},{ID:9,
Text:"<fArial Black><s1846> Yeye aliyeketi katika kiti cha enzi akasema. \"Tazama, nafanya yote upya.\"</s></f>"},{ID:10,
Text:"<fArial Black><s1846>Neno la Bwana.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>SHANGILIO LA INJILI</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Yohane 13:34</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Aleluya. Aleluya.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Amri mpya nawapeni: mpendane, asema Bwana.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Kama mimi nilivyowapenda, nanyi pia mpendane.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Aleluya.</s></f>"},{
Text:"<fArial Black><s1846>INJILI</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Yohane 
13:31-33a, 34-35</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Somo la Injili takatifu ilivyoandikwa na Yohane</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Baada ya Yuda kutoka (karamuni)[karamuni], </s></f>"},{ID:4,
Text:"<fArial Black><s1846>Yesu alisema,\"Sasa Mwana wa Mtu ametukuzwa, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>na Mungu ametukuzwa ndani yake.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>Mungu akiwa ametukuzwa ndani yake, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>naye Mungu atamtukuza pia, na atamtukuza mara.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Watoto wangu, bado kitambo kidogo nipo pamoja nanyi. </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Amri mpya nawapeni:</s></f>"},{ID:6,
Text:"<fArial Black><s1846> mpendane. Kama mimi nilivyowapenda, 
nanyi pia mpendane. </s></f>"},{ID:7,
Text:"<fArial Black><s1846>Hivyo watu wote watatambua </s></f>"},{ID:8,
Text:"<fArial Black><s1846>ya kuwa ninyi mmekuwa wafuasi wangu, mkipendana.\"</s></f>"},{ID:8,
Text:"<fArial Black><s1846>Injili ya Bwana.</s></f>"}],VideoDuration:0,
Text:"DOMINIKA YA TANO YA PASAKA MWAKA C"},{Guid:"erXM6zMSYUeJyafy7+hJUQ",Verses:[{Style:{Background:{Brush:{Type:0,Color:"FF000000"}}},
Text:"<b><fArial Black><s1846>KIUMIA KIA INYA KIA IRIUKIRO MWAKA C</s></f></b>"},{ID:2,Style:{Background:{Brush:{Type:0,Color:"FF000000"}}},
Text:"<fArial Black><s1846>GĨTHOMO KĨA MBERE
Atũmwo 13:14, 43-52</s></f>"},{ID:2,
Text:"<fArial Black><s1846>GŨTHOMA KUUMA IBUKU RĨA ATŨMWO:</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Matukũ-inĩ macio, Paul  na Barnaba, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>maarĩkia gũtuĩkanĩria bũrũri ũcio moimĩte Perje, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>magĩkinya Antiokia itũũra rĩa bũrũri wa Pisidia.  </s></f>"},{ID:5,
Text:"<fArial Black><s1846>Na magĩtonya thinagoga mũthenya wa thabatũ, magĩikara thĩ.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Na rĩrĩa kũu thinagoga-inĩ gwaitĩkire kũharaganio-rĩ, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>andũ aingĩ, Ayahudi o na andũ meamũrĩire 
Ngai a thiritũ ya arĩa megarũrĩte magatuĩka Ayahudi,</s></f>"},{ID:6,
Text:"<fArial Black><s1846> makĩrũmĩrĩra Paul na Barnaba: 
nao atũmwo acio makĩmaarĩria, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>makĩmahatĩrĩria atĩ matũre marũmĩte Wega-inĩ wa Ngai.</s></f>"},{ID:7,
Text:"<fArial Black><s1846>  Naguo mũthenya  ũyũ ũngĩ wa thabatũ gũgĩkinya atĩrĩ, atĩ ta andũ </s></f>"},{ID:8,
Text:"<fArial Black><s1846>othe a itũũra makĩũngana maigue Ũhoro wa Ngai. </s></f>"},{ID:8,
Text:"<fArial Black><s1846> No rĩrĩa Ayahudi monire kĩrĩndĩ kĩrĩa kĩingĩ kĩonganĩte, makĩigua ũiru </s></f>"},{ID:9,
Text:"<fArial Black><s1846>mũno, magĩkararia  maũndũ marĩa maaragio nĩ Paul,</s></f>"},{ID:9,
Text:"<fArial Black><s1846> makĩmũruma.  Nao Paul na Barnaba 
magĩitĩka kwaria na ũcamba, makĩmera atĩrĩ: </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Nĩ kwarĩ bata atĩ Ũhoro wa Ngai wambe wario kũrĩ inyuĩ.  </s></f>"},{ID:11,
Text:"<fArial Black><s1846>No rĩrĩ, 
kuona atĩ nĩ mwaũrega kũna, mwaũte, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>mwatua atĩ mũtiagĩrĩirũo nĩ kũheo muoyo wa tene na tene, rĩu-rĩ,</s></f>"},{ID:11,
Text:"<fArial Black><s1846> tũkũgarũrũkĩra andũ arĩa a Ndũrĩrĩ.  </s></f>"},{ID:12,
Text:"<fArial Black><s1846>Nĩ gũkorũo ũguo nĩguo Mwathani atwathĩte twĩke, 
akoiga atĩrĩ: </s></f>"},{ID:13,
Text:"<fArial Black><s1846>Nĩ ngũigĩte Wee ũtuĩke ũtheri wa gũtheria andũ a Ndũrĩrĩ, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>nĩ getha ũtuĩke wa gũkinyia ũhoro wa kũhonokania o ituri-inĩ ciothe cia thĩ.  </s></f>"},{ID:13,
Text:"<fArial Black><s1846>Nao andũ arĩa mataarĩ Ayahudi maaigua ũhoro ũcio,</s></f>"},{ID:13,
Text:"<fArial Black><s1846> magĩkena, magĩgĩkumia ũhoro wa Ngai: </s></f>"},{ID:14,
Text:"<fArial Black><s1846>nao arĩa othe maathĩrĩirio kuona muoyo wa tene na tene magĩitĩkia.</s></f>"},{ID:14,
Text:"<fArial Black><s1846>Naguo Ũhoro wa Mwathani ũgĩkĩhunja bũrũri ũcio wothe.  </s></f>"},{ID:15,
Text:"<fArial Black><s1846>No rĩrĩ, Ayahundi makĩhatĩrĩria atumia arĩa meamũrĩire Ngai,</s></f>"},{ID:15,
Text:"<fArial Black><s1846> o arĩa maarĩ igweta, o na anene a itũũra, </s></f>"},{ID:16,
Text:"<fArial Black><s1846>makĩrutithia ngũĩ nĩguo Paul na Barnaba manyarirũo,</s></f>"},{ID:16,
Text:"<fArial Black><s1846> makĩmaingata na hinya moime ndere-inĩ ciao.  </s></f>"},{ID:17,
Text:"<fArial Black><s1846>No-o magĩthukia magũrũ mao rũkũngũ rũitĩke, </s></f>"},{ID:18,
Text:"<fArial Black><s1846>kũmenyũo atĩ nĩ maatigana nao, </s></f>"},{ID:17,
Text:"<fArial Black><s1846>magĩthiĩ Ikonio.  Nao arutwo magĩkena o gũkena, </s></f>"},{ID:18,
Text:"<fArial Black><s1846>na makĩiyũrũo nĩ Muoyo Mũtheru</s></f>"},{ID:18,
Text:"<fArial Black><s1846> 
Ciugo cia Mwathani</s></f>"},{
Text:"<fArial Black><s1846>THABURI YA GŨCOKERŨO</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Thaburi 
100:2; 3; 5</s></f>"},{ID:2,
Text:"<fArial Black><s1846>ICOKIA	
Tũrĩ kĩrĩndĩ gĩaku, Mwathani, nĩ ithuĩ ng’ondu ciaku</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Tungatĩrai Mwathani mũkenete; </s></f>"},{ID:4,
Text:"<fArial Black><s1846>ũkai mbere-inĩ yake mũgĩkũngũyagia.</s></f>"},{ID:4,
Text:"<fArial Black><s1846>ICOKIA	
Tũrĩ kĩrĩndĩ gĩaku, Mwathani, nĩ ithuĩ ng’ondu ciaku</s></f>"},{ID:5,
Text:"<fArial Black><s1846>Menyai atĩ we Mwathani nĩwe Ngai: </s></f>"},{ID:6,
Text:"<fArial Black><s1846>nĩwe watũũmbire, ithuĩ tũrĩ ake; </s></f>"},{ID:7,
Text:"<fArial Black><s1846>tũrĩ kĩrĩndĩ gĩake, 
nĩ ithuĩ ng’ondu ciake kwĩrĩithĩria</s></f>"},{ID:6,
Text:"<fArial Black><s1846>ICOKIA	
Tũrĩ kĩrĩndĩ gĩaku, Mwathani, nĩ ithuĩ ng’ondu ciaku</s></f>"},{ID:7,
Text:"<fArial Black><s1846>Nĩ gũkorũo Mwathani nĩ mwega; </s></f>"},{ID:8,
Text:"<fArial Black><s1846>ũtugi wake nĩ wa tene na tene, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>na wĩhokeku wake nĩ wa nginya njiarũa na njiarũa.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>ICOKIA	
Tũrĩ kĩrĩndĩ gĩaku, Mwathani, nĩ ithuĩ ng’ondu ciaku</s></f>"},{
Text:"<fArial Black><s1846>GĨTHOMO KĨA IGĨRĨ</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Kũguũrĩrio 
7:9. 14-17</s></f>"},{ID:2,
Text:"<fArial Black><s1846>GŨTHOMA KUUMA IBUKU RĨA KŨGUŨRĨRIO:</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Niĩ John ndonire ngĩona kĩrĩndĩ kĩingĩ mũno, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>gĩtangĩgereka nĩ mũndũ, kĩa andũ moimĩte ndũrĩrĩ-inĩ ciothe,</s></f>"},{ID:4,
Text:"<fArial Black><s1846> na marĩ a mĩhĩrĩga yothe na nduka ciothe o na mĩario yothe, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>marũgamĩte mbere-inĩ ya gĩtĩ kĩrĩa gĩa ũthamaki na mbere ya Gatũrũme,</s></f>"},{ID:5,
Text:"<fArial Black><s1846> mehumbĩte nguo njerũ ndaya, na me na makĩndũ moko.  </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Na niĩ ngĩmwĩra, Mũthuri ũyũ, nĩwe ũũĩ.  </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Nake akĩnjĩra atĩrĩ: Acio nĩo arĩa moimĩte </s></f>"},{ID:7,
Text:"<fArial Black><s1846>mĩnyamaro-inĩ ĩrĩa mĩnene, 
na nĩ maathambirie nguo ciao,</s></f>"},{ID:7,
Text:"<fArial Black><s1846> magĩgĩcierũhia na thakame ya Gatũrũme.  </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Nĩkĩo rĩu maikaraga mbere-inĩ ya gĩtĩ gĩa ũthamaki kĩa Ngai; </s></f>"},{ID:8,
Text:"<fArial Black><s1846>na nĩ kũmũtungatagĩra mũthenya na ũtukũ thĩinĩ wa hekarũ yake; </s></f>"},{ID:9,
Text:"<fArial Black><s1846>nake ũcio ũikarĩire gĩtĩ gĩa ũthamaki egũtũũra  aarĩte hema yake igũrũ rĩao.  </s></f>"},{ID:9,
Text:"<fArial Black><s1846>Nao matirĩ hingo magacoka kũhũta, kana macoke kũnyota; </s></f>"},{ID:10,
Text:"<fArial Black><s1846>o narĩo riũa rĩtirĩ hingo rĩkamacina, kana ũrugarĩ mũnene o na ũrĩkũ; </s></f>"},{ID:10,
Text:"<fArial Black><s1846>nĩ gũkorũo Gatũrũme karĩa ge gĩtĩ-inĩ gĩa ũthamaki 
gatagatĩ egũtũũra arĩ o mũrĩithi wao,</s></f>"},{ID:11,
Text:"<fArial Black><s1846>amatongoragie amakinyagie ithima-inĩ cia maaĩ marĩa ma muoyo; </s></f>"},{ID:11,
Text:"<fArial Black><s1846>nake Ngai nĩ ekũmagiria maithori mothe mathire maitho mao.</s></f>"},{ID:12,
Text:"<fArial Black><s1846>Ciugo cia Mwathani.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>RŨĨMBO RWA INJIRI</s></f>"},{ID:14,
Text:"<fArial Black><s1846>John 10, 14</s></f>"},{ID:14,
Text:"<fArial Black><s1846>						       
Alleluya, Alleluya			   </s></f>"},{ID:14,
Text:"<fArial Black><s1846>Mwathani ekuuga: Niĩ nĩ niĩ mũrĩithi ũrĩa mwega; </s></f>"},{ID:15,
Text:"<fArial Black><s1846>nĩ njũĩ ng’ondu ciakwa mwene, o nacio ng’ondu ciakwa nĩ injũĩ.</s></f>"},{ID:15,
Text:"<fArial Black><s1846>Alleluya</s></f>"},{
Text:"<fArial Black><s1846>GĨTHOMO KĨA INJIRI</s></f>"},{ID:2,
Text:"<fArial Black><s1846>John 10:27-30</s></f>"},{ID:2,
Text:"<fArial Black><s1846>GŨTHOMA INJIRI YA MŨTHURE JOHN: </s></f>"},{ID:3,
Text:"<fArial Black><s1846>Hĩndĩ ĩo Yesu nĩ  oigire: Ng’ondu ciakwa-rĩ, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>nĩ ciiguaga mũgambo wakwa, na niĩ nĩ ndĩciũĩ, nacio ikanũmĩrĩra; </s></f>"},{ID:4,
Text:"<fArial Black><s1846>na niĩ ngacihe muoyo wa tene na tene,</s></f>"},{ID:5,
Text:"<fArial Black><s1846>na itirĩ hingo ikora, o rĩ, o rĩ, na gũtirĩ ũngĩgacihuria ciume moko-inĩ makwa. </s></f>"},{ID:5,
Text:"<fArial Black><s1846> Awa, ũrĩa ũheete cio, nĩ mũnene kũrĩ othe; </s></f>"},{ID:6,
Text:"<fArial Black><s1846>na gũtirĩ ũngĩhota gũcihuria  ciume moko-inĩ ma Ithe witũ.  </s></f>"},{ID:7,
Text:"<fArial Black><s1846>Niĩ na Ithe witũ tũrĩ ũmwe.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Injiri theru ya Mwathani </s></f>"}],VideoDuration:0,Style:{Background:{Image:"sky4.jpg",Luminosity:-30}},
Text:"KIUMIA KIA INYA KIA IRIUKIRO MWAKA C"},{Guid:"NwnBTWUzBEWGBbtdzzDCGA",Verses:[{Style:{Body:{FontStyle:{Fill:{Type:0,Color:"FF9BBB59"},Stroke:{Type:0,Color:"FFFEFEFE"},ShadowColor:"FFCCCCCC",ShadowRadius:35,ShadowDirection:-135,ShadowDepth:24}}},
Text:"<u><fArial Black><s1846>KIUMIA KIA ITHANO 
KIA IRIUKIRO MWAKA C</s></f></u>"},{ID:2,
Text:"<fArial Black><s1846>GĨTHOMO KĨA MBERE</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Atũmwo 
14:21-27</s></f>"},{ID:2,
Text:"<fArial Black><s1846>GŨTHOMA KUUMA IBUKU RĨA ATŨMWO:</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Hĩndĩ ĩo, Paul na Barnaba magĩcoka Listria, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>Ikonio na Antiokia, makĩũmagĩrĩria arutwo ngoro,</s></f>"},{ID:4,
Text:"<fArial Black><s1846> makĩmataaraga atĩ marũmagie  wega morutani marĩa ma Wĩtĩkio,</s></f>"},{ID:5,
Text:"<fArial Black><s1846> makĩmaririkania atĩ ũthamaki wa </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Ngai ndũngĩtonyeka nĩ ithuĩ tiga o twambire kuona mathĩna maingĩ. </s></f>"},{ID:6,
Text:"<fArial Black><s1846> Na maarĩkia kũmathurĩra andũ a gũtuĩka athuri makanitha-inĩ mothe, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>na kũhoya Ngai makĩĩgiragia kũrĩa irio, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>makĩmatigĩra Mwathani o we mehokete.  </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Magĩcoka magĩtuĩkanĩria bũrũri wa Pisidia, magĩkinya Panfilia. </s></f>"},{ID:8,
Text:"<fArial Black><s1846> Na maarĩkia kũheana Ũhoro wa Ngai kũu Perje, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>magĩtherera magĩkinya Atalia; makiuma kuo, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>magĩcoka Antiokia mahaicĩte marikabu.  Kũu nĩkuo moimĩte, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>maarĩkia kũhoerũo Ngai atĩ maheo </s></f>"},{ID:11,
Text:"<fArial Black><s1846>Wega wake wa kũmahotithia kũruta wĩra o ro ũcio rĩu maarĩkĩtie.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>  Na maakinya kuo, makĩũngania andũ a kanitha, </s></f>"},{ID:12,
Text:"<fArial Black><s1846>makĩmahe  ũhoro wa maũndũ marĩa mothe Ngai  ekĩte hamwe nao,</s></f>"},{ID:12,
Text:"<fArial Black><s1846> o na ũrĩa aahingũrĩire andũ a Ndũrĩrĩ mũrango nĩguo maũtonyere, </s></f>"},{ID:13,
Text:"<fArial Black><s1846>na matuĩke a gwĩtĩkia.</s></f>"},{ID:13,
Text:"<fArial Black><s1846> 
Ciugo cia Mwathani</s></f>"},{
Text:"<fArial Black><s1846>THABURI YA GŨCOKERŨO</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Thaburi 
145: 8-9;10-11;12-13</s></f>"},{ID:2,
Text:"<fArial Black><s1846>ICOKIA	
Nĩ ngagoocaga rĩĩtwa rĩaku, Mwathani</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Mwathani nĩ muuma andũ, 
ningĩ nĩ wa matha maingĩ; </s></f>"},{ID:4,
Text:"<fArial Black><s1846>ndahiũhaga kũrakara, na e na ũtugi mũnene.  Mwathani-rĩ, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>nĩ ekaga andũ othe wega; 
indo ciothe iria aathondekire gũtirĩ atarĩ tha nakĩo.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>ICOKIA	
Nĩ ngagoocaga rĩĩtwa rĩaku, Mwathani</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Mawĩra macio maku mothe, Mwathani, </s></f>"},{ID:7,
Text:"<fArial Black><s1846>megũtũũra o magũcokagĩria ngatho; 
nao andũ arĩa maiguaine nawe,</s></f>"},{ID:7,
Text:"<fArial Black><s1846> kũgatha no matũre makũgathaga.  </s></f>"},{ID:8,
Text:"<fArial Black><s1846>Megũtũũra moigaga ũrĩa ũthamaki waku wĩ riri, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>o magĩteretaga ũhoro wa ũrĩa wee wĩ na ũhoti.</s></f>"},{ID:8,
Text:"<fArial Black><s1846>ICOKIA	
Nĩ ngagoocaga rĩĩtwa rĩaku, Mwathani</s></f>"},{ID:9,
Text:"<fArial Black><s1846>Maũndũ macio maku ma ũhoti </s></f>"},{ID:10,
Text:"<fArial Black><s1846>mamamenyithie ciana cia kĩrĩndĩ, </s></f>"},{ID:11,
Text:"<fArial Black><s1846>o gwata ũthamaki waku, mamere ũrĩa ũkaru waguo  wĩ riri, </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Ũthamaki waku nĩ ũrĩa wa tene na tene, </s></f>"},{ID:11,
Text:"<fArial Black><s1846>wathani waku-rĩ, ũtũũraga nginya njiarũa na njiarũa.  </s></f>"},{ID:11,
Text:"<fArial Black><s1846>ICOKIA	
Nĩ ngagoocaga rĩĩtwa rĩaku, Mwathani</s></f>"},{
Text:"<fArial Black><s1846>GĨTHOMO KĨA IGĨRĨ</s></f>"},{ID:2,
Text:"<fArial Black><s1846>Kũguũrĩrio 
21:1-5</s></f>"},{ID:2,
Text:"<fArial Black><s1846>GŨTHOMA KUUMA IBUKU RĨA KŨGUŨRĨRIO:</s></f>"},{ID:3,
Text:"<fArial Black><s1846>Niĩ John ngĩcoka ngĩona igũrũ rĩerũ o na thĩ njerũ; </s></f>"},{ID:4,
Text:"<fArial Black><s1846>amu igũrũ rĩrĩa rĩa mbere o na thĩ ĩrĩa ya mbere </s></f>"},{ID:5,
Text:"<fArial Black><s1846>nĩ gũthenga ciathengete igathira; iria rĩrĩa inene narĩo rĩgakĩaga.</s></f>"},{ID:5,
Text:"<fArial Black><s1846>  Na ngĩona itũũra rĩrĩa itherũ, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>Jerusalemu ĩrĩa njerũ, rĩgĩikũrũka  rĩkiuma Igũrũ kwĩ Ngai, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>rĩthagathagĩtwo  ta mũhiki agemeirio mũthuri  we.  </s></f>"},{ID:7,
Text:"<fArial Black><s1846>Na ngĩigua mũgambo mũnene woima gĩtĩ-inĩ kĩrĩa gĩa ũthamaki woiga:</s></f>"},{ID:7,
Text:"<fArial Black><s1846> Atĩrĩrĩ, gĩikaro kĩa Ngai kĩ hamwe na andu, </s></f>"},{ID:8,
Text:"<fArial Black><s1846>nake  nĩ egukarania nao, nao matuike andu ake  nake Ngai we mwene,</s></f>"},{ID:8,
Text:"<fArial Black><s1846>agiyage ohamwe nao e Ngai wao.  </s></f>"},{ID:9,
Text:"<fArial Black><s1846>nake ni ekũmagiria maithori mothe mathire maitho mao;</s></f>"},{ID:8,
Text:"<fArial Black><s1846> nakĩo gĩkuũ gũtirĩ hingo gĩgacoka  kũgĩa, </s></f>"},{ID:9,
Text:"<fArial Black><s1846>o na gũtirĩ hingo gũgacoka kũgĩa na kĩeha, kana kĩrĩro, kana ruo; </s></f>"},{ID:9,
Text:"<fArial Black><s1846>maũndũ marĩa ma mbere nĩ mathengu magathira.  </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Nake ũrĩa ũtũire aikarĩire gĩtĩ gĩa ũthamaki akiuga: Nĩ atĩrĩ, </s></f>"},{ID:11,
Text:"<fArial Black><s1846>maũndũ mothe nĩ kũmerũhia ndĩramerũhia.  </s></f>"},{ID:10,
Text:"<fArial Black><s1846>Ciugo cia Mwathani.</s></f>"},{ID:11,
Text:"<fArial Black><s1846>RŨĨMBO RWA INJIRI</s></f>"},{ID:12,
Text:"<fArial Black><s1846>John 13, 34
	</s></f>"},{ID:12,
Text:"<fArial Black><s1846>					       
Alleluya, Alleluya			   </s></f>"},{ID:12,
Text:"<fArial Black><s1846>Mwathani ekuuga ũũ: ngũmũhe rĩathani rĩerũ: </s></f>"},{ID:13,
Text:"<fArial Black><s1846>nĩ atĩ mwendane; o ta ũguo niĩ ndĩmwendete, </s></f>"},{ID:14,
Text:"<fArial Black><s1846>inyuĩ mwendane o ro ũguo inyuene.</s></f>"},{ID:13,
Text:"<fArial Black><s1846>Alleluya</s></f>"},{
Text:"<fArial Black><s1846>GĨTHOMO KĨA INJIRI</s></f>"},{ID:2,
Text:"<fArial Black><s1846>John 
13:31-33, 34-35</s></f>"},{ID:2,
Text:"<fArial Black><s1846>GŨTHOMA INJIRI YA MŨTHURE JOHN:
 </s></f>"},{ID:3,
Text:"<fArial Black><s1846>Juda oima nyũmba-inĩ ya irĩĩro, Yesu agĩkiuga atĩrĩrĩ: </s></f>"},{ID:4,
Text:"<fArial Black><s1846>Rĩu nĩ hĩndĩ Mũrũ wa mũndũ agoocithĩtio nake Ngai akagoocithio e thĩinĩ wake.</s></f>"},{ID:3,
Text:"<fArial Black><s1846>  Na rĩrĩ, Ngai aakorũo agoocithĩtio e thĩinĩ wake, Ngai o nake nĩ ekũmũgoocithia  e thĩinĩ wake mwene, </s></f>"},{ID:4,
Text:"<fArial Black><s1846>na nĩ ekũmũgoocithia o narua.  Twana tũtũ, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>no kahinda kanini ndigairie ga gũikarania na inyuĩ.  Rĩu ngũmũhe rĩathani  rĩerũ, </s></f>"},{ID:5,
Text:"<fArial Black><s1846>nĩ atĩ mwendane; o ta ũguo niĩ ndĩmwendete, </s></f>"},{ID:6,
Text:"<fArial Black><s1846>inyuĩ mwendane o ro ũguo inyuene.  </s></f>"},{ID:7,
Text:"<fArial Black><s1846>Nĩ ũguo  andu othe marĩmenyaga mũrĩ  arutwo akwa, mwatũũra mwendaine.</s></f>"},{ID:6,
Text:"<fArial Black><s1846>Injiri theru ya Mwathani </s></f>"}],VideoDuration:0,
