{IsBibleVerseCollection:1,Songs:[{Guid:"22YsjSUY0EmZqhW8PC336A",Verses:[{
Text:"<fArial Black><s2769>DOMINIKA YA TANO MWAKA B</s></f>"},{ID:2,
Text:"<fArial Black><s2769>SOMO LA KWANZA Ayubu 7:1-4,6-7</s></f>"},{ID:2,
Text:"<fArial Black><s2769>Somo katika kitabu cha Ayubu</s></f>"},{ID:3,
Text:"<fArial Black><s2769>Ayubu alisema:
Je, mtu hana kazi ngumu duniani? </s></f>"},{ID:4,
Text:"<fArial Black><s2769>Hatumiki kama mtu wa mshahara? Kama mtumwa </s></f>"},{ID:5,
Text:"<fArial Black><s2769>anayetamani kivuli kidogo; kama mfanyakazi </s></f>"},{ID:6,
Text:"<fArial Black><s2769>anayetazamia mshahara wake, ndivyo nami napata </s></f>"},{ID:7,
Text:"<fArial Black><s2769>miezi ya usumbufu na kupewa siku za mateso.</s></f>"},{ID:6,
Text:"<fArial Black><s2769>Nilalapo kitandani najisemea: kutakucha wakati gani? </s></f>"},{ID:7,
Text:"<fArial Black><s2769>Nikiamka naona kwamba jioni inakawia! </s></f>"},{ID:7,
Text:"<fArial Black><s2769>Hivi nazidi kusumbuka nahangaika hadi mapambazuko. </s></f>"},{ID:8,
Text:"<fArial Black><s2769>Siku zangu hupita upesi kama chombo cha mfumaji; </s></f>"},{ID:8,
Text:"<fArial Black><s2769>hupita bila matumaini.
Kumbuka ya kwamba uzima </s></f>"},{ID:9,
Text:"<fArial Black><s2769>wangu ni pumzi tu; macho yangu hayataona furaha tena.</s></f>"},{ID:9,
Text:"<fArial Black><s2769>Neno la Bwana (TUMSHUKURU MUNGU)</s></f>"},{ID:10,
Text:"<fArial Black><s2769>ZABURI YA KUITIKIZANA  			
Zaburi 147:1-2, 3-4, 5-6 (K. tazama 3a)</s></f>"},{ID:2,
Text:"<fArial Black><s2769>K. Msifuni Bwana, yeye anawaponya waliovunjika moyo.</s></f>"},{ID:3,
Text:"<fArial Black><s2769>Jinsi gani ni vema kumwimbia Mungu wetu sifa;</s></f>"},{ID:4,
Text:"<fArial Black><s2769>kwa maana kwapendeza, na yastahili kumsifu yeye.</s></f>"},{ID:5,
Text:"<fArial Black><s2769>Bwana anaijenga Yerusalemu, </s></f>"},{ID:6,
Text:"<fArial Black><s2769>anawakusanya 
Waisraeli waliotawanyika. </s></f>"},{ID:6,
Text:"<fArial Black><s2769>K. Msifuni Bwana, yeye anawaponya waliovunjika moyo.</s></f>"},{ID:7,
Text:"<fArial Black><s2769>Yeye anawaponya waliovunjika moyo, na kuvitibu vidonda vyao,</s></f>"},{ID:8,
Text:"<fArial Black><s2769>ameiweka idadi ya nyota, anaziita zote kwa jina. </s></f>"},{ID:9,
Text:"<fArial Black><s2769>Msifuni Bwana, yeye anawaponya waliovunjika moyo.</s></f>"},{ID:10,
Text:"<fArial Black><s2769>Bwana wetu ni mkuu na mwenye nguvu nyingi,
hekima yake haina kikomo.</s></f>"},{ID:11,
Text:"<fArial Black><s2769>Bwana huwategemeza wanyonge, huwaangusha waovu mpaka chini. </s></f>"},{ID:12,
Text:"<fArial Black><s2769>Msifuni Bwana, yeye anawaponya waliovunjika moyo. </s></f>"},{ID:13,
Text:"<fArial Black><s2769>SOMO LA PILI  			  	
1 Wakorintho 9:16-19, 22-23</s></f>"},{ID:2,
Text:"<fArial Black><s2769>Somo katika barua ya kwanza ya Mtakatifu Paulo kwa Wakorintho</s></f>"},{ID:3,
Text:"<fArial Black><s2769>Ndugu zangu: Nikiihubiri Injili, sina sababu ya kujisifu. Wajibu huo nimetwikwa. </s></f>"},{ID:4,
Text:"<fArial Black><s2769>Ole wangu nisipoihubiri Injili. Maana nikifanya </s></f>"},{ID:5,
Text:"<fArial Black><s2769>kazi hii kwa hiari, nitatuzwa.</s></f>"},{ID:5,
Text:"<fArial Black><s2769> Lakini nisipoichagua mwenyewe, nimekabidhiwa </s></f>"},{ID:6,
Text:"<fArial Black><s2769>madaraka tu. Hapo tuzo yangu ni nini?</s></f>"},{ID:6,
Text:"<fArial Black><s2769>Ni hili: nihubiri Injili bila kudai kitu, wala kutumia </s></f>"},{ID:7,
Text:"<fArial Black><s2769>haki yangu ninayopewa na Injili. Maana hivyo nina uhuru kwa wote, </s></f>"},{ID:8,
Text:"<fArial Black><s2769>naweza kujifanya mtumishi wa watu wote, nipate kuwavuta wengi zaidi. </s></f>"},{ID:8,
Text:"<fArial Black><s2769>Kwa watu dhaifu nalikuwa dhaifu, nipate kuwavuta wadhaifu.</s></f>"},{ID:9,
Text:"<fArial Black><s2769>Nimekuwa yote kwa wote, nipate kuwaokoa walau baadhi yao </s></f>"},{ID:10,
Text:"<fArial Black><s2769>kwa namna yoyote.
Hayo yote nayafanya </s></f>"},{ID:11,
Text:"<fArial Black><s2769>kwa ajili ya Injili, nipate kuwa mshiriki wake.</s></f>"},{ID:11,
Text:"<fArial Black><s2769>Neno la Bwana. (TUMSHUKURU BWANA)</s></f>"},{ID:12,
Text:"<fArial Black><s2769>SHANGILIO LA INJILI  Mathayo 8:17 </s></f>"},{ID:13,
Text:"<fArial Black><s2769>Aleluya. Aleluya 
Kristu Mwenyewe amejitwika udhaifu</s></f>"},{ID:14,
Text:"<fArial Black><s2769>wetu, amechukua magonjwa yetu. Alleluya</s></f>"},{ID:15,
Text:"<fArial Black><s2769>INJILI 						
Marko 1:29-39</s></f>"},{ID:14,
Text:"<fArial Black><s2769>Somo la Injili takatifu ilivyoandikwa na Marko</s></f>"},{ID:15,
Text:"<fArial Black><s2769>(UTUKUFU KWAKO EE BWANA)</s></f>"},{ID:3,
Text:"<fArial Black><s2769>Wakati ule: Yesu alipotoka kwenye sinagogi, </s></f>"},{ID:4,
Text:"<fArial Black><s2769>alikwenda mara pamoja na Yakobo na Yohane </s></f>"},{ID:5,
Text:"<fArial Black><s2769>katika nyumba ya Simoni na Andrea.</s></f>"},{ID:4,
Text:"<fArial Black><s2769> Hapo mkwewe Simoni alikuwa amelala 
kitandani </s></f>"},{ID:5,
Text:"<fArial Black><s2769>akishikwa na homa. 
Mara wakampasha habari ya hali yake.</s></f>"},{ID:5,
Text:"<fArial Black><s2769>Akamkaribia, akamshika mkono na kumwinua. </s></f>"},{ID:6,
Text:"<fArial Black><s2769>Mara moja homa ikamwacha na akawatumikia.</s></f>"},{ID:6,
Text:"<fArial Black><s2769>Ilipofika jioni, baada ya kuzama jua, walimletea </s></f>"},{ID:7,
Text:"<fArial Black><s2769>wagonjwa wote na waliopagawa na pepo wabaya.</s></f>"},{ID:7,
Text:"<fArial Black><s2769>Mji mzima walikusanyika mlangoni pake. </s></f>"},{ID:8,
Text:"<fArial Black><s2769>Akawaponya wengi walioshikwa na magonjwa mbalimbali. </s></f>"},{ID:8,
Text:"<fArial Black><s2769>Akatoa pepo wabaya wengi, wala hakuwaruhusu </s></f>"},{ID:9,
Text:"<fArial Black><s2769>kusema, kwa kuwa walimjua.
Asubuhi na mapema,</s></f>"},{ID:10,
Text:"<fArial Black><s2769>kabla ya kupambazuka, aliamka, akaondoka, </s></f>"},{ID:11,
Text:"<fArial Black><s2769>na kwenda mahali pa nyika ili kusali. </s></f>"},{ID:12,
Text:"<fArial Black><s2769>Simoni na wenziwe wakamtafuta na walipomwona,</s></f>"},{ID:10,
Text:"<fArial Black><s2769>wakasema, \"Watu wote wanakutafuta.\" </s></f>"},{ID:11,
Text:"<fArial Black><s2769>Akawaambia, \"Twendeni mahali pengine katika vijiji vya jirani, </s></f>"},{ID:12,
Text:"<fArial Black><s2769>nipate kuhubiri huko pia. 
Hiyo ndiyo nia ya kuja kwangu.\" </s></f>"},{ID:13,
Text:"<fArial Black><s2769>Basi alitembea nchi yote ya Galilaya akihubiri katika </s></f>"},{ID:14,
Text:"<fArial Black><s2769>masinagogi yao na kuwatoa pepo wabaya.</s></f>"},{ID:13,
Text:"<fArial Black><s2769>Injili ya Bwana.
(SIFA KWAKO EE KRISTU)</s></f>"}],VideoDuration:0,
Text:"DOMINIKA YA TANO MWAKA B"},{Guid:"8RMt6ZhmekWWHnL4MiVKjw",Verses:[{
Text:"<fArial Black><s2769>KIUMIA GIA ITHANO KIA MWAKA B</s></f>"},{ID:2,
Text:"<fArial Black><s2769>GITHOME KIA MBERE  
AYUBU 7; 1-4,6-7</s></f>"},{ID:3,
Text:"<fArial Black><s2769>GUTHOMA IBUKU RIA AYUBU</s></f>"},{ID:4,
Text:"<fArial Black><s2769>Hindi iyo Ayubu agicoka, akiuria atiri; </s></f>"},{ID:5,
Text:"<fArial Black><s2769>Anga mundu to ta kugereruo agereiruo </s></f>"},{ID:6,
Text:"<fArial Black><s2769>ihinda riake ria gutuurio ita-ini guku thii? </s></f>"},{ID:7,
Text:"<fArial Black><s2769>Namo matuku make anga to ta matuku </s></f>"},{ID:8,
Text:"<fArial Black><s2769>ma uria mwandike wira? Nii-ri ndarii ta ngombo </s></f>"},{ID:9,
Text:"<fArial Black><s2769>iiririirie muno kiigunyi, ningi ta muthukumi uria </s></f>"},{ID:10,
Text:"<fArial Black><s2769>uthethukiire mucara wake. Nii niguo nduiriiruo </s></f>"},{ID:11,
Text:"<fArial Black><s2769>ati ngie na mieri ya tuhu, na ngaathiriruo </s></f>"},{ID:12,
Text:"<fArial Black><s2769>ndaarage maraara ma minoga. Riria ndakoma </s></f>"},{ID:13,
Text:"<fArial Black><s2769>njuragia atiri; Ndiriukira ri? Utuku ugagituika </s></f>"},{ID:14,
Text:"<fArial Black><s2769>no muraya na ndaaraga ngianganga o nginya gukie</s></f>"},{ID:15,
Text:"<fArial Black><s2769>Matuku makwa ni marathira na ihenya</s></f>"},{ID:16,
Text:"<fArial Black><s2769>rikirite ria kanyamu karia gakonjanithangia</s></f>"},{ID:17,
Text:"<fArial Black><s2769>uthi tama ugitumwo, ni guthira marathira itari </s></f>"},{ID:18,
Text:"<fArial Black><s2769>na undu uria ndiirigiriire. No kiririkane ati muoyo </s></f>"},{ID:19,
Text:"<fArial Black><s2769>wakwa no ruhuho: riitho riakwa ritigacoka kuona undu mwega</s></f>"},{ID:20,
Text:"<fArial Black><s2769>Kiugo kia Mwathani (NGAI AROGATHWO)</s></f>"},{ID:21,
Text:"<fArial Black><s2769>THABURI YA GUCOKERUO 
Thaburi 147; 1-2, 3-4,5-6</s></f>"},{ID:22,
Text:"<fArial Black><s2769>Icokia; Uhonie Mwathani, Wee Ngai wa utuuro </s></f>"},{ID:23,
Text:"<fArial Black><s2769>Goocai Mwathani; amu kugooca Ngai witu na ruimbo </s></f>"},{ID:24,
Text:"<fArial Black><s2769>ni undu mwega; kumukumia-ri niundu wi gikeno; </s></f>"},{ID:25,
Text:"<fArial Black><s2769>ningi noguo wagiriire. Mwathani niwe wakaga Jerusalem; </s></f>"},{ID:26,
Text:"<fArial Black><s2769>a Israeli aria aingate, niwe umagokagiriria</s></f>"},{ID:27,
Text:"<fArial Black><s2769>Icokia; Uhonie Mwathani, Wee Ngai wa utuuro </s></f>"},{ID:28,
Text:"<fArial Black><s2769><kFF990000>Andu aria athuthiku ngoro, ni kuhonia ......</k></s></f>"},{ID:29,
Text:"<fArial Black><s2769>njata o uria ciigana</s></f>"},{ID:30,
Text:"<fArial Black><s2769>Icokia; Uhonie Mwathani, Wee Ngai wa utuuro </s></f>"},{ID:31,
Text:"<fArial Black><s2769>Mwathani witu ni Munene; akagia uhoti muno; </s></f>"},{ID:32,
Text:"<fArial Black><s2769>umenyi wake nduri gituri. Andu aria ahoreri, </s></f>"},{ID:33,
Text:"<fArial Black><s2769>Mwathani ni amanyitagirira; no andu </s></f>"},{ID:34,
Text:"<fArial Black><s2769>aria aganu ni kuharurukia </s></f>"},{ID:35,
Text:"<fArial Black><s2769>amaharurukagia o nginya tiri-ni</s></f>"},{ID:36,
Text:"<fArial Black><s2769>Icokia; Uhonie Mwathani, Wee Ngai wa utuuro</s></f>"},{ID:37,
Text:"<fArial Black><s2769>GITHOMO KIA IGIRI
1 Akorintho 9;16-29; 22-23</s></f>"},{ID:38,
Text:"<fArial Black><s2769>Ariu a Ithe witu, ni gukoruo ona ndatuika </s></f>"},{ID:39,
Text:"<fArial Black><s2769>ni hunjagia injiri-ri, ucio ti undu ingihota kwirahira, </s></f>"},{ID:40,
Text:"<fArial Black><s2769>amu nii ndiri hindi itabatairio ni kuhunjia, </s></f>"},{ID:41,
Text:"<fArial Black><s2769>na ingitiga kuhinjia Injiri kai ndagia na haaro-i! </s></f>"},{ID:42,
Text:"<fArial Black><s2769>Tondu ingirutaga wira ucio na kwiyendera, </s></f>"},{ID:43,
Text:"<fArial Black><s2769>ndaheo ngerenwa, no ingikoruo ti kwiyendera gwakwa -ri, </s></f>"},{ID:44,
Text:"<fArial Black><s2769>hindi io no gutuike ni uramati ndiihokeiruo. </s></f>"},{ID:45,
Text:"<fArial Black><s2769>Hakiri uguo-ri, ngerenwa yakwa ni ki? Ni atiri, </s></f>"},{ID:46,
Text:"<fArial Black><s2769>ati hindi iria nguhunjia Injiri, ngumuhunjiria </s></f>"},{ID:47,
Text:"<fArial Black><s2769>hatari kindu ikurutiruo, ngakirega kurandura </s></f>"},{ID:48,
Text:"<fArial Black><s2769>kiria ndii na kihooto gia kuheagwo ndi muhunjia wa Injiri. </s></f>"},{ID:49,
Text:"<fArial Black><s2769>Amu-ri, ona itari ngombo ya mundu o na uriku, </s></f>"},{ID:50,
Text:"<fArial Black><s2769>ni ndetuire ngombo ya andu othe ni getha nyone </s></f>"},{ID:51,
Text:"<fArial Black><s2769>aingi makiria magaruruke . Kuri andu aria manyihitie hinya </s></f>"},{ID:52,
Text:"<fArial Black><s2769>magarurukite ndane haanania na andu othe na </s></f>"},{ID:53,
Text:"<fArial Black><s2769>maundu mao ma muthemba o muthemba, niguo ngeragie </s></f>"},{ID:54,
Text:"<fArial Black><s2769>na njira ciothe gutuma amwe mahonoke. </s></f>"},{ID:55,
Text:"<fArial Black><s2769>Na maundu macio mothe ndimekaga ni undu wa Injiri, </s></f>"},{ID:56,
Text:"<fArial Black><s2769>ni getha nduike umwe wa kugwatanira uguni wayo</s></f>"},{ID:57,
Text:"<fArial Black><s2769>Kiugo kia Mwathani (NGAI AROGATHWO)</s></f>"},{ID:58,
Text:"<fArial Black><s2769>RUIMBO RWA ALLELUYA 
(JOHANA 6; 63-68)</s></f>"},{ID:59,
Text:"<fArial Black><s2769>Alleluya. Alleluya Migambo yaku, Mwathani ni Muoyo na utuuro; </s></f>"},{ID:60,
Text:"<fArial Black><s2769>Wee we na ndeto cia muoyo wa tene na tene. Alleluya</s></f>"},{ID:61,
Text:"<fArial Black><s2769>GITHOMO KIA INJIRI (Marko 1; 29-39)</s></f>"},{ID:62,
Text:"<fArial Black><s2769>GUTHOMA INJIRI YA MUTHURE MARKO</s></f>"},{ID:63,
Text:"<fArial Black><s2769>Hindi iyo Yesu, moima thunagogi, magithii na </s></f>"},{ID:64,
Text:"<fArial Black><s2769>Jakubu na Johana magitonya nyuumba ya Simone </s></f>"},{ID:65,
Text:"<fArial Black><s2769>na Anderea. Na riri nyina wa mutumia wa Simone</s></f>"},{ID:66,
Text:"<fArial Black><s2769>agikoruo akomete e murwaru murimu wa kuhiu mwiri ; </s></f>"},{ID:67,
Text:"<fArial Black><s2769>makihe Yesu uhoro wake ooka; nake agithii akimunyita guoko; </s></f>"},{ID:68,
Text:"<fArial Black><s2769>akimukiria naguo murimu ukimutiga, agiitika kumatungaira. </s></f>"},{ID:69,
Text:"<fArial Black><s2769>Ningi hwa-ini, riua rigithua akireherwo aria mari arwaru othe, </s></f>"},{ID:70,
Text:"<fArial Black><s2769>o na aria mari na ndaimono. Na andu, othe a ituura makiungana hau </s></f>"},{ID:71,
Text:"<fArial Black><s2769>muromo-ini wa nyumba. Nake akihonia andu aingi aria maruarite mirimu </s></f>"},{ID:72,
Text:"<fArial Black><s2769>mithemba miingi, o na ndaimono nacio, agituma ciume andu; </s></f>"},{ID:73,
Text:"<fArial Black><s2769>na ndangiitikiria ndaimono ciarie, tondu ni cia muui. </s></f>"},{ID:74,
Text:"<fArial Black><s2769>Ningi ruci-ini, gutigaire ihinda inini gukie, agiukira akiumagara, </s></f>"},{ID:75,
Text:"<fArial Black><s2769>agithii handu hatathigwo ni andu, akihoera Ngai ho. </s></f>"},{ID:76,
Text:"<fArial Black><s2769>Nake Simon na aria angi maari nao, makimukinyira; makimukora, </s></f>"},{ID:77,
Text:"<fArial Black><s2769>makimwira atiri; Ni uracario ni andu othe, nake akimera atiri; </s></f>"},{ID:78,
Text:"<fArial Black><s2769>ni tuume guku tuthii micii iria ingi, ngaheana uhoro o nakuo nikio ndokire. </s></f>"},{ID:79,
Text:"<fArial Black><s2769>Agithii agitonyaga thunagogi cia kuu Galilea guothe, </s></f>"},{ID:80,
Text:"<fArial Black><s2769>akiheanaga uhoro na akirutaga andu ndaimono</s></f>"},{ID:81,
Text:"<fArial Black><s2769>Injiri Theru ya Mwathani 
(NI TWAGUMIA WEE KRISTU)  </s></f>"}],VideoDuration:0,
Text:"KIUMIA GIA ITHANO KIA MWAKA B"},{Guid:"bwJhX9U8/Umzl3v6V1fUtQ",Verses:[{
Text:"<fArial Black><s3076>GITHOMO KIA MBERE
Maundu ma alawi 13;1-2,45-46</s></f>"},{ID:2,
Text:"<fArial Black><s3076>GUTHOMA KUUMA IBUKU RIA MAUNDU MA ALAWI</s></f>"},{ID:3,
Text:"<fArial Black><s3076>Mwathani agikiariria Musa na Haruni, akimera atiri ; </s></f>"},{ID:4,
Text:"<fArial Black><s3076>Hindi iria mundu akagia na handu haimbu gikonde-ini </s></f>"},{ID:5,
Text:"<fArial Black><s3076>kia mwiri wake, kana thundo o na kana handu hari gathuku </s></f>"},{ID:6,
Text:"<fArial Black><s3076>thi-ini wa mwiri wake, naho handu hau honwo ta ari </s></f>"},{ID:7,
Text:"<fArial Black><s3076>mangu me mwiri -ini wake, hindi iyo </s></f>"},{ID:8,
Text:"<fArial Black><s3076>ni agatwaruo kwi Haruni , muthinjiri Ngai , </s></f>"},{ID:9,
Text:"<fArial Black><s3076>kana hari umwe wa ariu ake aria athinjiri Ngai.</s></f>"},{ID:6,
Text:"<fArial Black><s3076>nake mundu uria uruarite mangu akehumba nguo ndembukangu ,</s></f>"},{ID:7,
Text:"<fArial Black><s3076>na njuiiri ya mutwe wake iikarage iri nguurie </s></f>"},{ID:8,
Text:"<fArial Black><s3076>na ehumbage kiromo kia mwena wa iguru,
akanagirira uu: </s></f>"},{ID:9,
Text:"<fArial Black><s3076>ndi na ng'uki ndi na ng'uki namo matuku 
mothe </s></f>"},{ID:10,
Text:"<fArial Black><s3076>maria mundu ucio agaikara ari o na murimu ucio </s></f>"},{ID:11,
Text:"<fArial Black><s3076>ni akonagwo ari a ng'uki, na akeikaragia wiki  </s></f>"},{ID:12,
Text:"<fArial Black><s3076>utuuro wake ukagia na kuu githaka-ini </s></f>"},{ID:13,
Text:"<fArial Black><s3076>mbari iria ingi ya hau kiraaro-ini. </s></f>"},{ID:14,
Text:"<fArial Black><s3076>Kiugo kia Mwathani.(NGAI AROGATHWO) </s></f>"},{ID:11,
Text:"<fArial Black><s3076>THABURI YA GUCOKERUO</s></f>"},{ID:12,
Text:"<fArial Black><s3076>Thaburi 32:1-2, 5, 11 (K. 7)</s></f>"},{ID:12,
Text:"<fArial Black><s3076>ICOKIA; Uhonokia waku Mwathani, unjiurie ukeni.</s></f>"},{ID:13,
Text:"<fArial Black><s3076>Mundu gukena ni uria woheiruo wihia wake,</s></f>"},{ID:14,
Text:"<fArial Black><s3076>kuhitia gwake gugakihumbiriruo.</s></f>"},{ID:14,
Text:"<fArial Black><s3076>Gukenari ni uria Mwathani atangitua </s></f>"},{ID:15,
Text:"<fArial Black><s3076>mwaganu o uria utakiri na uhinga ngoro.</s></f>"},{ID:15,
Text:"<fArial Black><s3076>ICOKIA; Uhonokia waku Mwathani, unjiurie ukeni.</s></f>"},{ID:16,
Text:"<fArial Black><s3076>Ngitua gukumethia kuhitia gwakwa waganu wakwa </s></f>"},{ID:17,
Text:"<fArial Black><s3076>ngaigitiga kuuhumburira, ngiuga atiri,</s></f>"},{ID:17,
Text:"<fArial Black><s3076>mehia makwa ni kuumbura ngumoimburira Mwathani ; </s></f>"},{ID:18,
Text:"<fArial Black><s3076>Wee nawe ugikinjohera waganu wa ihitia riakwa.</s></f>"},{ID:18,
Text:"<fArial Black><s3076>ICOKIA; Uhonokia waku, Mwathani, unjiurie ukeni.</s></f>"},{ID:19,
Text:"<fArial Black><s3076>No gikenerei Mwathani mucanjamuke, inyui athingu , </s></f>"},{ID:20,
Text:"<fArial Black><s3076>na mukunguiye ni gukena inyuothe arungiriru ngoro.</s></f>"},{ID:20,
Text:"<fArial Black><s3076>ICOKIA; Uhonokia waku, Mwathani, unjiurie ukeni.</s></f>"},{ID:21,
